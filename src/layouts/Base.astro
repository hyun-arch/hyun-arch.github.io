---
import '../styles/global.css';
const { title, frontmatter } = Astro.props;
const pageTitle = frontmatter?.title ?? title ?? 'Aramirror';
const desc = frontmatter?.description ?? 'AI는 나를 대신하지 않는다 — 거울이 된다. 내 생각이 자산·가치로 기능하는 환경.';
const isMarkdown = Boolean(frontmatter);

// OG 이미지 자동생성 무기: 페이지 경로 → /og/<slug>.png (빌드타임 생성분과 매칭)
const path = Astro.url.pathname.replace(/\/$/, '');
const ogMatch = path.match(/^\/((?:build-logs|writings)\/[^/]+)$/);
const ogKey = ogMatch ? ogMatch[1] : 'home';
const ogImage = new URL(`/og/${ogKey}.png`, Astro.site).href;
const pageUrl = new URL(path || '/', Astro.site).href;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle} · Aramirror</title>
    <meta name="description" content={desc} />
    <meta name="theme-color" content="#ffffff" />
    <!-- 등장 애니메이션 활성화 표시. JS가 실제로 도는 경우에만 콘텐츠를 숨겼다 보여준다. -->
    <script is:inline>document.documentElement.classList.add('reveal-js');</script>
    <!-- OG / 공유카드 (자동생성 이미지) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Aramirror" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Spline+Sans+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <nav class="nav">
      <div class="wrap">
        <a class="brand" href="/">Aramirror<span class="dot">.</span></a>
        <button class="nav-toggle" aria-label="메뉴 열기" aria-expanded="false">☰</button>
        <div class="links" id="navLinks">
          <div class="nav-group">
            <button class="nav-top nav-top--hq" type="button">총괄실</button>
            <div class="nav-menu">
              <a href="/hq/index.html">대시보드</a>
              <a href="/vault">🔴 금고 (매출·재무)</a>
              <a href="/admin">관리자</a>
            </div>
          </div>
          <div class="nav-group">
            <button class="nav-top" type="button">세컨드브레인</button>
            <div class="nav-menu">
              <a href="/ask">되묻기 · 멘토</a>
              <a href="/shelf">📚 책장 (분류함)</a>
              <a href="/archive">📥 자료실</a>
              <a href="/wall">생각의 벽</a>
              <a href="/writings">글</a>
              <a href="/reading">독서 · 학습</a>
              <a href="/board">게시판</a>
              <a href="/publish">발행</a>
            </div>
          </div>
          <div class="nav-group">
            <button class="nav-top" type="button">시간 · 몰입</button>
            <div class="nav-menu">
              <a href="/flow">몰입 · Flow</a>
              <a href="/masters">거장 &amp; 스승</a>
              <a href="/sponge">스폰지 시계</a>
              <a href="/world">세계 시계</a>
            </div>
          </div>
          <div class="nav-group">
            <button class="nav-top" type="button">프로젝트</button>
            <div class="nav-menu">
              <a href="/gtb">농구클럽 · GTB</a>
              <a href="/spongeclub">스폰지클럽</a>
              <a href="/mission-rank">🏆 4주 과제 랭킹</a>
              <a href="/robil">로빌 · 3주차 미션</a>
              <a href="/studio">캐러셀 스튜디오</a>
              <a href="/reels">릴스 스튜디오</a>
              <a href="/shell-studio">셸 스튜디오</a>
              <a href="/calendar">달력 (Luxe Calendar)</a>
            </div>
          </div>
          <div class="nav-group">
            <button class="nav-top" type="button">기록 · 안내</button>
            <div class="nav-menu">
              <a href="/build-logs">Build Logs</a>
              <a href="/how">작동 방식</a>
              <a href="/studio-team">🎬 스튜디오팀 구조</a>
            </div>
          </div>
        </div>
      </div>
    </nav>

    {isMarkdown ? (
      <main class="wrap prose"><slot /></main>
    ) : (
      <slot />
    )}

    <footer>
      <div class="wrap">
        <div class="foot-links">
          <a href="/hq/index.html">총괄실</a>
          <a href="/how">작동 방식</a>
          <a href="/gtb">농구클럽 · GTB</a>
          <a href="/spongeclub">스폰지클럽</a>
        </div>
        Aramirror — 아람, 아름다운 사람. AI는 거울이 된다.<br />
        © 2026 Aram Huvis · built with Claude Code
      </div>
    </footer>
    <style is:global>
      footer .foot-links { display:flex; flex-wrap:wrap; gap:16px; justify-content:center; margin-bottom:14px; }
      footer .foot-links a { color:inherit; text-decoration:underline; text-underline-offset:2px; font-size:0.9rem; }

      /* ===== 5층 그룹 네비게이션 ===== */
      .nav-solo {
        font-size:0.88rem; font-weight:700; color:var(--fg); text-decoration:none;
        padding:6px 12px; border-radius:999px; border:1px solid var(--accent);
        background:var(--accent-soft); transition:background .15s, transform .15s; white-space:nowrap;
      }
      .nav-solo:hover { background:color-mix(in srgb, var(--accent) 22%, transparent); transform:translateY(-1px); }
      .nav-solo::after { display:none; }
      .nav-toggle { display:none; background:none; border:0; color:var(--fg); font-size:1.4rem; cursor:pointer; margin-left:auto; line-height:1; padding:6px; }
      .nav .links { align-items:center; }
      .nav-group { position:relative; }
      .nav-top {
        background:none; border:0; color:var(--muted); font:inherit; font-size:0.88rem;
        cursor:pointer; padding:6px 2px; display:inline-flex; align-items:center; gap:5px; letter-spacing:-0.01em;
      }
      .nav-top::after { content:"▾"; font-size:0.7em; opacity:0.6; transition:transform .2s; }
      .nav-group:hover .nav-top, .nav-group.open .nav-top { color:var(--fg); }
      .nav-group.open .nav-top::after { transform:rotate(180deg); }
      .nav-top--hq { color:var(--accent); font-weight:700; }
      .nav-top--hq::before { content:"●"; font-size:0.6em; vertical-align:middle; margin-right:2px; }
      .nav-menu {
        position:absolute; top:calc(100% + 10px); left:50%; transform:translateX(-50%) translateY(6px);
        min-width:172px; padding:8px; display:flex; flex-direction:column; gap:2px;
        background:var(--bg-1); border:1px solid var(--line); border-radius:14px;
        box-shadow:0 20px 44px rgba(196,110,54,0.20); opacity:0; visibility:hidden; transition:opacity .18s, transform .18s;
        z-index:60;
      }
      .nav-group:hover .nav-menu, .nav-group.open .nav-menu { opacity:1; visibility:visible; transform:translateX(-50%) translateY(0); }
      .nav-menu a { padding:9px 12px; border-radius:9px; font-size:0.9rem; color:var(--fg-soft); white-space:nowrap; }
      .nav-menu a:hover { background:var(--bg-2); color:var(--fg); }
      .nav-menu a::after { display:none; }

      @media (max-width: 820px) {
        .nav-toggle { display:block; }
        .nav .wrap { flex-wrap:wrap; }
        .nav .links {
          flex-basis:100%; flex-direction:column; align-items:stretch; gap:2px;
          margin-left:0; max-height:0; overflow:hidden; transition:max-height .28s ease;
        }
        .nav .links.open { max-height:78vh; overflow-y:auto; padding-bottom:14px; }
        .nav-group { border-top:1px solid var(--line-soft); }
        .nav-top { width:100%; justify-content:space-between; padding:14px 4px; font-size:1rem; }
        .nav-menu {
          position:static; transform:none; opacity:1; visibility:visible; box-shadow:none;
          border:0; background:none; padding:0 0 8px 12px; min-width:0; display:none;
        }
        .nav-group.open .nav-menu { display:flex; transform:none; }
        .nav-group:hover .nav-menu { opacity:1; }
      }
    </style>

    <script is:inline>
      // scroll reveal — 요소가 뷰포트에 들어오면 스르륵 나타남.
      // is:inline 으로 즉시 실행(무거운 번들/네트워크에 안 묶임) + 안전장치로 절대 백지 안 됨.
      (function () {
        var els = document.querySelectorAll('[data-reveal]');
        if (!els.length) return;
        function showAll() { for (var i = 0; i < els.length; i++) els[i].classList.add('in'); }
        if ('IntersectionObserver' in window) {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                var el = e.target;
                el.style.transitionDelay = (el.dataset.reveal ? Number(el.dataset.reveal) : 0) + 'ms';
                el.classList.add('in');
                io.unobserve(el);
              }
            });
          }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
          for (var i = 0; i < els.length; i++) io.observe(els[i]);
          // 안전장치: 어떤 이유로든 1초 안에 안 켜졌으면 전부 강제 표시(백지 방지)
          setTimeout(showAll, 1000);
        } else {
          showAll();
        }
      })();
    </script>

    <script>
      // 5층 그룹 네비 — 모바일 햄버거 + 그룹 펼치기
      const navToggle = document.querySelector('.nav-toggle');
      const navLinks = document.getElementById('navLinks');
      const groups = Array.from(document.querySelectorAll('.nav-group'));
      const isMobile = () => window.matchMedia('(max-width: 820px)').matches;

      navToggle?.addEventListener('click', () => {
        const open = navLinks?.classList.toggle('open');
        navToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      });

      groups.forEach((g) => {
        const top = g.querySelector('.nav-top');
        top?.addEventListener('click', (e) => {
          e.stopPropagation();
          const wasOpen = g.classList.contains('open');
          groups.forEach((o) => o.classList.remove('open'));
          if (!wasOpen) g.classList.add('open');
        });
      });

      // 바깥 클릭 시 닫기 (데스크톱 드롭다운)
      document.addEventListener('click', (e) => {
        if (!(e.target as HTMLElement).closest('.nav-group')) {
          groups.forEach((o) => o.classList.remove('open'));
        }
      });
    </script>

    <script>
      // 지하 엔진실 — 모든 페이지 열람을 자동 기록하고 window.aramLog를 전역 노출
      import { logEvent } from '../lib/events.js';
      logEvent('page_view', { path: location.pathname, ref: document.referrer || null });
    </script>
  </body>
</html>
