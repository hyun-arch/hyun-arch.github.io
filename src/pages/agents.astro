---
import Base from '../layouts/Base.astro';
const agents = [
  { n: '사고 파트너', role: '되묻는 거울', body: '따뜻하게 되물어 내 생각을 꺼낸다. 답을 대신 주지 않는다 — 패턴을 표면화하고 질문 하나를 돌려준다.' },
  { n: 'PM', role: '하루를 굴린다', body: '아침 브리핑(Must·Should·Nice)과 결정 대기 목록을 정리한다. 제안하고 승인받는다 — 자동으로 실행하지 않는다.' },
  { n: '연결 엔진', role: '그래프로 엮는다', body: '밤마다 쌓인 메모를 그래프로 컴파일해 반복 패턴과 숨은 연결을 찾는다. 동일 엔진, 입력에 따라 다른 의미.' },
  { n: '위키 에디터', role: '구조화하되 해석하지 않는다', body: '연결을 주제별 위키 글로 서술한다. 내 생각은 내 언어로. 소유권은 나에게.' },
  { n: '사이트 에디터', role: '자산으로 발행한다', body: '성숙한 글감을 골라 초안을 쓴다. 중복을 검사하고 기존 글과 교차 링크한다. 발행 버튼은 언제나 사람이 누른다.' },
];
---
<Base title="Agents">
  <section style="padding-top:80px">
    <div class="wrap">
      <p class="section-kicker">Agents</p>
      <h2>역할은 나뉘고, 결정은 내가 한다</h2>
      <p class="lead">각 에이전트는 한 가지 일을 잘한다. 손은 AI가, 생각과 발행은 사람이.</p>
      <div class="cards" style="grid-template-columns:1fr">
        {agents.map((a) => (
          <div class="card">
            <span class="n">{a.n} · <span style="color:var(--muted)">{a.role}</span></span>
            <p style="margin-top:8px">{a.body}</p>
          </div>
        ))}
      </div>
      <p class="lead" style="margin-top:24px;font-size:0.9rem">※ 에이전트 구성은 Aramirror가 자라며 계속 다듬어집니다. (현재 설계 초안)</p>
    </div>
  </section>
</Base>
