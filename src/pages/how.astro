---
import Base from '../layouts/Base.astro';

// 작동 방식 = 아라미러가 "어떻게 굴러가는지" 설명을 한 곳에 모은 페이지.
// (예전 Architecture + Agents 를 합침. 메인 메뉴에서 빼서 여기로.)
// 카드는 클릭하면 펼쳐진다 — 죽은 설명이 아니라 눌러서 여는 구조.

// 3층 흐름
const layers = [
  {
    n: '1층 · 사고', en: 'Divergence', rhythm: '실시간', status: 'live',
    title: '던진 생각을 그대로 포착',
    body: '텔레그램으로 떠오른 생각을 던진다. AI는 사고 엔진이지 노트 정리 도구가 아니다 — 대신 생각하지 않고, 되물어 내 생각을 꺼낸다. 입력 마찰은 0.',
    to: '/m/journal-capture', toLabel: 'journal 포착 열기',
  },
  {
    n: '2층 · 지식', en: 'Convergence', rhythm: '밤마다 자동', status: 'building',
    title: '연결을 발견하고 위키로 굳힌다',
    body: '쌓인 메모를 그래프로 엮어 반복 패턴과 숨은 연결을 찾는다. 내 생각(Self)과 외부 개념(External)을 교차해, 나 혼자선 못 본 연결을 가져온다. 주제마다 한 편의 위키 글로 정리된다.',
    to: '/m/threads', toLabel: 'threads 열기',
  },
  {
    n: '3층 · 자산', en: 'Transformation', rhythm: '필요할 때', status: 'seed',
    title: '지식을 공유 가능한 자산으로',
    body: '성숙한 주제는 글·발표·아카이브가 된다. AI가 초안을 쓰고, 판단·편집·발행은 언제나 사람이 한다. 내 사고 과정 자체가 포트폴리오가 된다.',
    to: '/publish', toLabel: '발행으로',
  },
];

// 그 흐름을 돌리는 AI 역할들
const agents = [
  { n: '사고 파트너', role: '되묻는 거울', status: 'live',
    body: '따뜻하게 되물어 내 생각을 꺼낸다. 답을 대신 주지 않는다 — 패턴을 표면화하고 질문 하나를 돌려준다. (지금 이 텔레그램 대화가 그 역할)' },
  { n: 'PM', role: '하루를 굴린다', status: 'building',
    body: '아침 브리핑(Must·Should·Nice)과 결정 대기 목록을 정리한다. 제안하고 승인받는다 — 자동으로 실행하지 않는다.' },
  { n: '연결 엔진', role: '그래프로 엮는다', status: 'building',
    body: '밤마다 쌓인 메모를 그래프로 컴파일해 반복 패턴과 숨은 연결을 찾는다. 동일 엔진, 입력에 따라 다른 의미.' },
  { n: '위키 에디터', role: '구조화하되 해석하지 않는다', status: 'seed',
    body: '연결을 주제별 위키 글로 서술한다. 내 생각은 내 언어로. 소유권은 나에게.' },
  { n: '사이트 에디터', role: '자산으로 발행한다', status: 'seed',
    body: '성숙한 글감을 골라 초안을 쓴다. 중복을 검사하고 기존 글과 교차 링크한다. 발행 버튼은 언제나 사람이 누른다.' },
];

const S = { live: '작동 중', building: '만드는 중', seed: '설계' };
---
<Base title="작동 방식">
  <section style="padding-top:80px">
    <div class="wrap" style="max-width:820px">
      <p class="section-kicker">How it works · 작동 방식</p>
      <h2>어떻게 굴러가는가</h2>
      <p class="lead">
        전체 지도가 <b>무엇이 있나</b>라면, 여기는 <b>어떻게 작동하나</b>.
        생각이 자산이 되는 3층 흐름과, 그 흐름을 맡은 AI 역할들. 카드를 누르면 펼쳐진다.
      </p>

      <h3 class="grp">🏗️ 흐름 — 생각 → 지식 → 자산</h3>
      <div class="stack">
        {layers.map((l) => (
          <details class="row">
            <summary>
              <span class={`dot ${l.status}`} title={S[l.status]}></span>
              <span class="row-n">{l.n}<span class="row-en">{l.en}</span></span>
              <span class="row-rhythm">{l.rhythm}</span>
              <span class="chev">▾</span>
            </summary>
            <div class="row-body">
              <p class="row-title">{l.title}</p>
              <p>{l.body}</p>
              <a class="jumpbtn" href={l.to}>{l.toLabel} →</a>
            </div>
          </details>
        ))}
      </div>

      <h3 class="grp">🤖 일꾼 — 역할은 나뉘고, 결정은 내가</h3>
      <p class="mini">손은 AI가, 생각·발행은 사람이.</p>
      <div class="stack">
        {agents.map((a) => (
          <details class="row">
            <summary>
              <span class={`dot ${a.status}`} title={S[a.status]}></span>
              <span class="row-n">{a.n}<span class="row-en">{a.role}</span></span>
              <span class="row-rhythm">{S[a.status]}</span>
              <span class="chev">▾</span>
            </summary>
            <div class="row-body">
              <p>{a.body}</p>
            </div>
          </details>
        ))}
      </div>

      <p class="legend2">
        <span><i class="dot live"></i>작동 중</span>
        <span><i class="dot building"></i>만드는 중</span>
        <span><i class="dot seed"></i>설계</span>
      </p>
    </div>
  </section>

  <style>
    .grp { margin: 44px 0 12px; font-size: 1.12rem; letter-spacing: -0.02em; }
    .mini { color: var(--muted); font-size: 0.92rem; margin: -4px 0 12px; }
    .stack { display: flex; flex-direction: column; gap: 8px; }

    .row {
      border: 1px solid var(--line); border-radius: 12px;
      background: var(--bg-card); overflow: hidden;
      transition: border-color 0.15s ease;
    }
    .row[open] { border-color: var(--fg); }
    .row > summary {
      display: flex; align-items: center; gap: 12px;
      padding: 15px 18px; cursor: pointer; list-style: none; user-select: none;
    }
    .row > summary::-webkit-details-marker { display: none; }
    .row > summary:hover { background: var(--bg-soft); }
    .row-n { font-weight: 700; letter-spacing: -0.01em; }
    .row-en { color: var(--muted); font-weight: 500; font-size: 0.85rem; margin-left: 9px; }
    .row-rhythm { color: var(--muted); font-size: 0.85rem; margin-left: auto; }
    .chev { color: var(--muted); font-size: 0.8rem; transition: transform 0.2s ease; }
    .row[open] .chev { transform: rotate(180deg); }

    .row-body {
      padding: 2px 18px 18px 40px; color: var(--fg-soft); line-height: 1.7;
      border-top: 1px solid var(--line-soft);
    }
    .row-body p { margin: 12px 0 0; }
    .row-title { font-weight: 700; color: var(--fg); }
    .jumpbtn {
      display: inline-block; margin-top: 14px;
      border: 1px solid var(--line); border-radius: 999px; padding: 7px 14px;
      font-size: 0.88rem; font-weight: 600; color: var(--fg); text-decoration: none;
    }
    .jumpbtn:hover { background: var(--bg-soft); }

    .dot { width: 8px; height: 8px; border-radius: 50%; flex: 0 0 auto; background: var(--line); }
    .dot.live { background: #2fa15a; }
    .dot.building { background: #e0a217; }
    .dot.seed { background: #5a6fd0; }

    .legend2 { display: flex; gap: 18px; margin: 26px 0 0; color: var(--muted); font-size: 0.85rem; }
    .legend2 span { display: inline-flex; align-items: center; gap: 7px; }
    .legend2 i.dot { display: inline-block; }
  </style>
</Base>
