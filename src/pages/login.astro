---
// 🟡 로그인 — 준민감(auth) 데이터를 여는 문.
// 실제 인증은 클라이언트에서 Supabase Auth(auth.js)로 처리한다.
import Base from '../layouts/Base.astro';
---
<Base title="로그인">
  <section class="lg-wrap">
    <div class="lg-card">
      <p class="section-kicker">🟡 로그인 · Auth</p>
      <h1>사장님 전용 로그인</h1>
      <p class="lg-sub">
        진행 프로젝트·준민감 정보는 로그인해야 열립니다.
        <br />(재무·매출 🔴 은 로그인과 무관하게 배포에 아예 없습니다.)
      </p>

      <form id="lgForm" class="lg-form" autocomplete="on" novalidate>
        <label class="lg-field">
          <span>이메일</span>
          <input id="lgEmail" type="email" name="email" required autocomplete="username"
            placeholder="you@aramhuvis.com" inputmode="email" />
        </label>
        <label class="lg-field">
          <span>비밀번호</span>
          <input id="lgPw" type="password" name="password" required autocomplete="current-password"
            placeholder="비밀번호" />
        </label>
        <button id="lgBtn" type="submit" class="lg-btn">로그인 →</button>
        <p id="lgMsg" class="lg-msg" role="status" aria-live="polite"></p>
      </form>

      <div id="lgSigned" class="lg-signed" hidden>
        <p class="lg-ok">✅ <b id="lgWho"></b> 로 로그인됨</p>
        <div class="lg-signed-actions">
          <a id="lgGo" class="lg-btn lg-btn-ghost" href="/projects">준민감 페이지로 →</a>
          <button id="lgOut" type="button" class="lg-btn lg-btn-ghost">로그아웃</button>
        </div>
      </div>

      <details class="lg-help">
        <summary>로그인이 안 되면? (사장님 1회 설정)</summary>
        <ol>
          <li>Supabase 대시보드 → <b>Authentication → Providers → Email</b> 켜기</li>
          <li>같은 화면에서 <b>“Confirm email”</b>는 꺼두면 편합니다(메일 인증 생략)</li>
          <li><b>Authentication → Users → Add user</b> 로 본인 이메일·비번 계정 1개 생성</li>
          <li>그 이메일·비번으로 위에서 로그인</li>
        </ol>
        <p class="ad-hint">보안 규칙상 계정 생성·비번 입력은 사장님 본인이 합니다. 코드(로그인 구조)는 준비돼 있습니다.</p>
      </details>
    </div>
  </section>

  <style>
    .lg-wrap { min-height: 72vh; display: grid; place-items: center; padding: 110px 0 80px; }
    .lg-card { width: min(440px, 92vw); border: 1px solid var(--line); border-radius: 20px;
      background: var(--bg-1); padding: 34px 30px; }
    .lg-card h1 { font-size: 1.7rem; font-weight: 800; letter-spacing: -0.03em; margin: 10px 0 10px; }
    .lg-sub { color: var(--fg-soft); font-size: 0.98rem; line-height: 1.6; margin: 0 0 24px; }
    .lg-form { display: flex; flex-direction: column; gap: 14px; }
    .lg-field { display: flex; flex-direction: column; gap: 6px; }
    .lg-field span { font-size: 0.82rem; color: var(--muted); font-weight: 600; }
    .lg-field input { font: inherit; font-size: 1rem; padding: 12px 14px; border-radius: 12px;
      border: 1px solid var(--line); background: var(--bg-2); color: var(--fg); }
    .lg-field input:focus { outline: none; border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-soft); }
    .lg-btn { font: inherit; font-size: 0.98rem; font-weight: 700; color: #fff; cursor: pointer;
      background: var(--accent); border: 1px solid var(--accent); border-radius: 12px; padding: 13px 18px;
      transition: transform .12s, opacity .15s; margin-top: 4px; }
    .lg-btn:hover { transform: translateY(-1px); }
    .lg-btn:disabled { opacity: 0.6; cursor: default; transform: none; }
    .lg-btn-ghost { color: var(--fg); background: var(--bg-2); border-color: var(--line); text-align: center; }
    .lg-msg { min-height: 1.2em; margin: 6px 0 0; font-size: 0.9rem; color: var(--muted); }
    .lg-msg.err { color: #ff8a8a; }
    .lg-msg.busy { color: var(--accent); }
    .lg-signed { text-align: center; }
    .lg-ok { font-size: 1.05rem; margin: 6px 0 18px; }
    .lg-signed-actions { display: flex; flex-direction: column; gap: 10px; }
    .lg-help { margin-top: 26px; border-top: 1px solid var(--line-soft); padding-top: 16px; }
    .lg-help summary { cursor: pointer; color: var(--fg-soft); font-size: 0.9rem; }
    .lg-help ol { margin: 12px 0 8px; padding-left: 20px; color: var(--fg-soft); font-size: 0.92rem; line-height: 1.7; }
    .lg-help .ad-hint { font-size: 0.84rem; color: var(--muted); margin: 0; }
  </style>

  <script>
    import { signIn, signOut, getUser, onAuthChange } from '../lib/auth.js';

    const form = document.getElementById('lgForm') as HTMLFormElement;
    const email = document.getElementById('lgEmail') as HTMLInputElement;
    const pw = document.getElementById('lgPw') as HTMLInputElement;
    const btn = document.getElementById('lgBtn') as HTMLButtonElement;
    const msg = document.getElementById('lgMsg') as HTMLElement;
    const signed = document.getElementById('lgSigned') as HTMLElement;
    const who = document.getElementById('lgWho') as HTMLElement;
    const goLink = document.getElementById('lgGo') as HTMLAnchorElement;
    const outBtn = document.getElementById('lgOut') as HTMLButtonElement;

    // ?redirect= 로 돌아갈 곳(오픈 리다이렉트 방지: 사이트 내부 경로만 허용)
    const params = new URLSearchParams(location.search);
    const raw = params.get('redirect') || '/projects';
    const redirect = raw.startsWith('/') && !raw.startsWith('//') ? raw : '/projects';
    goLink.href = redirect;

    function render(user) {
      if (user) {
        form.hidden = true;
        signed.hidden = false;
        who.textContent = user.email || '사장님';
      } else {
        form.hidden = false;
        signed.hidden = true;
      }
    }
    render(getUser());
    onAuthChange((s) => render(s?.user || null));

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.className = 'lg-msg busy';
      msg.textContent = '확인 중…';
      btn.disabled = true;
      try {
        await signIn(email.value.trim(), pw.value);
        msg.className = 'lg-msg';
        msg.textContent = '로그인 완료. 이동합니다…';
        setTimeout(() => { location.href = redirect; }, 500);
      } catch (err) {
        msg.className = 'lg-msg err';
        msg.textContent = (err as Error).message || '로그인 실패';
        btn.disabled = false;
      }
    });

    outBtn.addEventListener('click', async () => {
      await signOut();
      msg.className = 'lg-msg';
      msg.textContent = '';
      pw.value = '';
    });
  </script>
</Base>
