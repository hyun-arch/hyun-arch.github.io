---
import Base from '../layouts/Base.astro';

const ORIGIN = 'https://hyun-arch.github.io';
const strip = (s) => (s || '').replace(/\*\*/g, '').replace(/[*_`]/g, '').replace(/\s+/g, ' ').trim();
const stripKeepNL = (s) => (s || '').replace(/\*\*/g, '').replace(/[*_`]/g, '').replace(/[ \t]+/g, ' ').replace(/\n{3,}/g, '\n\n').trim();

function mapArticle(a, type) {
  const url = ORIGIN + a.url;
  const raw = typeof a.rawContent === 'function' ? a.rawContent() : '';
  const quoteMatch = raw.match(/^>\s?(.+)$/m);
  return {
    type,
    title: a.frontmatter.title || '무제',
    desc: strip(a.frontmatter.description || '') || (a.frontmatter.title ? strip(a.frontmatter.title) : '아라미러의 새 글이 올라왔습니다.'),
    date: a.frontmatter.date || '',
    tags: a.frontmatter.tags || ['Aramirror', '생각이자산', '성장', '리더십'],
    hook: quoteMatch ? strip(quoteMatch[1]) : '',
    body: stripKeepNL(raw),
    url,
  };
}

const blMods = import.meta.glob('./build-logs/*.md', { eager: true });
const wMods = import.meta.glob('./writings/*.md', { eager: true });
const blFiles = Object.values(blMods).map((a) => mapArticle(a, 'buildlog'));
const wFiles = Object.values(wMods).map((a) => mapArticle(a, 'writing'));
// 내가 쓴 글(writing)을 먼저, 그다음 빌드로그. 각각 최신순.
const articles = [...wFiles, ...blFiles].sort((a, b) => {
  if (a.type !== b.type) return a.type === 'writing' ? -1 : 1;
  return a.date < b.date ? 1 : -1;
});

function hashtags(tags) { return tags.map((t) => '#' + String(t).replace(/\s+/g, '')).join(' '); }
function cleanTitle(t) {
  const parts = t.split('—');
  return (parts.length > 1 ? parts.slice(1).join('—') : t).replace(/^#\d+\s*\w*\s*/, '').trim() || t.replace(/^#\d+\s*/, '');
}
const enc = encodeURIComponent;

// ── 플랫폼별 글자 한도 (0 = 무제한/블로그) ──
const LIMITS = { linkedin: 3000, threads: 500, x: 280, facebook: 5000, instagram: 2200, naver: 0 };

// X(트위터)는 한글·CJK를 2자로 계산한다(트위터 가중치 규칙). 정확히 세려면 가중 카운트.
function xWeight(s) {
  let w = 0;
  for (const ch of s) {
    const c = ch.codePointAt(0);
    const cjk =
      (c >= 0x1100 && c <= 0x115f) || (c >= 0x2e80 && c <= 0x303e) || (c >= 0x3041 && c <= 0x33ff) ||
      (c >= 0x3400 && c <= 0x4dbf) || (c >= 0x4e00 && c <= 0x9fff) || (c >= 0xa000 && c <= 0xa4cf) ||
      (c >= 0xac00 && c <= 0xd7a3) || (c >= 0xf900 && c <= 0xfaff) || (c >= 0xfe30 && c <= 0xfe4f) ||
      (c >= 0xff00 && c <= 0xff60) || (c >= 0xffe0 && c <= 0xffe6);
    w += cjk ? 2 : 1;
  }
  return w;
}
const lenBy = (key) => (key === 'x' ? xWeight : (s) => [...s].length);

// core(본문) + tail(링크·태그 접미사)가 한도에 들어가게 맞춘다. 넘치면 본문을 잘라 '…' + tail.
function fitText(core, limit, tail, weigh) {
  weigh = weigh || ((s) => [...s].length);
  const t = tail || '';
  const whole = core + t;
  if (!limit || weigh(whole) <= limit) return { text: whole, count: weigh(whole), fits: true };
  // 들어가는 최대 본문 길이를 이분 탐색
  let lo = 0, hi = [...core].length;
  const arr = [...core];
  const build = (n) => arr.slice(0, n).join('').replace(/\s+$/, '') + '…' + t;
  while (lo < hi) {
    const mid = Math.ceil((lo + hi) / 2);
    if (weigh(build(mid)) <= limit) lo = mid; else hi = mid - 1;
  }
  const text = build(lo);
  return { text, count: weigh(text), fits: weigh(text) <= limit };
}

// 카드 하나 만들기 — 항상 한도 안에 들어가게 + 카운트 표기.
function card(key, name, tone, core, tail, note, shareBuilder) {
  const limit = LIMITS[key];
  const f = fitText(core, limit, tail, lenBy(key));
  const out = { key, name, tone, text: f.text, count: f.count, limit, fits: f.fits, note };
  if (shareBuilder) {
    const s = shareBuilder(f.text);
    out.share = s.url; out.shareLabel = s.label;
  }
  return out;
}

// 빌드로그: 제목·핵심문장·요약으로 채널별 게시글 — 각 한도에 맞춰.
function genSummaryPosts(a) {
  const ct = cleanTitle(a.title);
  const hook = a.hook ? a.hook + '\n\n' : '';
  const core = `${hook}${ct}\n\n${a.desc}`;
  const link = `\n\n전문 → ${a.url}`;
  const tags = hashtags(a.tags);
  const shortTags = hashtags(a.tags.slice(0, 3));
  return [
    card('linkedin', 'LinkedIn', '전문·인사이트', core, `${link}\n\n${tags}`, '텍스트 복사 후 붙여넣기'),
    card('threads', 'Threads', '짧고 강하게', core, `${link}\n${shortTags}`, '스레드 500자 안에 맞춤 · 버튼으로 채워 열기',
      (txt) => ({ url: `https://www.threads.net/intent/post?text=${enc(txt)}`, label: '스레드에 채워 열기' })),
    card('x', 'X (Twitter)', '한 방', core, `${link}\n${shortTags}`, 'X 280자(한글은 2자 계산) 안에 맞춤',
      (txt) => ({ url: `https://x.com/intent/tweet?text=${enc(txt)}`, label: 'X에 채워 열기' })),
    card('facebook', 'Facebook (Meta)', '따뜻하게', core, `${link}\n${shortTags}`, '텍스트 복사 후 붙여넣기',
      () => ({ url: `https://www.facebook.com/sharer/sharer.php?u=${enc(a.url)}`, label: '페이스북 열기(링크)' })),
    card('instagram', 'Instagram', '감성·캡션', `${ct} 🌊\n\n${a.desc}\n\n전문은 프로필 링크에서.`, `\n\n${tags} #독서기록`, '사진 1장 필요 · 캡션 복사 후 앱에서'),
    card('naver', '네이버 블로그', '블로그 글', `[${ct}]\n\n${hook}${a.desc}`, `\n\n전문: ${a.url}`, '복사 후 블로그 글쓰기에'),
  ];
}

// 내가 쓴 글: 원문 기준. 각 플랫폼 한도에 맞춰 자르고 전문 링크를 붙인다. + '전체 글' 따로 제공.
function genFullPosts(a) {
  const body = a.body;
  const link = `\n\n전문 → ${a.url}`;
  const tags = hashtags(a.tags.slice(0, 5));
  return [
    // 전체 글(전문) — 블로그/노트처럼 길이 제한 없는 곳에 통째로.
    { key: 'full', name: '전체 글 (전문)', tone: '블로그·노트에 통째로', text: body, count: [...body].length, limit: 0, fits: true, note: '길이 제한 없는 곳(네이버·브런치·노트)에 그대로. SNS는 아래 플랫폼별 버전을 쓰세요.' },
    card('linkedin', 'LinkedIn', '원문 그대로', body, link, '3,000자 안에 맞춤 · 복사 후 붙여넣기'),
    card('threads', 'Threads', '요지 + 전문 링크', body, link, '500자 안에 맞춤 · 버튼으로 채워 열기',
      (txt) => ({ url: `https://www.threads.net/intent/post?text=${enc(txt)}`, label: '스레드에 채워 열기' })),
    card('x', 'X (Twitter)', '한 방 + 링크', body, link, '280자(한글은 2자 계산) 안에 맞춤',
      (txt) => ({ url: `https://x.com/intent/tweet?text=${enc(txt)}`, label: 'X에 채워 열기' })),
    card('facebook', 'Facebook (Meta)', '원문 그대로', body, link, '복사 후 붙여넣기',
      () => ({ url: `https://www.facebook.com/sharer/sharer.php?u=${enc(a.url)}`, label: '페이스북 열기(링크)' })),
    card('instagram', 'Instagram', '캡션', body, `${link}\n\n${tags}`, '사진 1장 필요 · 캡션 복사 후 앱에서'),
    card('naver', '네이버 블로그', '원문 그대로', body, `\n\n원문: ${a.url}`, '복사 후 블로그 글쓰기에'),
  ];
}

const withPosts = articles.map((a) => ({ ...a, posts: a.type === 'writing' ? genFullPosts(a) : genSummaryPosts(a) }));
---
<Base title="발행 · Publish">
  <section style="padding-top:72px">
    <div class="wrap" style="max-width:760px">
      <p class="section-kicker">발행 · Publish Hub</p>
      <h2>한 글, 모든 채널로</h2>
      <p class="lead">글이 올라오면 자동으로 여기 나타나고, 채널별로 <b>그 플랫폼 글자 수에 맞춰</b> 붙여넣을 글이 준비됩니다. 각 버전은 한도 안으로 잘리고 <b>전문 링크</b>가 붙어요. 전체 원문이 필요하면 맨 위 <b>‘전체 글(전문)’</b>을 복사하세요. 스레드·X는 버튼으로 자동 채움.</p>

      {withPosts.map((a, i) => (
        <details class="pub-article" open={i === 0}>
          <summary>
            <span class="pa-title">{a.title}</span>
            {a.type === 'writing' && <span class="pa-badge">내 글</span>}
            <span class="pa-date">{a.date}</span>
          </summary>
          <p class="pa-link"><a href={a.url}>{a.url}</a></p>
          {a.posts.map((p) => (
            <div class={`pub-card ${p.key === 'full' ? 'is-full' : ''}`}>
              <div class="pub-head">
                <span class="pub-name">{p.name}</span>
                <span class="pub-tone">{p.tone}</span>
                <span class={`pub-count ${p.limit && p.count > p.limit ? 'over' : 'ok'}`}>
                  {p.limit ? `${p.count} / ${p.limit}${p.key === 'x' ? ' (X기준)' : '자'}` : `${p.count}자 · 제한 없음`}
                  {p.limit ? (p.count <= p.limit ? ' ✓' : ' ⚠') : ''}
                </span>
              </div>
              <textarea class="pub-text" readonly rows={Math.min(16, p.text.split('\n').length + 1)}>{p.text}</textarea>
              <div class="pub-actions">
                <button class="pub-btn copy" type="button">복사</button>
                {p.share && <a class="pub-btn share" href={p.share} target="_blank" rel="noopener">{p.shareLabel} ↗</a>}
              </div>
              {p.note && <p class="pub-note">ⓘ {p.note}</p>}
            </div>
          ))}
        </details>
      ))}

      <p style="color:var(--muted);font-size:0.88rem;margin-top:28px">
        완전 자동 게시(무터치)를 켜려면 → Meta(인스타·페북·스레드) 1회 인증부터. 준비되면 텔레그램으로 승인 창을 띄워드립니다.
      </p>
    </div>
  </section>

  <style is:global>
    .pub-article { border-top:1px solid var(--line); padding:18px 0; }
    .pub-article > summary { cursor:pointer; list-style:none; display:flex; align-items:baseline; gap:12px; padding:6px 0; }
    .pub-article > summary::-webkit-details-marker { display:none; }
    .pub-article > summary::before { content:'▸'; color:var(--muted); transition:transform .15s ease; }
    .pub-article[open] > summary::before { transform:rotate(90deg); }
    .pa-title { font-weight:700; font-size:1.15rem; letter-spacing:-0.02em; }
    .pa-badge { font-size:0.68rem; font-weight:700; letter-spacing:0.03em; background:var(--accent); color:#17140f; padding:2px 8px; border-radius:999px; }
    .pa-date { color:var(--muted); font-size:0.85rem; margin-left:auto; }
    .pa-link { margin:4px 0 8px 22px; }
    .pa-link a { color:var(--muted); font-size:0.85rem; text-decoration:underline; text-underline-offset:2px; }
    .pub-card { border:1px solid var(--line); border-radius:16px; padding:20px; margin:14px 0 0 22px; background:var(--bg-card); }
    .pub-card.is-full { border-color:var(--accent); box-shadow:0 0 0 1px var(--accent) inset; }
    .pub-head { display:flex; align-items:baseline; gap:12px; margin-bottom:12px; flex-wrap:wrap; }
    .pub-name { font-weight:700; font-size:1.05rem; letter-spacing:-0.02em; }
    .pub-tone { color:var(--muted); font-size:0.82rem; }
    .pub-count { margin-left:auto; font-family:var(--mono); font-size:0.78rem; font-weight:600; padding:2px 9px; border-radius:999px; border:1px solid var(--line); color:var(--fg-soft); }
    .pub-count.ok { color:#7fd39b; border-color:rgba(127,211,155,0.4); }
    .pub-count.over { color:#ff8a8a; border-color:rgba(255,138,138,0.5); }
    .pub-text { width:100%; border:1px solid var(--line); border-radius:10px; padding:14px; font-family:inherit; font-size:0.95rem; line-height:1.6; color:var(--fg); resize:vertical; background:var(--bg-soft); outline:none; }
    .pub-text:focus { border-color:var(--accent); }
    .pub-actions { display:flex; gap:10px; margin-top:12px; flex-wrap:wrap; }
    /* 버튼 — 다크 테마에서 확실히 보이게. 기본은 어두운 카드+밝은 글씨, 강조는 액센트+어두운 글씨. */
    .pub-btn { border:1px solid var(--line); border-radius:999px; padding:9px 20px; font-size:0.9rem; font-weight:700; cursor:pointer; background:var(--bg-1); color:var(--fg); font-family:inherit; transition:all .15s ease; }
    .pub-btn.copy:hover { background:var(--fg); color:var(--bg-1); border-color:var(--fg); }
    .pub-btn.copy.done { background:#2fa15a; color:#fff; border-color:#2fa15a; }
    .pub-btn.share { background:var(--accent); color:#17140f; border-color:var(--accent); text-decoration:none; }
    .pub-btn.share:hover { filter:brightness(1.1); }
    .pub-note { color:var(--muted); font-size:0.82rem; margin:10px 0 0; }
    @media(max-width:680px){ .pub-card{ margin-left:0; } }
  </style>

  <script is:inline>
    document.querySelectorAll('.pub-btn.copy').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var ta = btn.closest('.pub-card').querySelector('.pub-text');
        function ok(){ btn.textContent = '복사됨 ✓'; btn.classList.add('done'); setTimeout(function(){ btn.textContent='복사'; btn.classList.remove('done'); }, 1600); }
        if (navigator.clipboard && navigator.clipboard.writeText) { navigator.clipboard.writeText(ta.value).then(ok, function(){ ta.select(); document.execCommand('copy'); ok(); }); }
        else { ta.select(); document.execCommand('copy'); ok(); }
      });
    });
  </script>
</Base>
