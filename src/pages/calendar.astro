---
// 달력 — 그냥 보는 게 아니라 "말로 던지면 잡히는" 일정 도구.
// 정적 사이트라 서버 없이: 자연어 → 날짜·시간 파싱 → 구글 캘린더 저장 링크(한 번 탭).
import Base from '../layouts/Base.astro';
---
<Base title="달력">
  <section style="padding-top:84px">
    <div class="wrap">
      <p class="section-kicker">📅 달력 · 말하면 잡힌다</p>
      <h1 class="cal-h1">일정, <mark>한 줄로 던지면</mark> 끝</h1>
      <p class="cal-lead">
        “내일 오후 3시 김대표 미팅”처럼 <b>그냥 편하게 한 줄</b> 치세요.
        날짜·시간을 알아서 잡아, <b>구글 캘린더에 한 번 눌러 저장</b>합니다.
      </p>

      <!-- ⚡ 빠른 일정 추가 -->
      <div class="qa">
        <div class="qa-inbox">
          <input id="qaInput" type="text" autocomplete="off"
            placeholder="예: 내일 오후 3시 김대표 미팅" aria-label="일정 입력" />
          <button id="qaGo" type="button" class="qa-go">잡기</button>
        </div>

        <div class="qa-ex">
          <span>눌러서 예시:</span>
          <button type="button" class="qa-chip">내일 오후 3시 김대표 미팅</button>
          <button type="button" class="qa-chip">금요일 12시 반 점심 약속</button>
          <button type="button" class="qa-chip">7월 25일 종일 워크숍</button>
          <button type="button" class="qa-chip">오늘 저녁 7시~9시 회식</button>
        </div>

        <!-- 인식 결과 카드 -->
        <div id="qaCard" class="qa-card" hidden>
          <div class="qa-card-body">
            <p class="qa-when" id="qaWhen">—</p>
            <p class="qa-title" id="qaTitle">—</p>
          </div>
          <div class="qa-actions">
            <a id="qaSave" class="qa-save" target="_blank" rel="noopener">📅 구글 캘린더에 저장</a>
            <p class="qa-hint">버튼을 누르면 구글 캘린더가 <b>미리 채워진 채</b> 열립니다. “저장”만 누르면 끝.</p>
          </div>
        </div>
        <p id="qaErr" class="qa-err" hidden></p>

        <p class="qa-tel">💬 아니면 <b>텔레그램에 그냥 던지세요</b> — 날짜·시간 있는 약속이면 제가 바로 캘린더에 넣어드립니다.</p>
      </div>

      <!-- 내 일정 보기 (구글 캘린더 통합) -->
      <div class="cal-see">
        <div class="cal-see-head">
          <h2>내 일정 한눈에</h2>
          <a class="cal-open" href="https://calendar.google.com/calendar/u/0/r" target="_blank" rel="noopener">구글에서 열기 ↗</a>
        </div>
        <div class="gcal-wrap">
          <iframe
            title="구글 캘린더 (통합)"
            src="https://calendar.google.com/calendar/embed?ctz=Asia%2FSeoul&mode=WEEK&wkst=2&showTitle=0&showPrint=0&showTz=0&src=hyun%40aramhuvis.com&src=c_7896bcef6802c9f6262d15f5f14ecec437e192103854ce304586b1bc176ebea5%40group.calendar.google.com&src=c_186292f4af3265ed4e4f541283b1cc30f4aac8dad74559d443f62ae1664a4a27%40group.calendar.google.com&src=c_e81ab5f59597cd678049eccef9bee70e4a43c7376d031d70e44964da42fadc8c%40group.calendar.google.com&src=c_322c21398b32c9aee8950b73ec82be7529569d71bb8d479150cdd2b8491de70c%40group.calendar.google.com&src=c_d3af50d1aa283259bb698c80f6f8b6153f21934795aa3bbd50c51a73d80568a4%40group.calendar.google.com&color=%23039BE5&color=%237CB342&color=%23F09300&color=%238E24AA&color=%23E67C73&color=%230B8043"
            loading="lazy" style="border:0"></iframe>
        </div>
        <p class="cal-note">🔑 일정이 안 보이면 이 브라우저에 <b>hyun@aramhuvis.com</b> 구글 계정으로 로그인만 하면 됩니다.</p>
      </div>

      <details class="cal-more">
        <summary>이 달력의 “진짜 앱”(예약링크·미팅조율·알림)이 궁금하면 →</summary>
        <p>
          위 도구는 아라미러 안에서 바로 쓰는 <b>빠른 추가 + 보기</b>입니다.
          예약 링크(남이 내 빈 시간 예약)·미팅 자동 조율·웹푸시 알림 같은 풀 기능은
          사장님이 개발한 <b>Luxe Calendar</b>(Next.js·Electron PC앱)에 있고,
          그건 서버가 필요해 내 PC에서 돌립니다. 실제 코드: <code>Project/Calender</code>.
        </p>
      </details>
    </div>
  </section>

  <script>
    // ── 자연어 → 날짜·시간 파서 (한국어) ────────────────────────
    const $ = (id) => document.getElementById(id);
    const input = $('qaInput'), card = $('qaCard'), err = $('qaErr');
    const pad = (n) => String(n).padStart(2, '0');
    const WD = ['일','월','화','수','목','금','토'];

    function parse(raw) {
      let t = ' ' + raw.trim() + ' ';
      const now = new Date();
      let base = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      let dateSet = false, allDay = true;
      let startH = 9, startM = 0, endH = null, endM = null;

      // 상대 날짜
      const rel = [['그글피',4],['글피',3],['모레',2],['내일',1],['오늘',0]];
      for (const [w,d] of rel) { if (t.includes(w)) { base.setDate(base.getDate()+d); dateSet=true; t=t.replace(w,' '); break; } }

      // 다음주/이번주 + 요일
      let weekOffset = 0;
      if (t.includes('다음주') || t.includes('담주')) { weekOffset = 7; t=t.replace(/다음주|담주/,' '); }
      else if (t.includes('이번주')) { t=t.replace('이번주',' '); }
      const wdM = t.match(/([일월화수목금토])\s*요일|([월화수목금토일])요/);
      if (wdM) {
        const ch = (wdM[1]||wdM[2]);
        const target = WD.indexOf(ch);
        if (target >= 0) {
          let diff = (target - base.getDay() + 7) % 7;
          if (diff === 0 && !t.includes('오늘')) diff = 7; // "금요일"은 다가오는 금요일
          base.setDate(base.getDate() + diff + weekOffset);
          dateSet = true;
        }
        t = t.replace(/[일월화수목금토]\s*요일|[월화수목금토일]요/,' ');
      }

      // N월 N일
      const md = t.match(/(\d{1,2})\s*월\s*(\d{1,2})\s*일?/);
      if (md) {
        let mo = +md[1]-1, dy = +md[2];
        let y = now.getFullYear();
        let cand = new Date(y, mo, dy);
        if (cand < new Date(now.getFullYear(), now.getMonth(), now.getDate())) cand = new Date(y+1, mo, dy);
        base = cand; dateSet = true; t = t.replace(md[0],' ');
      } else {
        // N일 (이번달/다음달)
        const dm = t.match(/(?:^|\s)(\d{1,2})\s*일(?!정|\s*간)/);
        if (dm && !dateSet) {
          let dy = +dm[1]; let cand = new Date(now.getFullYear(), now.getMonth(), dy);
          if (cand < new Date(now.getFullYear(), now.getMonth(), now.getDate())) cand = new Date(now.getFullYear(), now.getMonth()+1, dy);
          base = cand; dateSet = true; t = t.replace(dm[0],' ');
        }
      }

      // 오전/오후/저녁/아침/점심 힌트
      let ampm = null;
      if (/오후|저녁|밤|낮/.test(t)) ampm = 'pm';
      if (/오전|아침|새벽/.test(t)) ampm = 'am';
      if (/점심/.test(t) && !/\d/.test(t)) { startH = 12; startM = 0; allDay = false; }
      t = t.replace(/오전|오후|저녁|밤|낮|아침|새벽/g,' ');

      // 시간 범위:  A시(반|M분)? ~|부터 B시(반|M분)?
      const range = t.match(/(\d{1,2})\s*시(?:\s*(반|\d{1,2})\s*분?)?\s*(?:~|-|부터|에서)\s*(\d{1,2})\s*시(?:\s*(반|\d{1,2})\s*분?)?/);
      const single = t.match(/(\d{1,2})\s*시(?:\s*(반|\d{1,2})\s*분?)?/);
      const toMin = (v) => v === '반' ? 30 : (v ? +v : 0);
      if (range) {
        startH = +range[1]; startM = toMin(range[2]); endH = +range[3]; endM = toMin(range[4]);
        allDay = false; t = t.replace(range[0],' ');
      } else if (single) {
        startH = +single[1]; startM = toMin(single[2]); allDay = false; t = t.replace(single[0],' ');
      }
      // 오전/오후 보정
      if (!allDay && ampm === 'pm' && startH < 12) startH += 12;
      if (!allDay && ampm === 'pm' && endH !== null && endH < 12) endH += 12;
      if (!allDay && ampm === 'am' && startH === 12) startH = 0;
      if (/종일|하루종일|온종일/.test(raw)) allDay = true;
      t = t.replace(/종일|하루종일|온종일/g,' ');

      // 제목 = 남은 텍스트 정리
      let title = t.replace(/\s+/g,' ').replace(/[~\-]/g,' ').trim();
      title = title.replace(/^(에|에서|,|\.)\s*/,'').trim();
      if (!title) title = '일정';

      // 종료시간 기본값
      if (!allDay && endH === null) {
        let e = new Date(base); e.setHours(startH, startM + 60, 0, 0);
        endH = e.getHours(); endM = e.getMinutes();
        if (e.getDate() !== base.getDate()) { endH = 23; endM = 59; }
      }

      return { base, allDay, startH, startM, endH, endM, title, dateSet };
    }

    function gcalUrl(p) {
      const d = p.base;
      const ymd = `${d.getFullYear()}${pad(d.getMonth()+1)}${pad(d.getDate())}`;
      let dates;
      if (p.allDay) {
        const e = new Date(d); e.setDate(e.getDate()+1);
        const ymd2 = `${e.getFullYear()}${pad(e.getMonth()+1)}${pad(e.getDate())}`;
        dates = `${ymd}/${ymd2}`;
      } else {
        dates = `${ymd}T${pad(p.startH)}${pad(p.startM)}00/${ymd}T${pad(p.endH)}${pad(p.endM)}00`;
      }
      const u = new URL('https://calendar.google.com/calendar/render');
      u.searchParams.set('action','TEMPLATE');
      u.searchParams.set('text', p.title);
      u.searchParams.set('dates', dates);
      u.searchParams.set('ctz','Asia/Seoul');
      return u.toString();
    }

    function whenLabel(p) {
      const d = p.base;
      const dstr = `${d.getMonth()+1}월 ${d.getDate()}일 (${WD[d.getDay()]})`;
      if (p.allDay) return `${dstr} · 종일`;
      const ap = (h) => h < 12 ? '오전' : '오후';
      const h12 = (h) => { const x = h%12; return x===0?12:x; };
      const s = `${ap(p.startH)} ${h12(p.startH)}시${p.startM?' '+p.startM+'분':''}`;
      const e = `${ap(p.endH)} ${h12(p.endH)}시${p.endM?' '+p.endM+'분':''}`;
      return `${dstr} · ${s} ~ ${e}`;
    }

    function run() {
      const v = input.value.trim();
      err.hidden = true; card.hidden = true;
      if (!v) { input.focus(); return; }
      const p = parse(v);
      if (!p.dateSet && p.allDay && p.title === '일정') {
        err.hidden = false; err.textContent = '날짜나 내용을 못 알아들었어요. 예: “내일 3시 회의”처럼 써보세요.';
        return;
      }
      $('qaWhen').textContent = whenLabel(p);
      $('qaTitle').textContent = p.title;
      $('qaSave').href = gcalUrl(p);
      card.hidden = false;
      card.scrollIntoView({ behavior:'smooth', block:'nearest' });
    }

    $('qaGo').addEventListener('click', run);
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') run(); });
    document.querySelectorAll('.qa-chip').forEach((c) =>
      c.addEventListener('click', () => { input.value = c.textContent; run(); }));
  </script>

  <style>
    .cal-h1 { font-size: clamp(2rem, 5.5vw, 3rem); font-weight: 800; letter-spacing: -0.04em; margin: 6px 0 14px; line-height: 1.1; }
    .cal-lead { color: var(--fg-soft); font-size: 1.1rem; line-height: 1.7; max-width: 640px; margin: 0 0 30px; }
    .cal-lead b { color: var(--fg); }

    /* 빠른 추가 */
    .qa { border: 1px solid var(--line); border-radius: 22px; padding: 26px; background: var(--bg-1); }
    .qa-inbox { display: flex; gap: 10px; }
    .qa-inbox input { flex: 1; font: inherit; font-size: 1.12rem; padding: 16px 18px; border-radius: 14px;
      border: 1px solid var(--line); background: var(--bg-2); color: var(--fg); }
    .qa-inbox input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); }
    .qa-go { font: inherit; font-size: 1.08rem; font-weight: 800; color: #fff; cursor: pointer;
      background: var(--accent); border: 0; border-radius: 14px; padding: 0 26px; white-space: nowrap;
      transition: transform .12s; }
    .qa-go:hover { transform: translateY(-1px); }

    .qa-ex { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 16px; }
    .qa-ex > span { font-size: 0.84rem; color: var(--muted); margin-right: 2px; }
    .qa-chip { font: inherit; font-size: 0.86rem; color: var(--fg-soft); background: var(--bg-2);
      border: 1px solid var(--line); border-radius: 999px; padding: 7px 14px; cursor: pointer; transition: border-color .15s, color .15s; }
    .qa-chip:hover { border-color: var(--accent); color: var(--fg); }

    .qa-card { margin-top: 20px; border: 1px solid var(--accent); border-radius: 16px; overflow: hidden;
      display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;
      padding: 20px 22px; background: var(--accent-soft); }
    .qa-card[hidden] { display: none; }
    .qa-when { font-family: var(--mono); font-size: 0.9rem; color: var(--accent); margin: 0 0 6px; font-weight: 600; }
    .qa-title { font-size: 1.35rem; font-weight: 800; letter-spacing: -0.02em; margin: 0; color: var(--fg); }
    .qa-actions { text-align: right; }
    .qa-save { display: inline-block; font-size: 1.02rem; font-weight: 800; color: #fff; background: var(--accent);
      border-radius: 12px; padding: 13px 22px; text-decoration: none; transition: transform .12s; }
    .qa-save:hover { transform: translateY(-1px); }
    .qa-hint { font-size: 0.8rem; color: var(--muted); margin: 8px 0 0; max-width: 260px; }
    .qa-err { margin: 16px 0 0; color: #ff8a8a; font-size: 0.92rem; }
    .qa-tel { margin: 18px 0 0; padding-top: 16px; border-top: 1px solid var(--line-soft);
      color: var(--fg-soft); font-size: 0.94rem; line-height: 1.6; }
    .qa-tel b { color: var(--fg); }

    /* 일정 보기 */
    .cal-see { margin-top: 40px; }
    .cal-see-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
    .cal-see-head h2 { font-size: 1.4rem; font-weight: 800; letter-spacing: -0.03em; margin: 0; }
    .cal-open { font-size: 0.9rem; color: var(--fg-soft); text-decoration: underline; text-underline-offset: 3px; white-space: nowrap; }
    .gcal-wrap { width: 100%; border: 1px solid var(--line); border-radius: 18px; overflow: hidden; background: #fff; }
    .gcal-wrap iframe { display: block; width: 100%; height: 620px; }
    .cal-note { color: var(--muted); font-size: 0.86rem; margin: 12px 0 0; }

    .cal-more { margin: 34px 0 20px; border-top: 1px solid var(--line-soft); padding-top: 18px; }
    .cal-more summary { cursor: pointer; color: var(--fg-soft); font-size: 0.92rem; }
    .cal-more p { color: var(--fg-soft); font-size: 0.92rem; line-height: 1.7; margin: 12px 0 0; }
    .cal-more code { font-family: var(--mono); font-size: 0.85em; background: var(--bg-soft); padding: 2px 6px; border-radius: 6px; }

    @media (max-width: 640px) {
      .qa-inbox { flex-direction: column; }
      .qa-go { padding: 14px; }
      .qa-card { flex-direction: column; align-items: stretch; }
      .qa-actions { text-align: left; }
      .qa-hint { max-width: none; }
      .gcal-wrap iframe { height: 500px; }
    }
  </style>
</Base>
