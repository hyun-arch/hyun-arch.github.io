---
import Base from '../../layouts/Base.astro';
const posts = (await Astro.glob('./*.md'))
  .filter((p) => !p.url.endsWith('/reading'))
  .sort((a, b) => (a.frontmatter.date < b.frontmatter.date ? 1 : -1));
---
<Base title="독서 · 학습">
  <section style="padding-top:80px">
    <div class="wrap">
      <p class="section-kicker">독서 · Reading</p>
      <h2>읽고, 배우고, 연결한다</h2>
      <p class="lead">내가 읽는 책을 AI가 함께 파고든다. 책의 한 대목을 최신 현실과 팩트로 확장한 학습노트를 여기에 쌓는다.</p>
      <ul class="logs">
        {posts.map((p) => (
          <li>
            <a href={p.url}>
              <span class="row">
                <span class="t">{p.frontmatter.title}</span>
                <span class="d">{p.frontmatter.date}</span>
              </span>
              {p.frontmatter.description && (
                <span class="desc">{p.frontmatter.description}</span>
              )}
              {p.frontmatter.tags && p.frontmatter.tags.length > 0 && (
                <span class="tags">
                  {p.frontmatter.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </span>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
  <style>
    .logs a { display: flex; flex-direction: column; gap: 8px; }
    .logs .row { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }
    .logs .desc {
      color: var(--muted);
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .logs .tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .logs .tag {
      font-size: 0.78rem;
      color: var(--muted);
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 2px 10px;
    }
  </style>
</Base>
