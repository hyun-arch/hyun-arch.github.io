---
import Base from '../../layouts/Base.astro';
import { detailItems, statusMeta } from '../../data/mirror.js';

export function getStaticPaths() {
  return detailItems().map((it) => ({ params: { slug: it.slug }, props: { it } }));
}
const { it } = Astro.props;
const m = statusMeta(it.status);
const dc = it.domainColor || '#ff7a4d';
---
<Base title={it.t + ' · 거울'}>
  <article class="place-pg" style={`--dc:${dc}`}>
    <div class="pp-inner">
      <a class="pp-back" href={`/mirror#${it.domainKey}`}>← {it.domainIcon} {it.domainTitle} 대륙으로</a>

      <p class="pp-crumb">
        <span class="pp-face" aria-hidden="true">{it.domainIcon}</span>
        <span>{it.domainTitle}</span><b>/</b><span>{it.branch}</span>
      </p>

      <div class="pp-head">
        <h1>{it.t}</h1>
        <span class={`pp-badge ${m.cls}`}><i class="dot"></i>{m.label}</span>
      </div>

      {it.lead && <p class="pp-lead">{it.lead}</p>}
      {it.from && <p class="pp-credit">💡 스폰지클럽에서 녹임 · <b>{it.from}</b></p>}

      {it.points && it.points.length > 0 && (
        <ul class="pp-points">{it.points.map((p) => <li>{p}</li>)}</ul>
      )}

      {it.links && it.links.length > 0 && (
        <div class="pp-jump">
          <span class="pp-jump-l">이동</span>
          {it.links.map((l) => (
            <a href={l.href} {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}>{l.label} →</a>
          ))}
        </div>
      )}

      <div class="pp-capture">
        <span class="pp-cap-ic">🌱</span>
        <div>
          <p class="pp-cap-t">이 칸에 생각 던지기</p>
          <p class="pp-cap-d">텔레그램에 <b>{it.t}</b> 관련해서 한 줄 던지면, 밤마다 알아서 이 칸에 쌓여요. 지금은 씨앗 내용이고, 던질수록 자라납니다.</p>
        </div>
      </div>
    </div>
  </article>

  <style is:global>
    .place-pg { max-width: 780px; margin: 0 auto; padding: 96px 18px 72px; }
    .place-pg .pp-inner {
      position: relative; border-radius: 24px; padding: 34px clamp(20px, 5vw, 44px) 40px;
      background:
        radial-gradient(120% 80% at 0% 0%, color-mix(in srgb, var(--dc) 14%, transparent), transparent 55%),
        var(--bg-1);
      border: 1px solid color-mix(in srgb, var(--dc) 26%, var(--line));
    }
    .pp-back { display: inline-block; color: var(--muted); font-size: .9rem; text-decoration: none; margin-bottom: 22px; transition: color .15s; }
    .pp-back:hover { color: var(--dc); }
    .pp-crumb { display: flex; align-items: center; gap: 8px; margin: 0 0 12px; font-size: .84rem; color: var(--muted); }
    .pp-crumb b { color: var(--faint); }
    .pp-face { display: inline-grid; place-items: center; width: 26px; height: 26px; border-radius: 50%; background: color-mix(in srgb, var(--dc) 20%, var(--bg-2)); border: 1px solid color-mix(in srgb, var(--dc) 30%, var(--line)); }
    .pp-head { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin: 0 0 4px; }
    .pp-head h1 { margin: 0; font-size: clamp(1.6rem, 4vw, 2.1rem); letter-spacing: -.03em; text-wrap: balance; }
    .pp-badge { display: inline-flex; align-items: center; gap: 7px; font-size: .76rem; font-weight: 700; padding: 5px 12px; border-radius: 999px; border: 1px solid var(--line); color: var(--fg-soft); white-space: nowrap; }
    .pp-badge .dot { width: 8px; height: 8px; border-radius: 50%; box-shadow: 0 0 6px currentColor; }
    .pp-badge.live { color: #6fe08a; border-color: color-mix(in srgb, #6fe08a 34%, transparent); }
    .pp-badge.building { color: #ffc061; border-color: color-mix(in srgb, #ffc061 34%, transparent); }
    .pp-badge.seed { color: #a78bfa; border-color: color-mix(in srgb, #a78bfa 34%, transparent); }
    .pp-badge.idea { color: var(--muted); }
    .pp-lead { margin: 18px 0 0; font-size: 1.12rem; line-height: 1.72; color: var(--fg); }
    .pp-credit { margin: 16px 0 0; display: inline-block; font-size: .86rem; color: var(--dc); background: color-mix(in srgb, var(--dc) 12%, transparent); border: 1px solid color-mix(in srgb, var(--dc) 26%, transparent); padding: 6px 13px; border-radius: 999px; }
    .pp-credit b { font-weight: 700; }
    .pp-points { margin: 28px 0 0; padding: 0; list-style: none; }
    .pp-points li { position: relative; padding: 13px 0 13px 24px; line-height: 1.65; color: var(--fg-soft); border-top: 1px solid var(--line-soft); }
    .pp-points li:last-child { border-bottom: 1px solid var(--line-soft); }
    .pp-points li::before { content: ""; position: absolute; left: 3px; top: 1.25em; width: 7px; height: 7px; border-radius: 50%; background: var(--dc); box-shadow: 0 0 8px color-mix(in srgb, var(--dc) 60%, transparent); }
    .pp-jump { margin: 30px 0 0; display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
    .pp-jump-l { color: var(--muted); font-size: .84rem; margin-right: 2px; }
    .pp-jump a { border: 1px solid color-mix(in srgb, var(--dc) 30%, var(--line)); border-radius: 999px; padding: 8px 15px; font-size: .9rem; font-weight: 600; color: var(--fg); text-decoration: none; transition: background .15s, border-color .15s; }
    .pp-jump a:hover { background: color-mix(in srgb, var(--dc) 14%, transparent); border-color: var(--dc); }
    .pp-capture { margin: 40px 0 0; padding: 20px 22px; border-radius: 18px; background: var(--bg-2); border: 1px dashed color-mix(in srgb, var(--dc) 36%, var(--line)); display: flex; gap: 14px; align-items: flex-start; }
    .pp-cap-ic { font-size: 1.5rem; }
    .pp-cap-t { margin: 0 0 5px; font-weight: 700; }
    .pp-cap-d { margin: 0; color: var(--fg-soft); line-height: 1.65; font-size: .94rem; }
    .pp-cap-d b { color: var(--fg); }
  </style>
</Base>
