---
import Base from '../../layouts/Base.astro';
import { detailItems, statusMeta } from '../../data/mirror.js';

// 공개 상세(2026-07-06 개정): 비밀번호 잠금 제거. mirror.js 평문을 빌드 때 정적 렌더.
export function getStaticPaths() {
  return detailItems().map((it) => ({ params: { slug: it.slug }, props: { it } }));
}
const { it } = Astro.props;
const m = statusMeta(it.status);
---
<Base title={it.t + ' · 거울'}>
  <section style="padding-top:96px; min-height:60vh">
    <div class="wrap" style="max-width:760px">
      <a class="back" href="/mirror">← 전체 지도</a>

      <div id="detail-root">
        <p class="crumb"><span>{it.domainIcon} {it.domainTitle}</span><span class="sep">›</span><span>{it.branch}</span></p>
        <div class="head"><h1>{it.t}</h1><span class={`badge ${m.cls}`}>{m.label}</span></div>

        {it.lead && <p class="lead">{it.lead}</p>}
        {it.from && <p class="credit">💡 스폰지클럽에서 녹임 · <b>{it.from}</b></p>}

        {it.points && it.points.length > 0 && (
          <ul class="points">{it.points.map((p) => <li>{p}</li>)}</ul>
        )}

        {it.links && it.links.length > 0 && (
          <div class="jump">
            <span class="jump-label">이동</span>
            {it.links.map((l) => (
              <a href={l.href} {...(l.external ? { target: '_blank', rel: 'noopener' } : {})}>{l.label} →</a>
            ))}
          </div>
        )}

        <div class="capture">
          <p class="capture-t">이 칸에 생각 던지기</p>
          <p class="capture-d">텔레그램에 <b>{it.t}</b> 관련해서 한 줄 던지면, 밤마다 알아서 이 칸에 쌓여. 지금은 씨앗 내용이고, 던질수록 자라난다.</p>
        </div>
      </div>
    </div>
  </section>

  <style>
    .back { display: inline-block; color: var(--muted); font-size: 0.92rem; text-decoration: none; margin-bottom: 22px; }
    .back:hover { color: var(--fg); }
    #detail-root .crumb { color: var(--muted); font-size: 0.88rem; margin: 0 0 10px; display: flex; gap: 8px; align-items: center; }
    #detail-root .crumb .sep { opacity: 0.5; }
    #detail-root .head { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin: 0 0 6px; }
    #detail-root .head h1 { margin: 0; font-size: 2rem; letter-spacing: -0.03em; }
    #detail-root .badge { font-size: 0.76rem; font-weight: 700; padding: 4px 10px; border-radius: 999px;
      border: 1px solid var(--line); color: var(--muted); white-space: nowrap; }
    #detail-root .badge.live { background: #eafaef; border-color: #bfe8cd; color: #1f7a44; }
    #detail-root .badge.building { background: #fff6e5; border-color: #f2dcae; color: #96660a; }
    #detail-root .badge.seed { background: #eef2ff; border-color: #cdd7f2; color: #3a4ea0; }
    #detail-root .badge.idea { background: var(--bg-soft); }
    #detail-root .lead { margin: 18px 0 0; font-size: 1.12rem; line-height: 1.7; color: var(--fg-soft); }
    #detail-root .credit { margin: 14px 0 0; font-size: 0.88rem; color: var(--accent-strong); background: var(--accent-soft);
      display: inline-block; padding: 6px 12px; border-radius: 999px; }
    #detail-root .credit b { font-weight: 700; }
    #detail-root .points { margin: 26px 0 0; padding: 0; list-style: none; }
    #detail-root .points li { position: relative; padding: 12px 0 12px 22px; line-height: 1.6;
      border-top: 1px solid var(--line-soft); color: var(--fg); }
    #detail-root .points li:last-child { border-bottom: 1px solid var(--line-soft); }
    #detail-root .points li::before { content: ''; position: absolute; left: 4px; top: 1.15em; width: 6px; height: 6px;
      border-radius: 50%; background: var(--fg); }
    #detail-root .jump { margin: 30px 0 0; display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
    #detail-root .jump-label { color: var(--muted); font-size: 0.85rem; margin-right: 4px; }
    #detail-root .jump a { border: 1px solid var(--line); border-radius: 999px; padding: 8px 15px; font-size: 0.9rem;
      font-weight: 600; color: var(--fg); text-decoration: none; transition: background 0.15s ease; }
    #detail-root .jump a:hover { background: var(--bg-soft); }
    #detail-root .capture { margin: 44px 0 0; padding: 22px 24px; border-radius: var(--radius);
      background: var(--bg-soft); border: 1px dashed var(--line); }
    #detail-root .capture-t { margin: 0 0 6px; font-weight: 700; }
    #detail-root .capture-d { margin: 0; color: var(--fg-soft); line-height: 1.65; font-size: 0.96rem; }
    @media (max-width: 680px) { #detail-root .head h1 { font-size: 1.6rem; } }
  </style>
</Base>
