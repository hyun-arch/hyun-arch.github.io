---
import Base from '../layouts/Base.astro';
---
<Base title="게시판">
  <section style="padding-top:80px">
    <div class="wrap">
      <p class="section-kicker">게시판 · Board</p>
      <h2>생각과 기록이 쌓이는 곳</h2>
      <p class="lead">
        던진 생각·빌드로그·공유회 메모가 여기 모인다. 글은 브라우저에 저장되며,
        관리는 <a href="/admin" style="text-decoration:underline">관리자 콘솔</a>에서 한다.
      </p>

      <div class="board-filters" id="filters"></div>
      <ul class="logs" id="postList"></ul>
      <p class="board-empty" id="empty" hidden>아직 글이 없습니다. 관리자 콘솔에서 글을 작성해보세요.</p>
    </div>
  </section>

  <!-- 읽기(R) 모달 -->
  <div class="board-modal" id="modal" hidden>
    <div class="board-modal-card">
      <button class="board-x" id="modalClose" aria-label="닫기">×</button>
      <p class="board-cat" id="mCat"></p>
      <h3 id="mTitle"></h3>
      <p class="board-meta" id="mMeta"></p>
      <div class="board-body" id="mBody"></div>
      <div class="board-tags" id="mTags"></div>
    </div>
  </div>

  <style>
    .board-filters { display: flex; flex-wrap: wrap; gap: 8px; margin: 0 0 28px; }
    .board-chip {
      border: 1px solid var(--line); background: var(--bg); color: var(--muted);
      border-radius: 999px; padding: 7px 16px; font-size: 0.85rem; cursor: pointer;
      transition: all 0.15s ease; font-family: inherit;
    }
    .board-chip:hover { color: var(--fg); border-color: var(--fg); }
    .board-chip.active { background: var(--fg); color: #fff; border-color: var(--fg); }
    .logs .cat { color: var(--muted); font-weight: 700; font-size: 0.8rem; min-width: 56px; }
    .board-empty { color: var(--muted); padding: 40px 8px; }
    .board-modal {
      position: fixed; inset: 0; background: rgba(0,0,0,0.4);
      display: flex; align-items: center; justify-content: center; padding: 24px; z-index: 50;
    }
    .board-modal[hidden] { display: none; }
    .board-modal-card {
      background: var(--bg); border-radius: var(--radius); max-width: var(--readw);
      width: 100%; max-height: 82vh; overflow-y: auto; padding: 40px; position: relative;
    }
    .board-x {
      position: absolute; top: 18px; right: 20px; border: none; background: none;
      font-size: 1.6rem; line-height: 1; cursor: pointer; color: var(--muted);
    }
    .board-cat { color: var(--muted); font-size: 0.8rem; font-weight: 600; margin: 0 0 6px; }
    .board-modal-card h3 { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin: 0 0 8px; }
    .board-meta { color: var(--muted); font-size: 0.85rem; margin: 0 0 24px; }
    .board-body { color: var(--fg-soft); line-height: 1.8; white-space: pre-wrap; }
    .board-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
    .board-tags span { background: var(--bg-soft); color: var(--muted); font-size: 0.8rem; padding: 4px 10px; border-radius: 6px; }
  </style>

  <script>
    import { getPosts, CATEGORIES, onChange } from '../scripts/store.js';

    const listEl = document.getElementById('postList');
    const filtersEl = document.getElementById('filters');
    const emptyEl = document.getElementById('empty');
    const modal = document.getElementById('modal');
    let active = '전체';

    const cats = ['전체', ...CATEGORIES];
    filtersEl.innerHTML = cats
      .map((c) => `<button class="board-chip${c === active ? ' active' : ''}" data-cat="${c}">${c}</button>`)
      .join('');
    filtersEl.addEventListener('click', (e) => {
      const btn = e.target.closest('.board-chip');
      if (!btn) return;
      active = btn.dataset.cat;
      [...filtersEl.children].forEach((b) => b.classList.toggle('active', b.dataset.cat === active));
      render();
    });

    const esc = (s) => String(s).replace(/[&<>"]/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[m]));

    function render() {
      const posts = getPosts()
        .filter((p) => p.status === 'published')
        .filter((p) => active === '전체' || p.category === active);
      emptyEl.hidden = posts.length > 0;
      listEl.innerHTML = posts
        .map(
          (p) => `<li><a href="#" data-id="${p.id}">
            <span class="cat">${esc(p.category)}</span>
            <span class="t">${esc(p.title)}</span>
            <span class="d">${esc(p.date)}</span>
          </a></li>`
        )
        .join('');
    }

    listEl.addEventListener('click', (e) => {
      const a = e.target.closest('a[data-id]');
      if (!a) return;
      e.preventDefault();
      const p = getPosts().find((x) => x.id === a.dataset.id);
      if (!p) return;
      document.getElementById('mCat').textContent = p.category;
      document.getElementById('mTitle').textContent = p.title;
      document.getElementById('mMeta').textContent = `${p.date}${p.updated && p.updated !== p.date ? ' · 수정 ' + p.updated : ''}`;
      document.getElementById('mBody').textContent = p.body;
      document.getElementById('mTags').innerHTML = (p.tags || []).map((t) => `<span>#${esc(t)}</span>`).join('');
      modal.hidden = false;
    });

    function closeModal() { modal.hidden = true; }
    document.getElementById('modalClose').addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

    onChange(render);
    render();
  </script>
</Base>
