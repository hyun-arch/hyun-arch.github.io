  <script>
    // ── 성장 컴패니언: 활동 로그(엔진실 events)로 구동 ──
    (function () {
      function readEvents() { try { return JSON.parse(localStorage.getItem('aramirror.events.buffer.v1') || '[]'); } catch (_) { return []; } }
      function dayKey(iso) { const d = new Date(iso); return d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate(); }
      function streakOf(evs) { const days = new Set(evs.map((e) => dayKey(e.occurred_at))); let s = 0; const d = new Date(); for (;;) { const k = d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate(); if (days.has(k)) { s++; d.setDate(d.getDate() - 1); } else break; } return s; }
      const STAGES = [0, 3, 10, 25, 60, 120], NAMES = ['씨앗', '새싹', '잎', '봉오리', '꽃', '큰 나무'];
      const stageOf = (t) => { let s = 0; for (let i = 0; i < STAGES.length; i++) if (t >= STAGES[i]) s = i; return s; };
      const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = String(v); };
      function refresh() {
        const evs = readEvents(), total = evs.length;
        const today = evs.filter((e) => dayKey(e.occurred_at) === dayKey(new Date().toISOString())).length;
        const streak = streakOf(evs), stage = stageOf(total), level = Math.max(1, Math.floor(Math.sqrt(total)) + 1);
        set('statLevel', level); set('statStreak', streak); set('statToday', today); set('statTotal', total);
        set('stagePill', NAMES[stage]);
        const sp = document.getElementById('sprout'); if (sp) sp.setAttribute('data-stage', String(stage));
        const isMax = stage >= STAGES.length - 1, base = STAGES[stage], next = STAGES[Math.min(stage + 1, STAGES.length - 1)];
        const frac = isMax ? 1 : Math.min(1, (total - base) / (next - base));
        const fill = document.getElementById('xpFill'); if (fill) fill.style.width = Math.max(6, Math.round(frac * 100)) + '%';
        set('xpText', isMax ? '만개 완료 🌳' : (total + ' / ' + next + ' XP'));
        const ring = document.getElementById('ringFg'); if (ring) ring.style.strokeDashoffset = String(195 - 195 * frac);
        const say = document.getElementById('araSay');
        if (say && total > 0) say.textContent = '“연속 ' + streak + '일째 · ' + NAMES[stage] + ' 단계예요!”';
      }
      refresh(); setTimeout(refresh, 300);
    })();
  </script>

  <script is:inline>
    // ── 거울 지도(병합): 대륙 드릴다운 + 상태 필터 ──
    (function () {
      const view = document.getElementById('view');
      if (!view) return;
      const mapSec = document.getElementById('map');
      const conts = Array.from(document.querySelectorAll('.cont'));
      const details = Array.from(document.querySelectorAll('.detail'));
      function openDomain(key) {
        details.forEach((d) => { d.hidden = d.dataset.key !== key; });
        view.dataset.level = 'detail';
        if (mapSec) mapSec.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.replaceState(null, '', '#' + key);
      }
      function backToMap() {
        view.dataset.level = 'overview';
        details.forEach((d) => { d.hidden = true; });
        history.replaceState(null, '', location.pathname);
        if (mapSec) mapSec.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
      conts.forEach((c) => c.addEventListener('click', () => openDomain(c.dataset.key)));
      document.querySelectorAll('[data-back]').forEach((b) => b.addEventListener('click', backToMap));
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && view.dataset.level === 'detail') backToMap(); });
      details.forEach((d) => {
        const chips = Array.from(d.querySelectorAll('.fchip'));
        const places = Array.from(d.querySelectorAll('.place'));
        const noHit = d.querySelector('.no-hit');
        const regions = Array.from(d.querySelectorAll('.region'));
        chips.forEach((c) => c.addEventListener('click', () => {
          chips.forEach((x) => x.classList.toggle('on', x === c));
          const s = c.dataset.status;
          places.forEach((p) => { p.hidden = !(s === 'all' || p.dataset.status === s); });
          let any = false;
          regions.forEach((r) => { const vis = r.querySelector('.place:not([hidden])'); r.style.display = vis ? '' : 'none'; if (vis) any = true; });
          if (noHit) noHit.hidden = any;
        }));
      });
      const h = location.hash.replace('#', '');
      if (h && details.some((d) => d.dataset.key === h)) openDomain(h);
    })();
  </script>
</Base>
