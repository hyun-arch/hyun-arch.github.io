---
import Base from '../layouts/Base.astro';
import { logs } from '../data/logs.js';
import { domains } from '../data/mirror.js';
const latestLogs = logs.slice(0, 3);

function counts(d) {
  let live = 0, total = 0, building = 0;
  d.branches.forEach((b) => b.items.forEach((it) => {
    total++;
    if (it.status === 'live') live++;
    if (it.status === 'building') building++;
  }));
  return { live, total, building, branches: d.branches.length };
}

const perDomain = domains.map((d) => ({ ...d, c: counts(d) }));
const totalLive = perDomain.reduce((s, d) => s + d.c.live, 0);
const totalItems = perDomain.reduce((s, d) => s + d.c.total, 0);
const totalBuilding = perDomain.reduce((s, d) => s + d.c.building, 0);
const donePct = Math.round((totalLive / totalItems) * 100);

// 빠른 실행 — 각 항목이 "눈 달린 꼬마 캐릭터"가 된다
const apps = [
  { emoji: '🗺️', label: '거울 지도', sub: '5대륙 탐험', href: '/mirror',        c: '#f2622f', m: 'hop' },
  { emoji: '💬', label: '되묻기 멘토', sub: '생각 끌어내기', href: '/ask',         c: '#ff5d8f', m: 'sway' },
  { emoji: '🎛️', label: '총괄실', sub: '오늘 한눈에', href: '/hq/index.html', c: '#ffb457', m: 'bob' },
  { emoji: '📚', label: '책장', sub: '던지면 분류', href: '/shelf',        c: '#34d3c0', m: 'spin' },
  { emoji: '📅', label: '달력', sub: '일정·할일', href: '/calendar',     c: '#7aa2ff', m: 'bob' },
  { emoji: '🌊', label: '몰입 플로우', sub: '집중 타이머', href: '/flow',        c: '#a78bfa', m: 'hop' },
  { emoji: '📥', label: '자료실', sub: '모아둔 것', href: '/archive',     c: '#ff8a4d', m: 'sway' },
  { emoji: '🏀', label: 'GTB 클럽', sub: '새벽 농구', href: '/gtb',         c: '#ff9a3d', m: 'spin' },
];

const donutC = 2 * Math.PI * 26;
---
<Base title="Home">
  <!-- ═══════════ 히어로 : 아라미 + 성장 컴패니언 ═══════════ -->
  <header class="ghero">
    <span class="gh-orb o1" aria-hidden="true"></span>
    <span class="gh-orb o2" aria-hidden="true"></span>
    <div class="wrap gh-wrap">
      <div class="gh-left" data-reveal>
        <p class="gh-kicker">🪞 Aramirror · 아람, 아름다운 사람</p>
        <h1 class="gh-title">안녕하세요 사장님 <span class="wave">👋</span><br /><mark>아라미</mark>가 오늘도 켜졌어요.</h1>
        <p class="gh-sub">던지면 알아서 제자리에 쌓이고, 밤마다 엮이고, 쓸수록 자라요. 아래 꼬마들을 눌러 바로 시작하세요.</p>

        <!-- 성장 컴패니언 : 레벨 + 연속 + XP + 자라는 화분 -->
        <div class="grow" data-reveal="120">
          <div class="grow-ring" title="레벨">
            <svg viewBox="0 0 72 72" aria-hidden="true"><circle class="gr-bg" cx="36" cy="36" r="31"/><circle class="gr-fg" id="ringFg" cx="36" cy="36" r="31"/></svg>
            <span class="gr-n"><b id="statLevel">1</b><small>Lv</small></span>
          </div>
          <div class="grow-mid">
            <div class="gchips">
              <span class="gchip"><b id="statStreak">0</b><i>🔥 연속</i></span>
              <span class="gchip"><b id="statToday">0</b><i>오늘</i></span>
              <span class="gchip"><b id="statTotal">0</b><i>누적</i></span>
              <span class="gchip live"><b>{totalLive}</b><i>🟢 작동</i></span>
            </div>
            <div class="gxp"><i id="xpFill" style="width:6%"></i></div>
            <p class="gxp-line"><span id="stagePill">씨앗</span> · <span id="xpText">0 / 3 XP</span> · 전체 {donePct}% 작동</p>
          </div>
          <div class="sprout" id="sprout" data-stage="0" title="활동할수록 자라요">
            <svg viewBox="0 0 90 90" aria-hidden="true">
              <ellipse cx="45" cy="80" rx="26" ry="6" fill="rgba(0,0,0,.18)"/>
              <path d="M30 66 h30 l-4 14 a5 5 0 0 1-5 4 H39 a5 5 0 0 1-5-4 Z" fill="#8a5334"/>
              <rect x="26" y="60" width="38" height="8" rx="3" fill="#a06a44"/>
              <g class="seed"><ellipse cx="45" cy="60" rx="4" ry="5" fill="#c9905a"/></g>
              <g class="gg g1"><path d="M45 62 C45 52 45 46 45 40" stroke="#7fd67a" stroke-width="4" fill="none" stroke-linecap="round"/><path d="M45 50 C36 46 30 50 29 57 C38 58 43 55 45 50 Z" fill="#8ce08a"/><path d="M45 44 C54 40 60 44 61 51 C52 52 47 49 45 44 Z" fill="#7fd67a"/></g>
              <g class="gg g2"><path d="M45 40 C34 35 27 40 26 48 C38 49 43 45 45 40 Z" fill="#9be89a"/><path d="M45 34 C56 29 63 34 64 42 C52 43 47 39 45 34 Z" fill="#72ca6d"/></g>
              <g class="gg g3"><circle cx="45" cy="30" r="6" fill="#ffd27a"/><circle cx="30" cy="46" r="4.5" fill="#ffcf6e"/><circle cx="60" cy="44" r="4.5" fill="#ffcf6e"/></g>
              <g class="gg g4"><g transform="translate(45 28)"><circle r="7" fill="#ff7a4d"/><circle r="3" fill="#ffe08a"/></g><g transform="translate(30 44)"><circle r="5" fill="#ff9f6a"/><circle r="2" fill="#ffe08a"/></g><g transform="translate(60 42)"><circle r="5" fill="#ff9f6a"/><circle r="2" fill="#ffe08a"/></g></g>
              <g class="gg g5"><circle cx="45" cy="24" r="17" fill="#69c164"/><circle cx="30" cy="34" r="12" fill="#7fd67a"/><circle cx="60" cy="34" r="12" fill="#7fd67a"/><circle cx="45" cy="18" r="5" fill="#ff7a4d"/></g>
            </svg>
          </div>
        </div>
      </div>

      <!-- 움직이는 아라미 캐릭터 -->
      <div class="gh-char" data-reveal="80" aria-hidden="true">
        <div class="arami">
          <span class="ar-shadow"></span>
          <span class="ar-ring"></span>
          <span class="ar-body">
            <span class="ar-shine"></span>
            <span class="ar-eye l"></span>
            <span class="ar-eye r"></span>
            <span class="ar-cheek l"></span>
            <span class="ar-cheek r"></span>
            <span class="ar-mouth"></span>
          </span>
          <span class="ar-hand" aria-hidden="true">👋</span>
          <span class="ar-spark s1">✦</span>
          <span class="ar-spark s2">✧</span>
          <span class="ar-spark s3">✦</span>
        </div>
        <p class="ar-say" id="araSay">“오늘 뭐부터 볼까요?”</p>
      </div>
    </div>
  </header>

  <!-- ═══════════ 빠른 실행 : 캐릭터 런처 ═══════════ -->
  <section class="applaunch">
    <div class="wrap">
      <p class="section-kicker" data-reveal>Quick Launch</p>
      <h2 data-reveal="60">한 번에 열기 — 꼬마들을 눌러요</h2>
      <p class="lead" data-reveal="120">자주 쓰는 곳마다 작은 친구가 살아있어요. 마우스를 올리면 폴짝 뛰어요.</p>
      <div class="crit-grid" data-reveal="160">
        {apps.map((a, i) => (
          <a class={`critc m-${a.m}`} href={a.href} style={`--ac:${a.c}; --d:${i * 120}ms`}>
            <span class="crit">
              <span class="crit-shadow"></span>
              <span class="crit-body">
                <span class="crit-eye l"></span>
                <span class="crit-eye r"></span>
                <span class="crit-cheek l"></span>
                <span class="crit-cheek r"></span>
                <span class="crit-badge">{a.emoji}</span>
              </span>
            </span>
            <span class="crit-label">{a.label}</span>
            <span class="crit-sub">{a.sub}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ 5 대륙 : 캐릭터 + 진척 링 ═══════════ -->
  <section class="conts-sec">
    <div class="wrap">
      <p class="section-kicker" data-reveal>The Mirror · 5 Continents</p>
      <h2 data-reveal="60">나를 비추는 다섯 대륙</h2>
      <p class="lead" data-reveal="120">각 대륙마다 사는 친구가 있어요. 링이 찰수록 성장한 거예요. 눌러서 들어가 보세요.</p>
      <div class="conts" data-reveal="160">
        {perDomain.map((d, i) => {
          const pct = d.c.total ? Math.round((d.c.live / d.c.total) * 100) : 0;
          const dash = `${(donutC * pct) / 100} ${donutC}`;
          return (
            <a class="ctile" href={`/mirror#${d.key}`} style={`--dc:${d.color}; --d:${i * 90}ms`}>
              <span class="ct-glow" aria-hidden="true"></span>
              <div class="ct-top">
                <span class="ct-ring" aria-hidden="true">
                  <svg viewBox="0 0 60 60" width="60" height="60">
                    <circle cx="30" cy="30" r="26" class="ct-track" />
                    <circle cx="30" cy="30" r="26" class="ct-fill" style={`stroke-dasharray:${dash}`} />
                  </svg>
                  <span class="ct-face">
                    <span class="ct-eye l"></span><span class="ct-eye r"></span>
                    <span class="ct-cheek l"></span><span class="ct-cheek r"></span>
                    <span class="ct-emoji">{d.icon}</span>
                  </span>
                </span>
                <span class="ct-pct">{pct}<small>%</small></span>
              </div>
              <span class="ct-num">대륙 {d.key} · {d.en}</span>
              <span class="ct-title">{d.title}</span>
              <span class="ct-tag">{d.tagline}</span>
              <span class="ct-foot">
                <i class="dot"></i>{d.c.live} 작동 · {d.c.total}곳
                <span class="ct-go">들어가기 →</span>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════ The Loop ═══════════ -->
  <section class="loop-sec">
    <div class="wrap">
      <p class="section-kicker" data-reveal>The Loop</p>
      <h2 data-reveal="60">생각 → 지식 → 자산</h2>
      <p class="lead" data-reveal="120">던지면 알아서 엮이고 서술된다. 네 단계가 서로 다른 리듬으로 돈다.</p>
      <div class="num-grid">
        <div class="num-item" data-reveal="0"><span class="ni">01</span><h4>던진다</h4><p>떠오른 생각을 그대로 던진다. 정리·분류·태그는 없다. 입력 마찰 0.</p></div>
        <div class="num-item" data-reveal="80"><span class="ni">02</span><h4>엮인다</h4><p>쌓인 메모 사이의 연결을 매일 밤 자동으로 발견한다. 오늘 생각이 지난달·외부 개념과 이어진다.</p></div>
        <div class="num-item" data-reveal="160"><span class="ni">03</span><h4>자산이 된다</h4><p>성숙한 생각은 글·발표·아카이브가 된다. 생각의 과정 자체가 포트폴리오.</p></div>
        <div class="num-item" data-reveal="240"><span class="ni">04</span><h4>소유권은 나에게</h4><p>AI는 편집자일 뿐. 내 생각은 내 언어로, 내 자산으로 남는다.</p></div>
      </div>
    </div>
  </section>

  <!-- ═══════════ Build Logs ═══════════ -->
  <section>
    <div class="wrap">
      <p class="section-kicker" data-reveal>Build Logs</p>
      <h2 data-reveal="60">이 시스템을 만들어가는 기록</h2>
      <p class="lead" data-reveal="120">Aramirror가 어떻게 태어나고 자라는지, 개발일지로 남긴다.</p>
      <ul class="logs" data-reveal="160">
        {latestLogs.map((l) => (
          <li><a href={l.href}><span class="id">{l.id}</span><span class="t">{l.title}</span><span class="d">{l.date}</span></a></li>
        ))}
      </ul>
      <p data-reveal="200" style="margin-top:22px"><a class="btn-outline" href="/build-logs">전체 기록 보기 →</a></p>
    </div>
  </section>

  <style is:global>
    /* ══════════ 히어로 ══════════ */
    .ghero { position: relative; overflow: hidden; padding: clamp(30px, 6vw, 64px) 0 clamp(30px, 6vw, 56px); }
    .gh-orb { position: absolute; border-radius: 50%; filter: blur(46px); opacity: .5; pointer-events: none; z-index: 0; }
    .gh-orb.o1 { width: 340px; height: 340px; top: -110px; right: -60px; background: radial-gradient(circle, #ffb45766, transparent 70%); animation: drift 14s var(--ease) infinite; }
    .gh-orb.o2 { width: 300px; height: 300px; bottom: -120px; left: -70px; background: radial-gradient(circle, #ff5d8f4d, transparent 70%); animation: drift 18s var(--ease) infinite reverse; }
    .gh-wrap { position: relative; z-index: 1; display: grid; grid-template-columns: 1.35fr 1fr; align-items: center; gap: 30px; }
    .gh-kicker { font-family: var(--mono); font-size: .78rem; letter-spacing: .04em; color: var(--accent); margin-bottom: 12px; }
    .gh-title { font-size: clamp(1.85rem, 5vw, 2.95rem); line-height: 1.13; letter-spacing: -.03em; font-weight: 800; }
    .gh-title mark { background: var(--grad); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; padding: 0; }
    .gh-title .wave { display: inline-block; transform-origin: 70% 80%; animation: wave 2.4s var(--ease) infinite; }
    .gh-sub { margin-top: 14px; max-width: 44ch; color: var(--fg-soft); font-size: 1.02rem; line-height: 1.6; }

    /* 성장 컴패니언 */
    .grow { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 14px; margin-top: 22px; padding: 15px 18px; border-radius: 20px; background: var(--bg-1); border: 1px solid var(--line); box-shadow: var(--shadow-soft); max-width: 520px; }
    .grow-ring { position: relative; width: 60px; height: 60px; flex-shrink: 0; }
    .grow-ring svg { width: 60px; height: 60px; transform: rotate(-90deg); }
    .gr-bg { fill: none; stroke: color-mix(in srgb, var(--accent) 14%, var(--bg-2)); stroke-width: 6; }
    .gr-fg { fill: none; stroke: url(#g); stroke: var(--accent); stroke-width: 6; stroke-linecap: round; stroke-dasharray: 195; stroke-dashoffset: 184; transition: stroke-dashoffset 1s var(--ease); filter: drop-shadow(0 0 4px var(--accent-glow)); }
    .gr-n { position: absolute; inset: 0; display: grid; place-items: center; line-height: 1; }
    .gr-n b { font-size: 1.15rem; font-weight: 800; color: var(--accent); }
    .gr-n small { font-size: .55rem; color: var(--muted); font-family: var(--mono); }
    .grow-mid { min-width: 0; }
    .gchips { display: flex; flex-wrap: wrap; gap: 6px; }
    .gchip { display: inline-flex; align-items: baseline; gap: 4px; background: var(--bg-2); border: 1px solid var(--line); border-radius: 999px; padding: 3px 9px; font-size: .7rem; color: var(--fg-soft); }
    .gchip b { font-size: .84rem; font-weight: 800; color: var(--fg); font-variant-numeric: tabular-nums; }
    .gchip.live b { color: #128a7c; }
    .gxp { height: 9px; margin: 9px 0 5px; border-radius: 999px; background: color-mix(in srgb, var(--accent) 12%, var(--bg-2)); overflow: hidden; }
    .gxp i { display: block; height: 100%; border-radius: 999px; background: var(--grad); box-shadow: 0 0 10px var(--accent-glow); transition: width 1s var(--ease); }
    .gxp-line { font-family: var(--mono); font-size: .68rem; color: var(--muted); }
    .sprout { width: 62px; height: 62px; flex-shrink: 0; animation: bob 3.4s var(--ease) infinite; }
    .sprout svg { width: 100%; height: 100%; overflow: visible; }
    .sprout .gg { opacity: 0; transform-origin: 45px 66px; transform: scale(.4); transition: opacity .5s, transform .5s var(--ease); }
    .sprout .seed { transition: opacity .4s; }
    .sprout[data-stage="0"] .seed { opacity: 1; } .sprout:not([data-stage="0"]) .seed { opacity: 0; }
    .sprout[data-stage="1"] .g1, .sprout[data-stage="2"] .g1, .sprout[data-stage="2"] .g2,
    .sprout[data-stage="3"] .g1, .sprout[data-stage="3"] .g2, .sprout[data-stage="3"] .g3,
    .sprout[data-stage="4"] .g1, .sprout[data-stage="4"] .g2, .sprout[data-stage="4"] .g3, .sprout[data-stage="4"] .g4,
    .sprout[data-stage="5"] .g5 { opacity: 1; transform: scale(1); }

    /* 아라미 캐릭터 */
    .gh-char { display: grid; place-items: center; }
    .arami { position: relative; width: 190px; height: 190px; animation: float 4s var(--ease) infinite; }
    .ar-shadow { position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%); width: 108px; height: 20px; border-radius: 50%; background: radial-gradient(ellipse, rgba(70,45,25,.22), transparent 72%); animation: shadowpulse 4s var(--ease) infinite; }
    .ar-ring { position: absolute; inset: 6px; border-radius: 50%; border: 2px dashed color-mix(in srgb, var(--accent) 45%, transparent); animation: spin 22s linear infinite; }
    .ar-body { position: absolute; inset: 20px; border-radius: 50% 50% 48% 48%; background: linear-gradient(160deg, #fff 0%, #ffe6d3 44%, #ffb9a0 100%); box-shadow: inset 0 -14px 26px rgba(255,120,90,.35), inset 0 10px 20px #fff, 0 18px 36px rgba(242,98,47,.30); animation: squish 3.2s var(--ease) infinite; }
    .ar-shine { position: absolute; top: 16%; left: 20%; width: 34%; height: 24%; border-radius: 50%; background: radial-gradient(circle at 40% 40%, rgba(255,255,255,.95), transparent 68%); }
    .ar-eye { position: absolute; top: 44%; width: 15px; height: 20px; background: #3a2418; border-radius: 50%; animation: blink 4s infinite; }
    .ar-eye::after { content: ""; position: absolute; top: 3px; left: 3px; width: 5px; height: 5px; background: #fff; border-radius: 50%; }
    .ar-eye.l { left: 34%; } .ar-eye.r { right: 34%; }
    .ar-cheek { position: absolute; top: 55%; width: 16px; height: 10px; border-radius: 50%; background: #ff9a8b; opacity: .6; filter: blur(1px); }
    .ar-cheek.l { left: 27%; } .ar-cheek.r { right: 27%; }
    .ar-mouth { position: absolute; top: 60%; left: 50%; transform: translateX(-50%); width: 26px; height: 13px; border: 3px solid #3a2418; border-top: 0; border-radius: 0 0 26px 26px; animation: talk 4s var(--ease) infinite; }
    .ar-hand { position: absolute; right: 6%; top: 38%; font-size: 30px; transform-origin: 60% 90%; animation: wave 2s var(--ease) infinite; }
    .ar-spark { position: absolute; font-size: 18px; color: var(--a2); animation: twinkle 2.4s ease-in-out infinite; }
    .ar-spark.s1 { top: 8%; right: 6%; } .ar-spark.s2 { bottom: 20%; left: 0%; color: var(--a3); animation-delay: .7s; font-size: 15px; } .ar-spark.s3 { top: 30%; left: -6%; color: var(--a1); animation-delay: 1.3s; font-size: 13px; }
    .ar-say { margin-top: 8px; font-size: .9rem; font-weight: 700; color: var(--accent); background: var(--bg-1); border: 1px solid var(--line); padding: 7px 14px; border-radius: 999px; box-shadow: var(--shadow-soft); animation: pop 3.4s var(--ease) infinite; }

    /* ══════════ 캐릭터 런처 ══════════ */
    .applaunch { padding-top: 6px; }
    .crit-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(132px, 1fr)); gap: 14px; margin-top: 22px; }
    .critc { position: relative; overflow: hidden; text-decoration: none; color: var(--fg); display: flex; flex-direction: column; align-items: center; text-align: center; gap: 3px; padding: 18px 12px 15px; border-radius: 22px; background: linear-gradient(165deg, color-mix(in srgb, var(--ac) 12%, var(--bg-1)), var(--bg-1) 76%); border: 1px solid color-mix(in srgb, var(--ac) 26%, var(--line)); box-shadow: var(--shadow-soft); transition: transform .18s var(--ease), box-shadow .2s, border-color .2s; animation: rise .5s var(--ease) both; animation-delay: var(--d); }
    .critc:hover { transform: translateY(-6px); border-color: var(--ac); box-shadow: 0 20px 40px color-mix(in srgb, var(--ac) 30%, transparent); }
    .critc:active { transform: translateY(-1px) scale(.96); }

    .crit { position: relative; width: 66px; height: 62px; margin-bottom: 8px; }
    .crit-shadow { position: absolute; bottom: -2px; left: 50%; transform: translateX(-50%); width: 42px; height: 8px; border-radius: 50%; background: radial-gradient(ellipse, rgba(70,45,25,.20), transparent 72%); }
    .crit-body { position: absolute; inset: 0 6px 4px 6px; border-radius: 50% 50% 46% 46%; background: linear-gradient(160deg, color-mix(in srgb, var(--ac) 45%, #fff), color-mix(in srgb, var(--ac) 92%, #000 8%)); box-shadow: inset 0 -6px 12px rgba(0,0,0,.22), inset 0 6px 10px rgba(255,255,255,.5), 0 8px 16px color-mix(in srgb, var(--ac) 35%, transparent); }
    .crit-eye { position: absolute; top: 34%; width: 9px; height: 13px; background: #241a14; border-radius: 50%; animation: blink 3.6s infinite; }
