---
import Base from '../layouts/Base.astro';
import { logs } from '../data/logs.js';
import { domains } from '../data/mirror.js';
const latestLogs = logs.slice(0, 3);

function counts(d) {
  let live = 0, total = 0, building = 0;
  d.branches.forEach((b) => b.items.forEach((it) => {
    total++;
    if (it.status === 'live') live++;
    if (it.status === 'building') building++;
  }));
  return { live, total, building, branches: d.branches.length };
}

// ── 게이미피케이션 집계 ──────────────────────────────
const perDomain = domains.map((d) => ({ ...d, c: counts(d) }));
const totalLive = perDomain.reduce((s, d) => s + d.c.live, 0);
const totalItems = perDomain.reduce((s, d) => s + d.c.total, 0);
const totalBuilding = perDomain.reduce((s, d) => s + d.c.building, 0);
const level = Math.floor(totalLive / 5) + 1;         // 5개 작동할 때마다 레벨업
const levelBase = (level - 1) * 5;
const xpInLevel = totalLive - levelBase;              // 이번 레벨에서 채운 XP
const xpPct = Math.round((xpInLevel / 5) * 100);
const donePct = Math.round((totalLive / totalItems) * 100);

// ── 빠른 실행(앱 아이콘) ─────────────────────────────
const apps = [
  { icon: '🗺️', label: '거울 지도', sub: '5대륙 탐험', href: '/mirror',        c: '#f2622f' },
  { icon: '💬', label: '되묻기 멘토', sub: '생각 끌어내기', href: '/ask',         c: '#ff5d8f' },
  { icon: '🎛️', label: '총괄실', sub: '오늘 한눈에', href: '/hq/index.html', c: '#ffb457' },
  { icon: '📚', label: '책장', sub: '던지면 분류', href: '/shelf',        c: '#34d3c0' },
  { icon: '📅', label: '달력', sub: '일정·할일', href: '/calendar',     c: '#7aa2ff' },
  { icon: '🌊', label: '몰입 플로우', sub: '집중 타이머', href: '/flow',        c: '#a78bfa' },
  { icon: '📥', label: '자료실', sub: '모아둔 것', href: '/archive',     c: '#ff8a4d' },
  { icon: '🏀', label: 'GTB 클럽', sub: '새벽 농구', href: '/gtb',         c: '#ff9a3d' },
];

const donutC = 2 * Math.PI * 26; // 반지름 26 원 둘레
---
<Base title="Home">
  <!-- ═══════════ 히어로 : 움직이는 아라미 + 게임 HUD ═══════════ -->
  <header class="ghero">
    <span class="gh-orb o1" aria-hidden="true"></span>
    <span class="gh-orb o2" aria-hidden="true"></span>
    <div class="wrap gh-wrap">
      <div class="gh-left" data-reveal>
        <p class="gh-kicker">🪞 Aramirror · 아람, 아름다운 사람</p>
        <h1 class="gh-title">안녕하세요 사장님 👋<br /><mark>아라미</mark>가 오늘도 켜졌어요.</h1>
        <p class="gh-sub">
          던지면 알아서 제자리에 쌓이고, 밤마다 엮이고, 쓸수록 자라요.
          아래 아이콘을 눌러 바로 시작하세요.
        </p>

        <!-- 게임 HUD -->
        <div class="hud" data-reveal="120">
          <div class="hud-lv">
            <span class="hud-badge">Lv.{level}</span>
            <div class="hud-xp">
              <div class="hud-xp-head">
                <b>거울 성장도</b>
                <span>{totalLive} / {totalItems} 작동 중 · {donePct}%</span>
              </div>
              <div class="hud-bar"><i style={`width:${Math.max(xpPct, 6)}%`}></i></div>
              <div class="hud-xp-foot">다음 레벨까지 {5 - xpInLevel}개 더 켜기</div>
            </div>
          </div>
          <div class="hud-chips">
            <span class="chip on">🟢 작동 {totalLive}</span>
            <span class="chip build">🔨 만드는 중 {totalBuilding}</span>
            <span class="chip">🌍 대륙 {domains.length}</span>
          </div>
        </div>
      </div>

      <!-- 움직이는 아라미 캐릭터 -->
      <div class="gh-char" data-reveal="80" aria-hidden="true">
        <div class="arami">
          <span class="ar-shadow"></span>
          <span class="ar-ring"></span>
          <span class="ar-body">
            <span class="ar-shine"></span>
            <span class="ar-eye l"></span>
            <span class="ar-eye r"></span>
            <span class="ar-cheek l"></span>
            <span class="ar-cheek r"></span>
            <span class="ar-mouth"></span>
          </span>
          <span class="ar-spark s1">✦</span>
          <span class="ar-spark s2">✧</span>
          <span class="ar-spark s3">✦</span>
        </div>
        <p class="ar-say">“오늘 뭐부터 볼까요?”</p>
      </div>
    </div>
  </header>

  <!-- ═══════════ 빠른 실행 : 앱 아이콘 그리드 ═══════════ -->
  <section class="applaunch">
    <div class="wrap">
      <p class="section-kicker" data-reveal>Quick Launch</p>
      <h2 data-reveal="60">한 번에 열기</h2>
      <p class="lead" data-reveal="120">자주 쓰는 곳을 큼직한 버튼으로. 눌러 보세요.</p>
      <div class="app-grid" data-reveal="160">
        {apps.map((a, i) => (
          <a class="app" href={a.href} style={`--ac:${a.c}; --d:${i * 55}ms`}>
            <span class="app-ico"><span class="app-emoji">{a.icon}</span></span>
            <span class="app-label">{a.label}</span>
            <span class="app-sub">{a.sub}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════ 5 대륙 : 게임 타일 + 진척 링 ═══════════ -->
  <section class="conts-sec">
    <div class="wrap">
      <p class="section-kicker" data-reveal>The Mirror · 5 Continents</p>
      <h2 data-reveal="60">나를 비추는 다섯 대륙</h2>
      <p class="lead" data-reveal="120">각 대륙의 링이 얼마나 찼는지가 곧 성장도예요. 눌러서 안으로 들어가 보세요.</p>
      <div class="conts" data-reveal="160">
        {perDomain.map((d) => {
          const pct = d.c.total ? Math.round((d.c.live / d.c.total) * 100) : 0;
          const dash = `${(donutC * pct) / 100} ${donutC}`;
          return (
            <a class="ctile" href={`/mirror#${d.key}`} style={`--dc:${d.color}`}>
              <span class="ct-glow" aria-hidden="true"></span>
              <div class="ct-top">
                <span class="ct-ring" aria-hidden="true">
                  <svg viewBox="0 0 60 60" width="60" height="60">
                    <circle cx="30" cy="30" r="26" class="ct-track" />
                    <circle cx="30" cy="30" r="26" class="ct-fill" style={`stroke-dasharray:${dash}`} />
                  </svg>
                  <span class="ct-emoji">{d.icon}</span>
                </span>
                <span class="ct-pct">{pct}<small>%</small></span>
              </div>
              <span class="ct-num">대륙 {d.key} · {d.en}</span>
              <span class="ct-title">{d.title}</span>
              <span class="ct-tag">{d.tagline}</span>
              <span class="ct-foot">
                <i class="dot"></i>{d.c.live} 작동 · {d.c.total}곳
                <span class="ct-go">들어가기 →</span>
              </span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════ The Loop ═══════════ -->
  <section class="loop-sec">
    <div class="wrap">
      <p class="section-kicker" data-reveal>The Loop</p>
      <h2 data-reveal="60">생각 → 지식 → 자산</h2>
      <p class="lead" data-reveal="120">던지면 알아서 엮이고 서술된다. 네 단계가 서로 다른 리듬으로 돈다.</p>
      <div class="num-grid">
        <div class="num-item" data-reveal="0"><span class="ni">01</span><h4>던진다</h4><p>떠오른 생각을 그대로 던진다. 정리·분류·태그는 없다. 입력 마찰 0.</p></div>
        <div class="num-item" data-reveal="80"><span class="ni">02</span><h4>엮인다</h4><p>쌓인 메모 사이의 연결을 매일 밤 자동으로 발견한다. 오늘 생각이 지난달·외부 개념과 이어진다.</p></div>
        <div class="num-item" data-reveal="160"><span class="ni">03</span><h4>자산이 된다</h4><p>성숙한 생각은 글·발표·아카이브가 된다. 생각의 과정 자체가 포트폴리오.</p></div>
        <div class="num-item" data-reveal="240"><span class="ni">04</span><h4>소유권은 나에게</h4><p>AI는 편집자일 뿐. 내 생각은 내 언어로, 내 자산으로 남는다.</p></div>
      </div>
    </div>
  </section>

  <!-- ═══════════ Build Logs ═══════════ -->
  <section>
    <div class="wrap">
      <p class="section-kicker" data-reveal>Build Logs</p>
      <h2 data-reveal="60">이 시스템을 만들어가는 기록</h2>
      <p class="lead" data-reveal="120">Aramirror가 어떻게 태어나고 자라는지, 개발일지로 남긴다.</p>
      <ul class="logs" data-reveal="160">
        {latestLogs.map((l) => (
          <li><a href={l.href}><span class="id">{l.id}</span><span class="t">{l.title}</span><span class="d">{l.date}</span></a></li>
        ))}
      </ul>
      <p data-reveal="200" style="margin-top:22px"><a class="btn-outline" href="/build-logs">전체 기록 보기 →</a></p>
    </div>
  </section>

  <style is:global>
    /* ══════════ 히어로 ══════════ */
    .ghero { position: relative; overflow: hidden; padding: clamp(30px, 6vw, 68px) 0 clamp(34px, 6vw, 62px); }
    .gh-orb { position: absolute; border-radius: 50%; filter: blur(46px); opacity: .5; pointer-events: none; z-index: 0; }
    .gh-orb.o1 { width: 340px; height: 340px; top: -110px; right: -60px; background: radial-gradient(circle, #ffb45766, transparent 70%); animation: drift 14s var(--ease) infinite; }
    .gh-orb.o2 { width: 300px; height: 300px; bottom: -120px; left: -70px; background: radial-gradient(circle, #ff5d8f4d, transparent 70%); animation: drift 18s var(--ease) infinite reverse; }
    .gh-wrap { position: relative; z-index: 1; display: grid; grid-template-columns: 1.35fr 1fr; align-items: center; gap: 30px; }
    .gh-kicker { font-family: var(--mono); font-size: .78rem; letter-spacing: .04em; color: var(--accent); margin-bottom: 12px; }
    .gh-title { font-size: clamp(1.9rem, 5.2vw, 3.05rem); line-height: 1.12; letter-spacing: -.03em; font-weight: 800; }
    .gh-title mark { background: var(--grad); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; padding: 0; }
    .gh-sub { margin-top: 16px; max-width: 44ch; color: var(--fg-soft); font-size: 1.02rem; line-height: 1.6; }

    /* 게임 HUD */
    .hud { margin-top: 24px; padding: 16px 18px; border-radius: 18px; background: var(--bg-1); border: 1px solid var(--line); box-shadow: var(--shadow-soft); max-width: 460px; }
    .hud-lv { display: flex; align-items: center; gap: 14px; }
    .hud-badge { flex-shrink: 0; display: grid; place-items: center; width: 54px; height: 54px; border-radius: 15px; background: var(--grad); color: #fff; font-weight: 800; font-size: 1.05rem; box-shadow: 0 8px 20px var(--accent-glow); animation: pop 2.6s var(--ease) infinite; }
    .hud-xp { flex: 1; min-width: 0; }
    .hud-xp-head { display: flex; justify-content: space-between; align-items: baseline; gap: 8px; font-size: .8rem; }
    .hud-xp-head b { font-size: .9rem; }
    .hud-xp-head span { font-family: var(--mono); color: var(--muted); font-size: .72rem; font-variant-numeric: tabular-nums; }
    .hud-bar { height: 11px; margin: 7px 0 5px; border-radius: 7px; background: color-mix(in srgb, var(--accent) 12%, var(--bg-2)); overflow: hidden; }
    .hud-bar i { display: block; height: 100%; border-radius: 7px; background: var(--grad); box-shadow: 0 0 12px var(--accent-glow); animation: fillin 1.2s var(--ease) both; }
    .hud-xp-foot { font-size: .72rem; color: var(--muted); }
    .hud-chips { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 14px; }
    .chip { font-size: .74rem; font-weight: 700; padding: 5px 11px; border-radius: 999px; background: var(--bg-2); border: 1px solid var(--line); color: var(--fg-soft); }
    .chip.on { background: color-mix(in srgb, #34d3c0 16%, var(--bg-1)); border-color: #34d3c055; color: #128a7c; }
    .chip.build { background: color-mix(in srgb, #ffb457 18%, var(--bg-1)); border-color: #ffb45766; color: #a9691a; }

    /* 아라미 캐릭터 */
    .gh-char { display: grid; place-items: center; }
    .arami { position: relative; width: 190px; height: 190px; animation: float 4s var(--ease) infinite; }
    .ar-shadow { position: absolute; bottom: 2px; left: 50%; transform: translateX(-50%); width: 108px; height: 20px; border-radius: 50%; background: radial-gradient(ellipse, rgba(70,45,25,.22), transparent 72%); animation: shadowpulse 4s var(--ease) infinite; }
    .ar-ring { position: absolute; inset: 6px; border-radius: 50%; border: 2px dashed color-mix(in srgb, var(--accent) 45%, transparent); animation: spin 22s linear infinite; }
    .ar-body { position: absolute; inset: 20px; border-radius: 50% 50% 48% 48%; background: linear-gradient(160deg, #fff 0%, #ffe6d3 44%, #ffb9a0 100%); box-shadow: inset 0 -14px 26px rgba(255,120,90,.35), inset 0 10px 20px #fff, 0 18px 36px rgba(242,98,47,.30); }
    .ar-shine { position: absolute; top: 16%; left: 20%; width: 34%; height: 24%; border-radius: 50%; background: radial-gradient(circle at 40% 40%, rgba(255,255,255,.95), transparent 68%); }
    .ar-eye { position: absolute; top: 44%; width: 15px; height: 20px; background: #3a2418; border-radius: 50%; animation: blink 4.4s infinite; }
    .ar-eye::after { content: ""; position: absolute; top: 3px; left: 3px; width: 5px; height: 5px; background: #fff; border-radius: 50%; }
    .ar-eye.l { left: 34%; } .ar-eye.r { right: 34%; }
    .ar-cheek { position: absolute; top: 55%; width: 16px; height: 10px; border-radius: 50%; background: #ff9a8b; opacity: .6; filter: blur(1px); }
    .ar-cheek.l { left: 27%; } .ar-cheek.r { right: 27%; }
    .ar-mouth { position: absolute; top: 60%; left: 50%; transform: translateX(-50%); width: 26px; height: 13px; border: 3px solid #3a2418; border-top: 0; border-radius: 0 0 26px 26px; animation: talk 4s var(--ease) infinite; }
    .ar-spark { position: absolute; font-size: 18px; color: var(--a2); animation: twinkle 2.4s ease-in-out infinite; }
    .ar-spark.s1 { top: 8%; right: 6%; animation-delay: 0s; }
    .ar-spark.s2 { bottom: 20%; left: 0%; color: var(--a3); animation-delay: .7s; font-size: 15px; }
    .ar-spark.s3 { top: 30%; left: -6%; color: var(--a1); animation-delay: 1.3s; font-size: 13px; }
    .ar-say { margin-top: 10px; font-size: .9rem; font-weight: 700; color: var(--accent); background: var(--bg-1); border: 1px solid var(--line); padding: 7px 14px; border-radius: 999px; box-shadow: var(--shadow-soft); animation: pop 3.4s var(--ease) infinite; }

    /* ══════════ 앱 런치 그리드 ══════════ */
    .applaunch { padding-top: 6px; }
    .app-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 14px; margin-top: 22px; }
    .app { position: relative; overflow: hidden; text-decoration: none; color: var(--fg); display: flex; flex-direction: column; align-items: center; text-align: center; gap: 4px; padding: 20px 12px 16px; border-radius: 20px; background: var(--bg-1); border: 1px solid var(--line); box-shadow: var(--shadow-soft); transition: transform .18s var(--ease), box-shadow .2s, border-color .2s; animation: rise .5s var(--ease) both; animation-delay: var(--d); }
    .app::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 4px; background: var(--ac); opacity: .85; }
    .app:hover { transform: translateY(-5px); border-color: var(--ac); box-shadow: 0 18px 36px color-mix(in srgb, var(--ac) 28%, transparent); }
    .app:active { transform: translateY(-1px) scale(.97); }
    .app-ico { width: 58px; height: 58px; border-radius: 17px; display: grid; place-items: center; background: color-mix(in srgb, var(--ac) 15%, var(--bg-2)); border: 1px solid color-mix(in srgb, var(--ac) 30%, transparent); margin-bottom: 6px; transition: transform .2s var(--ease); }
    .app:hover .app-ico { transform: rotate(-6deg) scale(1.08); }
    .app-emoji { font-size: 1.9rem; line-height: 1; display: block; animation: wiggle 3.5s var(--ease) infinite; }
    .app:hover .app-emoji { animation-duration: 1s; }
    .app-label { font-weight: 800; font-size: 1rem; letter-spacing: -.02em; }
    .app-sub { font-size: .74rem; color: var(--muted); }

    /* ══════════ 대륙 게임 타일 ══════════ */
    .conts-sec { padding-top: 8px; }
    .conts { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 16px; margin-top: 22px; }
    .ctile { position: relative; overflow: hidden; text-decoration: none; color: var(--fg); display: flex; flex-direction: column; gap: 3px; padding: 20px; border-radius: 22px; background: linear-gradient(158deg, color-mix(in srgb, var(--dc) 15%, var(--bg-1)), var(--bg-1) 74%); border: 1px solid color-mix(in srgb, var(--dc) 30%, var(--line)); box-shadow: var(--shadow-soft); transition: transform .2s var(--ease), border-color .2s, box-shadow .2s; }
    .ctile:hover { transform: translateY(-5px); border-color: var(--dc); box-shadow: 0 20px 42px color-mix(in srgb, var(--dc) 30%, transparent); }
    .ct-glow { position: absolute; top: -40px; right: -40px; width: 130px; height: 130px; background: radial-gradient(circle, color-mix(in srgb, var(--dc) 50%, transparent), transparent 70%); opacity: .5; pointer-events: none; transition: opacity .2s; }
    .ctile:hover .ct-glow { opacity: .95; }
    .ct-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .ct-ring { position: relative; width: 60px; height: 60px; display: grid; place-items: center; }
    .ct-ring svg { position: absolute; inset: 0; transform: rotate(-90deg); }
    .ct-track { fill: none; stroke: color-mix(in srgb, var(--dc) 18%, var(--line)); stroke-width: 5; }
    .ct-fill { fill: none; stroke: var(--dc); stroke-width: 5; stroke-linecap: round; transition: stroke-dasharray 1s var(--ease); filter: drop-shadow(0 0 4px color-mix(in srgb, var(--dc) 60%, transparent)); }
    .ct-emoji { font-size: 1.55rem; line-height: 1; animation: bob 3s var(--ease) infinite; }
    .ctile:hover .ct-emoji { animation-duration: 1.1s; }
    .ct-pct { font-family: var(--mono); font-weight: 800; font-size: 1.5rem; color: var(--dc); font-variant-numeric: tabular-nums; }
    .ct-pct small { font-size: .8rem; opacity: .7; }
    .ct-num { font-family: var(--mono); font-size: .66rem; color: var(--dc); letter-spacing: .05em; text-transform: uppercase; }
    .ct-title { font-size: 1.22rem; font-weight: 800; letter-spacing: -.02em; line-height: 1.12; }
    .ct-tag { font-size: .82rem; color: var(--fg-soft); }
    .ct-foot { display: flex; align-items: center; gap: 7px; margin-top: 13px; padding-top: 11px; border-top: 1px solid var(--line-soft); font-family: var(--mono); font-size: .72rem; color: var(--muted); font-variant-numeric: tabular-nums; }
    .ct-foot .dot { width: 7px; height: 7px; border-radius: 50%; background: #34d3c0; box-shadow: 0 0 7px #34d3c0; animation: pulse 2s infinite; }
    .ct-go { margin-left: auto; color: var(--dc); font-weight: 700; }

    .loop-sec { }

    /* ══════════ 애니메이션 ══════════ */
    @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-14px); } }
    @keyframes shadowpulse { 0%,100% { transform: translateX(-50%) scale(1); opacity: .22; } 50% { transform: translateX(-50%) scale(.8); opacity: .12; } }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes blink { 0%,92%,100% { transform: scaleY(1); } 96% { transform: scaleY(.1); } }
    @keyframes talk { 0%,100% { height: 13px; } 50% { height: 8px; } }
    @keyframes twinkle { 0%,100% { opacity: .25; transform: scale(.7); } 50% { opacity: 1; transform: scale(1.15); } }
    @keyframes pop { 0%,100% { transform: scale(1); } 50% { transform: scale(1.05); } }
    @keyframes fillin { from { width: 0; } }
    @keyframes rise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes wiggle { 0%,100% { transform: rotate(0); } 25% { transform: rotate(-7deg); } 75% { transform: rotate(7deg); } }
    @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
    @keyframes drift { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-24px, 20px); } }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .4; } }

