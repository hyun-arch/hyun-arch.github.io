    .ctile { position: relative; overflow: hidden; text-decoration: none; color: var(--fg); display: flex; flex-direction: column; gap: 3px; padding: 20px; border-radius: 22px; background: linear-gradient(158deg, color-mix(in srgb, var(--dc) 15%, var(--bg-1)), var(--bg-1) 74%); border: 1px solid color-mix(in srgb, var(--dc) 30%, var(--line)); box-shadow: var(--shadow-soft); transition: transform .2s var(--ease), border-color .2s, box-shadow .2s; animation: rise .5s var(--ease) both; animation-delay: var(--d); }
    .ctile:hover { transform: translateY(-5px); border-color: var(--dc); box-shadow: 0 20px 42px color-mix(in srgb, var(--dc) 30%, transparent); }
    .ct-glow { position: absolute; top: -40px; right: -40px; width: 130px; height: 130px; background: radial-gradient(circle, color-mix(in srgb, var(--dc) 50%, transparent), transparent 70%); opacity: .5; pointer-events: none; transition: opacity .2s; }
    .ctile:hover .ct-glow { opacity: .95; }
    .ct-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .ct-ring { position: relative; width: 60px; height: 60px; display: grid; place-items: center; }
    .ct-ring svg { position: absolute; inset: 0; transform: rotate(-90deg); }
    .ct-track { fill: none; stroke: color-mix(in srgb, var(--dc) 18%, var(--line)); stroke-width: 5; }
    .ct-fill { fill: none; stroke: var(--dc); stroke-width: 5; stroke-linecap: round; transition: stroke-dasharray 1s var(--ease); filter: drop-shadow(0 0 4px color-mix(in srgb, var(--dc) 60%, transparent)); }
    /* 대륙 친구 얼굴 */
    .ct-face { position: relative; width: 40px; height: 38px; border-radius: 50% 50% 46% 46%; background: linear-gradient(160deg, color-mix(in srgb, var(--dc) 50%, #fff), color-mix(in srgb, var(--dc) 92%, #000 8%)); box-shadow: inset 0 -4px 8px rgba(0,0,0,.2), inset 0 4px 7px rgba(255,255,255,.5); animation: bob 3s var(--ease) infinite; }
    .ctile:hover .ct-face { animation: cheer .5s var(--ease) infinite; }
    .ct-eye { position: absolute; top: 32%; width: 6px; height: 9px; background: #241a14; border-radius: 50%; animation: blink 4.2s infinite; }
    .ct-eye::after { content: ""; position: absolute; top: 1.5px; left: 1.5px; width: 2.5px; height: 2.5px; background: #fff; border-radius: 50%; }
    .ct-eye.l { left: 28%; } .ct-eye.r { right: 28%; }
    .ct-cheek { position: absolute; top: 50%; width: 7px; height: 4px; border-radius: 50%; background: #ff8f7d; opacity: .5; }
    .ct-cheek.l { left: 16%; } .ct-cheek.r { right: 16%; }
    .ct-emoji { position: absolute; bottom: 1px; left: 50%; transform: translateX(-50%); font-size: .8rem; line-height: 1; }
    .ct-pct { font-family: var(--mono); font-weight: 800; font-size: 1.5rem; color: var(--dc); font-variant-numeric: tabular-nums; }
    .ct-pct small { font-size: .8rem; opacity: .7; }
    .ct-num { font-family: var(--mono); font-size: .66rem; color: var(--dc); letter-spacing: .05em; text-transform: uppercase; }
    .ct-title { font-size: 1.22rem; font-weight: 800; letter-spacing: -.02em; line-height: 1.12; }
    .ct-tag { font-size: .82rem; color: var(--fg-soft); }
    .ct-foot { display: flex; align-items: center; gap: 7px; margin-top: 13px; padding-top: 11px; border-top: 1px solid var(--line-soft); font-family: var(--mono); font-size: .72rem; color: var(--muted); font-variant-numeric: tabular-nums; }
    .ct-foot .dot { width: 7px; height: 7px; border-radius: 50%; background: #34d3c0; box-shadow: 0 0 7px #34d3c0; animation: pulse 2s infinite; }
    .ct-go { margin-left: auto; color: var(--dc); font-weight: 700; }

    /* ══════════ 애니메이션 ══════════ */
    @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-14px); } }
    @keyframes squish { 0%,100% { border-radius: 50% 50% 48% 48%; } 50% { border-radius: 48% 48% 52% 52%; } }
    @keyframes shadowpulse { 0%,100% { transform: translateX(-50%) scale(1); opacity: .22; } 50% { transform: translateX(-50%) scale(.8); opacity: .12; } }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes blink { 0%,92%,100% { transform: scaleY(1); } 96% { transform: scaleY(.1); } }
    @keyframes talk { 0%,100% { height: 13px; } 50% { height: 8px; } }
    @keyframes wave { 0%,100% { transform: rotate(0); } 25% { transform: rotate(-22deg); } 60% { transform: rotate(14deg); } }
    @keyframes twinkle { 0%,100% { opacity: .25; transform: scale(.7); } 50% { opacity: 1; transform: scale(1.15); } }
    @keyframes pop { 0%,100% { transform: translateX(-50%) scale(1); } 50% { transform: translateX(-50%) scale(1.08); } }
    @keyframes fillin { from { width: 0; } }
    @keyframes rise { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
    @keyframes hop { 0%,100% { transform: translateY(0) scaleY(1); } 15% { transform: translateY(0) scaleY(.86); } 45% { transform: translateY(-14px) scaleY(1.06); } 75% { transform: translateY(0) scaleY(.94); } }
    @keyframes sway { 0%,100% { transform: rotate(-7deg); } 50% { transform: rotate(7deg); } }
    @keyframes wobble { 0%,100% { transform: rotate(0); } 25% { transform: rotate(-9deg); } 75% { transform: rotate(9deg); } }
    @keyframes cheer { 0%,100% { transform: translateY(0) rotate(-4deg); } 50% { transform: translateY(-9px) rotate(4deg); } }
    @keyframes drift { 0%,100% { transform: translate(0,0); } 50% { transform: translate(-24px, 20px); } }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: .4; } }

    @media (max-width: 820px) {
      .gh-wrap { grid-template-columns: 1fr; text-align: center; }
      .gh-sub, .grow { margin-left: auto; margin-right: auto; }
      .gh-char { order: -1; }
      .arami { width: 150px; height: 150px; }
      .grow { grid-template-columns: auto 1fr; }
      .grow .sprout { grid-column: 1 / 3; justify-self: center; }
      .gchips { justify-content: center; }
    }
    @media (prefers-reduced-motion: reduce) {
      .arami, .ar-ring, .ar-eye, .ar-mouth, .ar-spark, .ar-shadow, .ar-hand, .ar-body, .wave,
      .critc, .crit-body, .crit-badge, .ct-face, .ct-eye, .ct-foot .dot, .sprout, .gh-orb { animation: none !important; }
    }
  </style>

  <script>
    // ── 성장 컴패니언: 활동 로그(엔진실 events)로 구동 ──
    (function () {
      function readEvents() { try { return JSON.parse(localStorage.getItem('aramirror.events.buffer.v1') || '[]'); } catch (_) { return []; } }
      function dayKey(iso) { const d = new Date(iso); return d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate(); }
      function streakOf(evs) { const days = new Set(evs.map((e) => dayKey(e.occurred_at))); let s = 0; const d = new Date(); for (;;) { const k = d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate(); if (days.has(k)) { s++; d.setDate(d.getDate() - 1); } else break; } return s; }
      const STAGES = [0, 3, 10, 25, 60, 120], NAMES = ['씨앗', '새싹', '잎', '봉오리', '꽃', '큰 나무'];
      const stageOf = (t) => { let s = 0; for (let i = 0; i < STAGES.length; i++) if (t >= STAGES[i]) s = i; return s; };
      const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = String(v); };
      function refresh() {
        const evs = readEvents(), total = evs.length;
        const today = evs.filter((e) => dayKey(e.occurred_at) === dayKey(new Date().toISOString())).length;
        const streak = streakOf(evs), stage = stageOf(total), level = Math.max(1, Math.floor(Math.sqrt(total)) + 1);
        set('statLevel', level); set('statStreak', streak); set('statToday', today); set('statTotal', total);
        set('stagePill', NAMES[stage]);
        const sp = document.getElementById('sprout'); if (sp) sp.setAttribute('data-stage', String(stage));
        const isMax = stage >= STAGES.length - 1, base = STAGES[stage], next = STAGES[Math.min(stage + 1, STAGES.length - 1)];
        const frac = isMax ? 1 : Math.min(1, (total - base) / (next - base));
        const fill = document.getElementById('xpFill'); if (fill) fill.style.width = Math.max(6, Math.round(frac * 100)) + '%';
        set('xpText', isMax ? '만개 완료 🌳' : (total + ' / ' + next + ' XP'));
        const ring = document.getElementById('ringFg'); if (ring) ring.style.strokeDashoffset = String(195 - 195 * frac);
        const say = document.getElementById('araSay');
        if (say && total > 0) say.textContent = '“연속 ' + streak + '일째 · ' + NAMES[stage] + ' 단계예요!”';
      }
      refresh(); setTimeout(refresh, 300);
    })();
  </script>
