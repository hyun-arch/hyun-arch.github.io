---
import Base from '../layouts/Base.astro';
import { logs } from '../data/logs.js';
import { domains } from '../data/mirror.js';
const latestLogs = logs.slice(0, 3);
function counts(d) {
  let live = 0, total = 0;
  d.branches.forEach((b) => b.items.forEach((it) => { total++; if (it.status === 'live') live++; }));
  return { live, total, branches: d.branches.length };
}
---
<Base title="Home">
  <header class="hero">
    <div class="wrap">
      <p class="kicker" data-reveal>Aramirror · 아람, 아름다운 사람</p>
      <h1 data-reveal="80">AI는 나를 대신하지 않는다 —<br /><mark>거울</mark>이 된다.</h1>
      <p class="sub" data-reveal="160">
        내 생각·자료·시간·사람·자산이 <strong>다섯 대륙의 하나의 지도</strong>가 된다.
        던지면 알아서 제자리에 쌓이고, 밤마다 엮이고, 쓸수록 자란다.
      </p>
      <div class="cta-row" data-reveal="240">
        <a class="btn accent" href="/mirror">🗺 거울 지도 탐험 →</a>
        <a class="btn-outline" href="/play">🎮 놀이터</a>
        <a class="btn-outline" href="/ask">되물음 받기</a>
        <a class="btn-outline" href="/hq/index.html">총괄실</a>
      </div>
    </div>
  </header>

  <!-- ── 다섯 대륙 미리보기 (지도로 들어가는 입구) ── -->
  <section>
    <div class="wrap">
      <p class="section-kicker" data-reveal>The Mirror</p>
      <h2 data-reveal="60">나를 비추는 다섯 대륙</h2>
      <p class="lead" data-reveal="120">큰 그림에서 시작해, 골목까지 파고들어요. 대륙을 눌러 안으로 들어가 보세요.</p>
      <div class="conts" data-reveal="160">
        {domains.map((d) => {
          const c = counts(d);
          return (
            <a class="cont-mini" href={`/mirror#${d.key}`} style={`--dc:${d.color}`}>
              <span class="cm-glow" aria-hidden="true"></span>
              <span class="cm-face" aria-hidden="true">
                <span class="cm-body"><span class="cm-eye l"></span><span class="cm-eye r"></span></span>
                <span class="cm-badge">{d.icon}</span>
              </span>
              <span class="cm-num">대륙 {d.key}</span>
              <span class="cm-title">{d.title}</span>
              <span class="cm-tag">{d.tagline}</span>
              <span class="cm-foot"><i class="dot live"></i>{c.live} 작동 · {c.total}곳<span class="cm-go">→</span></span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="dark-section">
    <div class="wrap">
      <p class="section-kicker" data-reveal>The Loop</p>
      <h2 data-reveal="60">생각 → 지식 → 자산</h2>
      <p class="lead" data-reveal="120">던지면 알아서 엮이고 서술된다. 세 층이 서로 다른 리듬으로 돈다.</p>
      <div class="num-grid">
        <div class="num-item" data-reveal="0"><span class="ni">01</span><h4>던진다</h4><p>떠오른 생각을 그대로 던진다. 정리·분류·태그는 없다. 입력 마찰 0.</p></div>
        <div class="num-item" data-reveal="80"><span class="ni">02</span><h4>엮인다</h4><p>쌓인 메모 사이의 연결을 매일 밤 자동으로 발견한다. 오늘 생각이 지난달·외부 개념과 이어진다.</p></div>
        <div class="num-item" data-reveal="160"><span class="ni">03</span><h4>자산이 된다</h4><p>성숙한 생각은 글·발표·아카이브가 된다. 생각의 과정 자체가 포트폴리오.</p></div>
        <div class="num-item" data-reveal="240"><span class="ni">04</span><h4>소유권은 나에게</h4><p>AI는 편집자일 뿐. 내 생각은 내 언어로, 내 자산으로 남는다.</p></div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <p class="section-kicker" data-reveal>Build Logs</p>
      <h2 data-reveal="60">이 시스템을 만들어가는 기록</h2>
      <p class="lead" data-reveal="120">Aramirror가 어떻게 태어나고 자라는지, 개발일지로 남긴다.</p>
      <ul class="logs" data-reveal="160">
        {latestLogs.map((l) => (
          <li><a href={l.href}><span class="id">{l.id}</span><span class="t">{l.title}</span><span class="d">{l.date}</span></a></li>
        ))}
      </ul>
      <p data-reveal="200" style="margin-top:22px"><a class="btn-outline" href="/build-logs">전체 기록 보기 →</a></p>
    </div>
  </section>

  <style is:global>
    .conts { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 14px; margin-top: 22px; }
    .cont-mini {
      position: relative; overflow: hidden; text-decoration: none; color: var(--fg);
      display: grid; grid-template-columns: auto 1fr; grid-template-rows: auto auto auto auto; gap: 2px 14px;
      padding: 18px; border-radius: 20px;
      background: linear-gradient(155deg, color-mix(in srgb, var(--dc) 13%, var(--bg-1)), var(--bg-1) 72%);
      border: 1px solid color-mix(in srgb, var(--dc) 28%, var(--line));
      transition: transform .2s var(--ease), border-color .2s, box-shadow .2s;
    }
    .cont-mini:hover { transform: translateY(-4px); border-color: var(--dc); box-shadow: 0 16px 38px rgba(0,0,0,.5); }
    .cm-glow { position: absolute; top: -30px; right: -30px; width: 120px; height: 120px; background: radial-gradient(circle, color-mix(in srgb, var(--dc) 45%, transparent), transparent 70%); opacity: .5; pointer-events: none; transition: opacity .2s; }
    .cont-mini:hover .cm-glow { opacity: .9; }
    .cm-face { position: relative; grid-row: 1 / 4; width: 48px; height: 44px; }
    .cm-body { position: absolute; inset: 0; border-radius: 50% 50% 46% 46%; background: linear-gradient(160deg, color-mix(in srgb, var(--dc) 90%, #fff 10%), color-mix(in srgb, var(--dc) 64%, #000 36%)); box-shadow: inset 0 -6px 9px rgba(0,0,0,.28), 0 6px 13px rgba(0,0,0,.4); animation: bob 3s var(--ease) infinite; }
    .cont-mini:hover .cm-body { animation-duration: 1.2s; }
    .cm-eye { position: absolute; top: 19px; width: 7px; height: 9px; background: #1a1620; border-radius: 50%; }
    .cm-eye::after { content: ""; position: absolute; top: 1px; left: 1.5px; width: 2.5px; height: 2.5px; background: #fff; border-radius: 50%; }
    .cm-eye.l { left: 13px; } .cm-eye.r { right: 13px; }
    .cm-num { grid-column: 2; font-family: var(--mono); font-size: .66rem; color: var(--dc); letter-spacing: .06em; text-transform: uppercase; }
    .cm-title { grid-column: 2; font-size: 1.12rem; font-weight: 800; letter-spacing: -.02em; line-height: 1.1; }
    .cm-tag { grid-column: 2; font-size: .78rem; color: var(--fg-soft); line-height: 1.4; }
    .cm-foot { grid-column: 1 / 3; display: flex; align-items: center; gap: 7px; margin-top: 12px; padding-top: 11px; border-top: 1px solid var(--line-soft); font-family: var(--mono); font-size: .72rem; color: var(--muted); font-variant-numeric: tabular-nums; }
    .cm-foot .dot { width: 7px; height: 7px; border-radius: 50%; background: #6fe08a; box-shadow: 0 0 6px #6fe08a; }
    .cm-go { margin-left: auto; color: var(--dc); font-weight: 700; }
    @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
    @media (prefers-reduced-motion: reduce) { .cm-body { animation: none !important; } .cont-mini { transition: none; } }
  </style>
</Base>
