---
import Base from '../layouts/Base.astro';
import { shell, stages, modes, manual, rotationRule, collector } from '../data/shell.js';
---
<Base title="셸 스튜디오">
  <section style="padding-top:80px">
    <div class="wrap">
      <p class="section-kicker">Shell Studio · 셸 선물 &amp; 수집 OS</p>
      <h2>셸을 <mark>쓰고 벌기</mark>, 한 화면에서</h2>
      <p class="lead">
        <b>{shell.team}</b>의 셸 봇 전체를 한 곳에. <b>선물봇(쓰는 쪽)</b>은 매일 사라지는 셸을
        한 사람에게 몰리지 않게 공정하게 돌려 선물하고, <b>수집봇(버는 쪽)</b>은 셸 벌 기회를
        놓치지 않게 감시·알림한다. 대상 계산·문구·감지는 자동, 마지막 한 번만 내가.
      </p>

      <div class="stage-nav">
        {stages.map((s) => (<a href={`#${s.id}`}><span class="sn">{s.n}</span>{s.t}</a>))}
      </div>

      <!-- 01 오늘 대상 -->
      <div class="block" id="today">
        <h3 class="blk-h"><span class="blk-n">01</span> 오늘 대상</h3>
        <p class="blk-d">아래는 접속한 날짜로 자동 계산한 <b>미리보기</b>입니다.</p>
        <p class="rule-note">📌 {rotationRule}</p>
        <div class="today-card">
          <div class="today-em">🐚</div>
          <div>
            <div class="today-label">오늘은</div>
            <div class="today-name" id="todayName">—</div>
            <div class="today-comment" id="todayComment">—</div>
          </div>
        </div>
        <p class="mini-h">다음 차례</p>
        <div class="upcoming" id="upcoming"></div>
      </div>

      <!-- 02 순환 명단 -->
      <div class="block" id="roster">
        <h3 class="blk-h"><span class="blk-n">02</span> 순환 명단 — {shell.roster.length}명</h3>
        <p class="blk-d">나(<b>{shell.owner}</b>)를 뺀 조원. 매일 한 명씩 순서대로, {shell.roster.length}일이면 모두 한 번씩 돌고 다시 처음.</p>
        <div class="roster">
          {shell.roster.map((m, i) => (
            <div class="rchip" data-name={m}><span class="ri">{String(i + 1).padStart(2, '0')}</span>{m}</div>
          ))}
        </div>
        <p class="fav-note">⭐ favorites 모드: <b>{shell.favorites.join(' · ')}</b> 안에서만 순환하게 바꿀 수도 있어요.</p>
      </div>

      <!-- 03 전송 문구 -->
      <div class="block" id="message">
        <h3 class="blk-h"><span class="blk-n">03</span> 전송 문구 — 복사해서 한 번만 보내기</h3>
        <p class="blk-d">봇이 오늘 대상 + 코멘트로 문구를 만들어 줍니다. <b>{shell.slash}</b>는 Slack 슬래시 명령이라 API가 대신 못 눌러요 — 마지막 전송만 사람 몫.</p>
        <div class="msg-row">
          <pre class="msg-body" id="msgBody">—</pre>
          <button class="btn accent" id="copyMsg">복사</button>
        </div>
        <p class="msg-hint">채널 입력창에서 <code>@이름</code>은 멘션으로 골라주세요. <span id="copied" class="copied"></span></p>
      </div>

      <!-- 04 두 가지 방식 -->
      <div class="block" id="modes">
        <h3 class="blk-h"><span class="blk-n">04</span> 두 가지 방식 — 웹(클라우드) · PC 앱</h3>
        <p class="blk-d">셸 분기를 <b>두 가지로 다 만들어 실제로 돌려봤습니다.</b> 웹(클라우드)과 내 PC에서 도는 앱, 둘 다 한 레포에 들어있어요. 원하는 걸 쓰면 됩니다.</p>
        <div class="modes">
          {modes.map((m) => (
            <div class="mode">
              <div class="mode-top">
                <span class="mode-k">방식 {m.key}</span><h4>{m.name}</h4>
                <span class="mode-tag">{m.tag}</span>
              </div>
              <p class="mode-how">{m.how}</p>
              <ul class="mode-kv">
                <li><span>자동화</span><b>{m.auto}</b></li>
                <li><span>실행 위치</span><b>{m.where}</b></li>
                <li><span>필요한 것</span><b>{m.need}</b></li>
                <li><span>안정성</span><b>{m.stable}</b></li>
                <li><span>파일</span><b><code>{m.files}</code></b></li>
              </ul>
            </div>
          ))}
        </div>
      </div>

      <!-- 05 사용 매뉴얼 -->
      <div class="block" id="manual">
        <h3 class="blk-h"><span class="blk-n">05</span> 사용 매뉴얼 — 1~6조 누구나 쓰게</h3>
        <p class="blk-d">봇 실제 코드는 <code>Project/자동 셸 선물 봇</code>. 조·명단만 바꾸면 다른 조도 그대로 씁니다.</p>

        <div class="man-common">
          <p class="man-h">공통 준비 (먼저 이것부터)</p>
          <ol class="man-steps">
            {manual.common.map((s) => (<li>{s}</li>))}
          </ol>
        </div>

        <div class="man-tracks">
          {manual.tracks.map((t) => (
            <div class="man-track">
              <p class="man-track-h"><span class="man-k">방식 {t.key}</span>{t.title}</p>
              <ol class="man-steps">
                {t.steps.map((s) => (<li>{s}</li>))}
              </ol>
            </div>
          ))}
        </div>

        <p class="setup-link"><a href="/m/shell-gift-bot">→ 지도에서 이 봇 상세 보기</a></p>
      </div>

      <!-- 06 수집봇 (셸 버는 쪽) -->
      <div class="block" id="collect">
        <h3 class="blk-h"><span class="blk-n">06</span> 수집봇 — 셸 버는 쪽</h3>
        <p class="blk-d">{collector.intro}</p>
        <p class="rule-note">{collector.tips}</p>

        <div class="col-tools">
          {collector.tools.map((t) => (
            <div class="col-tool">
              <div class="col-top">
                <span class="col-k">{t.key}</span>
                <h4>{t.name}</h4>
                <code class="col-file">{t.file}</code>
              </div>
              <p class="col-how">{t.how}</p>

              {t.detect && (
                <p class="col-detect">
                  <span class="col-lbl">감지</span>
                  {t.detect.map((d) => (<span class="col-badge">{d}</span>))}
                </p>
              )}
              {t.noise && <p class="col-noise">{t.noise}</p>}

              <div class="col-cmds">
                {t.cmds.map((cm) => (
                  <div class="col-cmd">
                    <code>{cm.c}</code><span>{cm.d}</span>
                  </div>
                ))}
              </div>

              {t.sched && <p class="col-sched">⏱ 자동 실행 · {t.sched}</p>}
              {t.guard && <p class="col-guard">{t.guard}</p>}
            </div>
          ))}
        </div>

        <p class="setup-link"><a href="/m/shell-gift-bot">→ 지도에서 이 봇 상세 보기</a></p>
      </div>
    </div>
  </section>

  <script id="shell-data" type="application/json" set:html={JSON.stringify({
    roster: shell.roster, comments: shell.comments, anchor: shell.anchor, slash: shell.slash,
  })} />

  <script>
    const data = JSON.parse(document.getElementById('shell-data').textContent);
    const $ = (id) => document.getElementById(id);

    // 로컬(KST) 자정 기준 날짜차 — 기준일부터 며칠 지났나
    function daysSince(anchorStr) {
      const [ay, am, ad] = anchorStr.split('-').map(Number);
      const now = new Date();
      const a = Date.UTC(ay, am - 1, ad);
      const t = Date.UTC(now.getFullYear(), now.getMonth(), now.getDate());
      return Math.floor((t - a) / 86400000);
    }
    const N = data.roster.length;
    const mod = (n, m) => ((n % m) + m) % m; // 음수(기준일 이전)도 안전하게
    const d = daysSince(data.anchor);

    const target = data.roster[mod(d, N)];
    const comment = data.comments[mod(d, data.comments.length)];

    $('todayName').textContent = target + ' 님 차례';
    $('todayComment').textContent = comment;

    // 전송 문구
    const msg = `${data.slash} @${target} ${comment}`;
    $('msgBody').textContent = msg;

    // 다음 5일 미리보기
    const days = ['일', '월', '화', '수', '목', '금', '토'];
    const up = [];
    for (let i = 1; i <= 5; i++) {
      const nm = data.roster[mod(d + i, N)];
      const dt = new Date(); dt.setDate(dt.getDate() + i);
      up.push(`<div class="up"><span class="up-d">+${i} (${days[dt.getDay()]})</span>${nm}</div>`);
    }
    $('upcoming').innerHTML = up.join('');

    // 오늘 대상 명단 칩 하이라이트
    document.querySelectorAll('.rchip').forEach((c) => {
      if (c.dataset.name === target) c.classList.add('on');
    });

    // 복사
    $('copyMsg').addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(msg);
        $('copied').textContent = '복사됐어요 ✓';
        setTimeout(() => { $('copied').textContent = ''; }, 2000);
      } catch {
        const r = document.createRange(); r.selectNode($('msgBody'));
        getSelection().removeAllRanges(); getSelection().addRange(r);
      }
    });
  </script>

  <style>
    .stage-nav { display: flex; flex-wrap: wrap; gap: 8px; margin: 22px 0 30px; }
    .stage-nav a { display: inline-flex; align-items: center; gap: 7px; font-size: 0.85rem;
      border: 1px solid var(--line); border-radius: 999px; padding: 7px 14px; color: var(--fg); text-decoration: none; }
    .stage-nav a:hover { border-color: var(--fg); }
    .stage-nav .sn { font-family: var(--mono); color: var(--muted); font-size: 0.78rem; }
    .block { border-top: 1px solid var(--line); padding: 30px 0; }
    .blk-h { font-size: 1.25rem; font-weight: 700; letter-spacing: -0.02em; margin: 0 0 6px; }
    .blk-n { font-family: var(--mono); color: var(--muted); margin-right: 8px; font-size: 0.9rem; }
    .blk-d { color: var(--fg-soft); margin: 0 0 20px; line-height: 1.6; }

    .today-card { display: flex; align-items: center; gap: 22px; border: 1px solid var(--line);
      border-radius: var(--radius); padding: 28px; background: var(--bg-soft); }
    .today-em { font-size: 3rem; line-height: 1; }
    .today-label { color: var(--muted); font-size: 0.85rem; }
    .today-name { font-size: 1.9rem; font-weight: 800; letter-spacing: -0.02em; margin: 2px 0 6px; }
    .today-comment { color: var(--fg-soft); }
    .mini-h { font-size: 0.8rem; color: var(--muted); margin: 22px 0 10px; font-weight: 600; }
    .upcoming { display: flex; flex-wrap: wrap; gap: 10px; }
    .up { border: 1px solid var(--line); border-radius: 12px; padding: 10px 14px; font-size: 0.9rem; }
    .up-d { display: block; font-family: var(--mono); font-size: 0.72rem; color: var(--muted); }

    .roster { display: flex; flex-wrap: wrap; gap: 8px; }
    .rchip { display: inline-flex; align-items: center; gap: 8px; border: 1px solid var(--line);
      border-radius: 999px; padding: 8px 15px; font-size: 0.92rem; }
    .rchip .ri { font-family: var(--mono); color: var(--muted); font-size: 0.75rem; }
    .rchip.on { background: var(--fg); color: var(--bg); border-color: var(--fg); font-weight: 700; }
    .fav-note { margin-top: 16px; color: var(--fg-soft); font-size: 0.9rem; }

    .msg-row { display: flex; gap: 12px; align-items: stretch; flex-wrap: wrap; }
    .msg-body { flex: 1; min-width: 260px; margin: 0; padding: 18px; border: 1px solid var(--line);
      border-radius: 12px; background: var(--bg-soft); font-family: var(--mono); font-size: 0.95rem;
      white-space: pre-wrap; word-break: break-all; }
    .msg-hint { color: var(--muted); font-size: 0.85rem; margin-top: 10px; }
    .msg-hint code { background: var(--bg-soft); padding: 2px 6px; border-radius: 6px; }
    .copied { color: var(--fg); font-weight: 600; margin-left: 6px; }

    .modes { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .mode { border: 1px solid var(--line); border-radius: var(--radius); padding: 22px; }
    .mode-top { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
    .mode-k { font-family: var(--mono); font-size: 0.72rem; color: var(--bg); background: var(--fg);
      padding: 3px 9px; border-radius: 999px; }
    .mode-top h4 { margin: 0; font-size: 1.05rem; }
    .mode-kv { list-style: none; padding: 0; margin: 0; }
    .mode-kv li { display: flex; justify-content: space-between; gap: 14px; padding: 9px 0;
      border-bottom: 1px solid var(--line-soft); font-size: 0.9rem; }
    .mode-kv li span { color: var(--muted); white-space: nowrap; }
    .mode-kv li b { text-align: right; }

    .rule-note { color: var(--muted); font-size: 0.85rem; margin: -8px 0 18px; line-height: 1.6;
      border-left: 2px solid var(--line); padding-left: 12px; }
    .mode-tag { margin-left: auto; font-size: 0.7rem; color: var(--muted); border: 1px solid var(--line);
      border-radius: 999px; padding: 2px 9px; }
    .mode-how { color: var(--fg-soft); font-size: 0.9rem; line-height: 1.55; margin: 0 0 14px; }
    .mode-kv li code { font-family: var(--mono); font-size: 0.82em; }

    .man-common { border: 1px solid var(--line); border-radius: var(--radius); padding: 20px 24px; margin-bottom: 18px; }
    .man-h { font-weight: 700; margin: 0 0 10px; }
    .man-tracks { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .man-track { border: 1px solid var(--line); border-radius: var(--radius); padding: 20px 24px; }
    .man-track-h { font-weight: 700; margin: 0 0 10px; display: flex; align-items: center; gap: 9px; }
    .man-k { font-family: var(--mono); font-size: 0.72rem; color: var(--bg); background: var(--fg);
      padding: 3px 9px; border-radius: 999px; }
    .man-steps { margin: 0; padding-left: 20px; line-height: 1.75; color: var(--fg-soft); }
    .man-steps li { margin-bottom: 4px; }

    .setup-link { margin-top: 18px; }
    .setup-link a { color: var(--fg); text-decoration: underline; }

    /* 06 수집봇 */
    .col-tools { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .col-tool { border: 1px solid var(--line); border-radius: var(--radius); padding: 22px; }
    .col-top { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; flex-wrap: wrap; }
    .col-k { font-family: var(--mono); font-size: 0.9rem; color: var(--bg); background: var(--fg);
      width: 24px; height: 24px; display: inline-flex; align-items: center; justify-content: center; border-radius: 999px; }
    .col-top h4 { margin: 0; font-size: 1.05rem; }
    .col-file { margin-left: auto; font-family: var(--mono); font-size: 0.76rem; color: var(--muted);
      border: 1px solid var(--line); border-radius: 999px; padding: 2px 9px; }
    .col-how { color: var(--fg-soft); font-size: 0.92rem; line-height: 1.6; margin: 0 0 14px; }
    .col-detect { display: flex; flex-wrap: wrap; align-items: center; gap: 6px; margin: 0 0 8px; }
    .col-lbl { font-size: 0.78rem; color: var(--muted); margin-right: 4px; }
    .col-badge { font-size: 0.78rem; border: 1px solid var(--line); border-radius: 999px; padding: 3px 10px;
      background: var(--bg-soft); }
    .col-noise { font-size: 0.82rem; color: var(--muted); margin: 0 0 14px; }
    .col-cmds { display: flex; flex-direction: column; gap: 8px; margin: 4px 0 0; }
    .col-cmd { display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
    .col-cmd code { font-family: var(--mono); font-size: 0.82rem; background: var(--bg-soft);
      border: 1px solid var(--line-soft); border-radius: 8px; padding: 6px 10px; word-break: break-all; }
    .col-cmd span { font-size: 0.82rem; color: var(--muted); }
    .col-sched { font-size: 0.84rem; color: var(--fg-soft); margin: 14px 0 0; }
    .col-guard { font-size: 0.82rem; color: var(--muted); line-height: 1.55; margin: 12px 0 0;
      border-left: 2px solid var(--line); padding-left: 12px; }

    @media (max-width: 640px) {
      .modes { grid-template-columns: 1fr; }
      .man-tracks { grid-template-columns: 1fr; }
      .col-tools { grid-template-columns: 1fr; }
      .today-card { flex-direction: column; text-align: center; }
    }
  </style>
</Base>
