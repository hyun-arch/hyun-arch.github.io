---
import Base from '../layouts/Base.astro';
import { domains, statusMeta } from '../data/mirror.js';

const hrefOf = (it) => it.to || ('/m/' + it.slug);
function counts(d) {
  let live = 0, building = 0, total = 0;
  d.branches.forEach((b) => b.items.forEach((it) => {
    total++;
    if (it.status === 'live') live++;
    else if (it.status === 'building') building++;
  }));
  return { live, building, total, branches: d.branches.length };
}
---
<Base title="거울 지도">
  <div class="hub">
    <span class="aurora a1" aria-hidden="true"></span>
    <span class="aurora a2" aria-hidden="true"></span>

    <!-- ── 컴패니언: 캐릭터 + 성장(게이미피케이션을 지도에 통합) ── -->
    <header class="companion" id="companion">
      <div class="comp-hi">
        <div class="arami" aria-hidden="true">
          <span class="ar-shadow"></span>
          <span class="ar-ring"></span>
          <span class="ar-body">
            <span class="ar-shine"></span>
            <span class="ar-eye l"></span><span class="ar-eye r"></span>
            <span class="ar-cheek l"></span><span class="ar-cheek r"></span>
            <span class="ar-mouth"></span>
          </span>
          <span class="ar-hand">👋</span>
          <span class="ar-spark s1">✦</span><span class="ar-spark s2">✧</span><span class="ar-spark s3">✦</span>
        </div>
        <div class="comp-say">
          <span class="bubble" id="araSay">오늘도 왔네요! 어디부터 들어가 볼까요?</span>
          <h1>거울 지도</h1>
          <p>나를 비추는 다섯 대륙 — 큰 그림에서 골목까지, 눌러서 안으로 들어가요.</p>
        </div>
      </div>

      <div class="growth">
        <div class="stat-ring" title="레벨">
          <svg viewBox="0 0 72 72" aria-hidden="true"><circle class="ring-bg" cx="36" cy="36" r="31"/><circle class="ring-fg" id="ringFg" cx="36" cy="36" r="31"/></svg>
          <span class="ring-n"><b id="statLevel">1</b><small>Lv</small></span>
        </div>
        <div class="growth-mid">
          <div class="chips3">
            <span class="gchip"><b id="statStreak">0</b><i>🔥 연속</i></span>
            <span class="gchip"><b id="statToday">0</b><i>오늘</i></span>
            <span class="gchip"><b id="statTotal">0</b><i>누적</i></span>
          </div>
          <div class="xp"><i id="xpFill"></i></div>
          <p class="xp-line"><span id="stagePill">씨앗</span> · <span id="xpText">0 / 3 XP</span></p>
        </div>
        <div class="sprout" id="sprout" data-stage="0" title="활동할수록 자라요">
          <svg viewBox="0 0 90 90" aria-hidden="true">
            <ellipse cx="45" cy="80" rx="26" ry="6" fill="rgba(0,0,0,.35)"/>
            <path d="M30 66 h30 l-4 14 a5 5 0 0 1-5 4 H39 a5 5 0 0 1-5-4 Z" fill="#8a5334"/>
            <rect x="26" y="60" width="38" height="8" rx="3" fill="#a06a44"/>
            <g class="seed"><ellipse cx="45" cy="60" rx="4" ry="5" fill="#c9905a"/></g>
            <g class="gg g1"><path d="M45 62 C45 52 45 46 45 40" stroke="#7fd67a" stroke-width="4" fill="none" stroke-linecap="round"/><path d="M45 50 C36 46 30 50 29 57 C38 58 43 55 45 50 Z" fill="#8ce08a"/><path d="M45 44 C54 40 60 44 61 51 C52 52 47 49 45 44 Z" fill="#7fd67a"/></g>
            <g class="gg g2"><path d="M45 40 C34 35 27 40 26 48 C38 49 43 45 45 40 Z" fill="#9be89a"/><path d="M45 34 C56 29 63 34 64 42 C52 43 47 39 45 34 Z" fill="#72ca6d"/></g>
            <g class="gg g3"><circle cx="45" cy="30" r="6" fill="#ffd27a"/><circle cx="30" cy="46" r="4.5" fill="#ffcf6e"/><circle cx="60" cy="44" r="4.5" fill="#ffcf6e"/></g>
            <g class="gg g4"><g transform="translate(45 28)"><circle r="7" fill="#ff7a4d"/><circle r="3" fill="#ffe08a"/></g><g transform="translate(30 44)"><circle r="5" fill="#ff9f6a"/><circle r="2" fill="#ffe08a"/></g><g transform="translate(60 42)"><circle r="5" fill="#ff9f6a"/><circle r="2" fill="#ffe08a"/></g></g>
            <g class="gg g5"><circle cx="45" cy="24" r="17" fill="#69c164"/><circle cx="30" cy="34" r="12" fill="#7fd67a"/><circle cx="60" cy="34" r="12" fill="#7fd67a"/><circle cx="45" cy="18" r="5" fill="#ff7a4d"/></g>
          </svg>
        </div>
      </div>
    </header>

    <!-- ── 뷰: 대륙 개요 ↔ 대륙 상세 ── -->
    <div class="view" id="view" data-level="overview">
      <p class="section-lead" id="mapLead">어디로 들어가 볼까요?</p>
      <div class="continents" id="continents">
        {domains.map((d, i) => {
          const c = counts(d);
          return (
            <button class="cont" type="button" data-key={d.key} style={`--dc:${d.color}; --i:${i}`} aria-label={`${d.title} 대륙 열기`}>
              <span class="cont-glow" aria-hidden="true"></span>
              <span class="cont-sheen" aria-hidden="true"></span>
              <span class="cont-face" aria-hidden="true">
                <span class="cf-body"><span class="cf-eye l"></span><span class="cf-eye r"></span><span class="cf-cheek l"></span><span class="cf-cheek r"></span></span>
                <span class="cf-badge">{d.icon}</span>
              </span>
              <span class="cont-num">대륙 {d.key}</span>
              <span class="cont-title">{d.title}</span>
              <span class="cont-en">{d.en} · {d.tagline}</span>
              <span class="cont-meta">
                <span class="cm"><i class="dot live"></i>{c.live} 작동</span>
                <span class="cm"><i class="dot building"></i>{c.building} 제작</span>
                <span class="cm">{c.branches}지역 · {c.total}곳</span>
              </span>
              <span class="cont-enter">들어가기 →</span>
            </button>
          );
        })}
      </div>

      {domains.map((d) => (
          <section class="detail" id={`d-${d.key}`} data-key={d.key} style={`--dc:${d.color}`} hidden>
            <div class="detail-bar">
              <button class="back" type="button" data-back>← 전체 지도</button>
              <div class="crumb"><span>거울 지도</span> <b>/</b> <span class="cr-here">{d.icon} {d.title}</span></div>
              <div class="dfilter" role="group" aria-label="상태 필터">
                <button class="fchip on" data-status="all" type="button">전체</button>
                <button class="fchip" data-status="live" type="button"><i class="dot live"></i>작동</button>
                <button class="fchip" data-status="building" type="button"><i class="dot building"></i>제작</button>
                <button class="fchip" data-status="idea" type="button"><i class="dot idea"></i>아이디어</button>
              </div>
            </div>
            <div class="detail-head">
              <span class="dh-face" aria-hidden="true">
                <span class="cf-body"><span class="cf-eye l"></span><span class="cf-eye r"></span><span class="cf-cheek l"></span><span class="cf-cheek r"></span></span>
                <span class="cf-badge">{d.icon}</span>
              </span>
              <div><h2>{d.title} <span class="dh-en">{d.en}</span></h2><p>{d.tagline}</p></div>
            </div>
            <div class="regions">
              {d.branches.map((b) => (
                <div class="region">
                  <h3>{b.h}</h3>
                  <ul>
                    {b.items.map((it) => {
                      const m = statusMeta(it.status);
                      return (
                        <li class="place" data-status={it.status}>
                          <a class="place-a" href={hrefOf(it)}>
                            <span class={`dot ${m.cls}`} title={m.label}></span>
                            <span class="place-t">{it.t}</span>
                            {it.from && <span class="from">{it.from}</span>}
                            {it.to && <span class="ext" title="바로 기능 페이지">↗</span>}
                            <span class="go">→</span>
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              ))}
            </div>
            <p class="no-hit" hidden>이 상태에 해당하는 장소가 없어요.</p>
          </section>
      ))}
    </div>

    <div class="legend">
      <span><i class="dot live"></i>작동 중</span>
      <span><i class="dot building"></i>만드는 중</span>
      <span><i class="dot seed"></i>내용 있음</span>
      <span><i class="dot idea"></i>아이디어</span>
      <span class="legend-note">· 던진 건 알아서 제자리에 쌓이고, 밤마다 다시 엮여요.</span>
    </div>
  </div>

  <style is:global>
    .hub { position: relative; max-width: 1140px; margin: 0 auto; padding: 92px 18px 64px; overflow: clip; }
    .aurora { position: absolute; border-radius: 50%; filter: blur(70px); opacity: .5; pointer-events: none; z-index: 0; }
    .aurora.a1 { width: 520px; height: 380px; top: -60px; left: -80px; background: radial-gradient(circle, rgba(255,122,77,.24), transparent 65%); }
    .aurora.a2 { width: 460px; height: 360px; top: 120px; right: -100px; background: radial-gradient(circle, rgba(167,139,250,.18), transparent 65%); }
    .hub > * { position: relative; z-index: 1; }

    /* ── 컴패니언 ── */
    .companion { display: grid; grid-template-columns: 1fr auto; gap: 20px 26px; align-items: center; margin-bottom: 30px;
      padding: 22px 24px; border-radius: 26px; border: 1px solid var(--line);
      background: linear-gradient(150deg, color-mix(in srgb, var(--accent) 8%, var(--bg-1)), var(--bg-1) 72%);
      box-shadow: 0 24px 60px rgba(0,0,0,.4); }
    @media (max-width: 780px) { .companion { grid-template-columns: 1fr; } }
    .comp-hi { display: flex; align-items: center; gap: 20px; }
    /* 움직이는 아라미 (홈과 동일) */
    .arami { position: relative; width: 118px; height: 118px; flex-shrink: 0; animation: float 4s var(--ease) infinite; }
    .ar-shadow { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 70px; height: 13px; border-radius: 50%; background: radial-gradient(ellipse, rgba(0,0,0,.45), transparent 72%); animation: shadowpulse 4s var(--ease) infinite; }
    .ar-ring { position: absolute; inset: 4px; border-radius: 50%; border: 2px dashed color-mix(in srgb, var(--accent) 45%, transparent); animation: spin 22s linear infinite; }
    .ar-body { position: absolute; inset: 14px; border-radius: 50% 50% 48% 48%; background: linear-gradient(160deg, #fff 0%, #ffe6d3 44%, #ffb9a0 100%); box-shadow: inset 0 -10px 18px rgba(255,120,90,.35), inset 0 8px 14px #fff, 0 14px 28px rgba(242,98,47,.32); animation: squish 3.2s var(--ease) infinite; }
    .ar-shine { position: absolute; top: 16%; left: 20%; width: 34%; height: 24%; border-radius: 50%; background: radial-gradient(circle at 40% 40%, rgba(255,255,255,.95), transparent 68%); }
    .ar-eye { position: absolute; top: 44%; width: 11px; height: 15px; background: #3a2418; border-radius: 50%; animation: blink 4s infinite; }
    .ar-eye::after { content: ""; position: absolute; top: 2px; left: 2px; width: 4px; height: 4px; background: #fff; border-radius: 50%; }
    .ar-eye.l { left: 34%; } .ar-eye.r { right: 34%; }
    .ar-cheek { position: absolute; top: 56%; width: 12px; height: 8px; border-radius: 50%; background: #ff9a8b; opacity: .6; filter: blur(1px); }
    .ar-cheek.l { left: 27%; } .ar-cheek.r { right: 27%; }
    .ar-mouth { position: absolute; top: 61%; left: 50%; transform: translateX(-50%); width: 20px; height: 10px; border: 3px solid #3a2418; border-top: 0; border-radius: 0 0 20px 20px; animation: talk 4s var(--ease) infinite; }
    .ar-hand { position: absolute; right: 0%; top: 38%; font-size: 24px; transform-origin: 60% 90%; animation: wave 2s var(--ease) infinite; }
    .ar-spark { position: absolute; font-size: 15px; color: var(--a2); animation: twinkle 2.4s ease-in-out infinite; }
    .ar-spark.s1 { top: 6%; right: 2%; } .ar-spark.s2 { bottom: 16%; left: -2%; color: var(--a3); animation-delay: .7s; font-size: 13px; } .ar-spark.s3 { top: 28%; left: -6%; color: var(--a1); animation-delay: 1.3s; font-size: 11px; }
    .comp-say .bubble { display: inline-block; font-size: .82rem; color: var(--fg); background: var(--bg-2); border: 1px solid var(--line); padding: 5px 13px; border-radius: 13px 13px 13px 3px; margin-bottom: 8px; }
    .comp-say h1 { font-size: clamp(1.7rem, 3.4vw, 2.3rem); margin: 0; letter-spacing: -.03em; }
    .comp-say p { margin: 5px 0 0; color: var(--fg-soft); font-size: .9rem; line-height: 1.5; }

    /* 성장 */
    .growth { display: flex; align-items: center; gap: 16px; }
    @media (max-width: 780px) { .growth { justify-content: space-between; flex-wrap: wrap; } }
    .stat-ring { position: relative; width: 72px; height: 72px; flex-shrink: 0; }
    .stat-ring svg { width: 72px; height: 72px; transform: rotate(-90deg); }
    .ring-bg { fill: none; stroke: var(--bg-2); stroke-width: 6; }
    .ring-fg { fill: none; stroke: url(#g); stroke: var(--accent); stroke-width: 6; stroke-linecap: round; stroke-dasharray: 195; stroke-dashoffset: 100; transition: stroke-dashoffset .9s var(--ease); filter: drop-shadow(0 0 5px var(--accent-glow)); }
    .ring-n { position: absolute; inset: 0; display: grid; place-content: center; text-align: center; }
    .ring-n b { font-family: var(--mono); font-size: 1.35rem; font-weight: 700; line-height: 1; }
    .ring-n small { display: block; font-size: .6rem; color: var(--muted); margin-top: 1px; }
    .growth-mid { min-width: 148px; }
    .chips3 { display: flex; gap: 8px; }
    .gchip { flex: 1; text-align: center; background: var(--bg-2); border: 1px solid var(--line); border-radius: 12px; padding: 7px 4px; }
    .gchip b { display: block; font-family: var(--mono); font-size: 1.05rem; line-height: 1; font-variant-numeric: tabular-nums; }
    .gchip i { display: block; font-style: normal; font-size: .64rem; color: var(--muted); margin-top: 3px; }
    .xp { height: 8px; border-radius: 999px; background: var(--bg-2); border: 1px solid var(--line); overflow: hidden; margin-top: 9px; }
    .xp i { display: block; height: 100%; width: 6%; border-radius: 999px; background: var(--grad); transition: width .9s var(--ease); }
    .xp-line { margin: 6px 0 0; font-family: var(--mono); font-size: .7rem; color: var(--muted); }
    #stagePill { color: var(--a2); }
    .sprout { width: 74px; height: 74px; flex-shrink: 0; }
    .sprout .gg { opacity: 0; transform: translateY(4px) scale(.5); transform-origin: 45px 62px; transition: opacity .6s var(--ease), transform .6s var(--ease); }
    .sprout[data-stage="0"] .seed { opacity: 1; } .sprout:not([data-stage="0"]) .seed { opacity: 0; transition: opacity .4s; }
    .sprout[data-stage="1"] .g1, .sprout[data-stage="2"] .g1, .sprout[data-stage="2"] .g2,
    .sprout[data-stage="3"] .g1, .sprout[data-stage="3"] .g2, .sprout[data-stage="3"] .g3,
    .sprout[data-stage="4"] .g1, .sprout[data-stage="4"] .g2, .sprout[data-stage="4"] .g3, .sprout[data-stage="4"] .g4,
    .sprout[data-stage="5"] .g1, .sprout[data-stage="5"] .g2, .sprout[data-stage="5"] .g3, .sprout[data-stage="5"] .g4, .sprout[data-stage="5"] .g5 { opacity: 1; transform: none; }

    /* ── 섹션 리드 ── */
    .section-lead { font-size: 1.05rem; font-weight: 600; color: var(--fg-soft); margin: 0 2px 16px; }

    /* ── 대륙 카드 ── */
    .continents { display: grid; grid-template-columns: repeat(auto-fill, minmax(324px, 1fr)); gap: 16px; }
    .cont {
      position: relative; text-align: left; cursor: pointer; overflow: hidden; isolation: isolate;
      display: grid; grid-template-columns: auto 1fr; grid-template-rows: auto auto auto auto; gap: 3px 16px;
      padding: 24px; border-radius: 24px; color: var(--fg);
      background: linear-gradient(155deg, color-mix(in srgb, var(--dc) 16%, var(--bg-1)), var(--bg-1) 74%);
      border: 1px solid color-mix(in srgb, var(--dc) 32%, var(--line));
      box-shadow: 0 10px 30px rgba(0,0,0,.35);
      transition: transform .24s var(--ease), box-shadow .24s var(--ease), border-color .24s;
      animation: rise .5s var(--ease) both; animation-delay: calc(var(--i) * .06s);
    }
    .cont:hover, .cont:focus-visible { transform: translateY(-6px); border-color: var(--dc); box-shadow: 0 26px 56px rgba(0,0,0,.5), 0 0 0 1px color-mix(in srgb, var(--dc) 40%, transparent); outline: none; }
    .cont:focus-visible { box-shadow: 0 0 0 2px var(--dc), 0 26px 56px rgba(0,0,0,.5); }
    .cont-glow { position: absolute; top: -50px; right: -50px; width: 180px; height: 180px; background: radial-gradient(circle, color-mix(in srgb, var(--dc) 50%, transparent), transparent 68%); opacity: .55; pointer-events: none; z-index: -1; transition: opacity .24s, transform .24s; }
    .cont:hover .cont-glow { opacity: .95; transform: scale(1.12); }
    .cont-sheen { position: absolute; inset: 0; background: linear-gradient(120deg, transparent 40%, rgba(255,255,255,.06) 50%, transparent 60%); transform: translateX(-120%); transition: transform .6s var(--ease); pointer-events: none; z-index: -1; }
    .cont:hover .cont-sheen { transform: translateX(120%); }
    .cont-face, .dh-face { position: relative; width: 62px; height: 58px; grid-row: 1 / 4; }
    .dh-face { grid-row: auto; flex: 0 0 auto; }
    .cf-body { position: absolute; inset: 0; border-radius: 50% 50% 46% 46%; background: linear-gradient(160deg, color-mix(in srgb, var(--dc) 92%, #fff 8%), color-mix(in srgb, var(--dc) 62%, #000 38%)); box-shadow: inset 0 -8px 12px rgba(0,0,0,.28), 0 8px 18px rgba(0,0,0,.42); animation: bob 3s var(--ease) infinite; }
    .cont:hover .cf-body { animation-duration: 1.1s; }
    .cf-eye { position: absolute; top: 25px; width: 8px; height: 11px; background: #1a1620; border-radius: 50%; animation: blink 5s infinite; }
    .cf-eye::after { content: ""; position: absolute; top: 1px; left: 1.5px; width: 3px; height: 3px; background: #fff; border-radius: 50%; }
    .cf-eye.l { left: 18px; } .cf-eye.r { right: 18px; }
    .cf-cheek { position: absolute; top: 34px; width: 7px; height: 4px; background: rgba(255,120,120,.5); border-radius: 50%; }
    .cf-cheek.l { left: 12px; } .cf-cheek.r { right: 12px; }
    .cf-badge { position: absolute; top: -6px; right: -8px; width: 27px; height: 27px; font-size: 1.02rem; background: var(--bg); border: 1px solid var(--line); border-radius: 50%; display: grid; place-items: center; box-shadow: 0 3px 9px rgba(0,0,0,.5); }
    .cont-num { grid-column: 2; font-family: var(--mono); font-size: .7rem; color: var(--dc); letter-spacing: .07em; text-transform: uppercase; }
    .cont-title { grid-column: 2; font-size: 1.45rem; font-weight: 800; letter-spacing: -.02em; line-height: 1.08; }
    .cont-en { grid-column: 2; font-size: .82rem; color: var(--fg-soft); }
    .cont-meta { grid-column: 1 / 3; display: flex; flex-wrap: wrap; gap: 6px 14px; margin-top: 14px; padding-top: 13px; border-top: 1px solid var(--line-soft); }
    .cm { display: inline-flex; align-items: center; gap: 6px; font-family: var(--mono); font-size: .72rem; color: var(--muted); font-variant-numeric: tabular-nums; }
    .cont-enter { position: absolute; right: 22px; bottom: 22px; font-size: .84rem; font-weight: 700; color: var(--dc); opacity: 0; transform: translateX(-6px); transition: opacity .22s, transform .22s; }
    .cont:hover .cont-enter, .cont:focus-visible .cont-enter { opacity: 1; transform: none; }

    /* ── 뷰 전환 ── */
    .view[data-level="overview"] .detail { display: none; }
    .view[data-level="detail"] .continents, .view[data-level="detail"] #mapLead { display: none; }
    .hub:has(.view[data-level="detail"]) .companion { display: none; }
    .detail { padding: 0; animation: drillIn .32s var(--ease); }
    @keyframes drillIn { from { opacity: 0; transform: scale(.97) translateY(8px); } }

    /* ── 상세 ── */
    .detail-bar { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 20px; }
    .back { background: var(--bg-2); border: 1px solid var(--line); color: var(--fg); font: inherit; font-size: .86rem; font-weight: 600; padding: 9px 15px; border-radius: 999px; cursor: pointer; transition: border-color .15s, background .15s; }
    .back:hover { border-color: var(--dc); background: color-mix(in srgb, var(--dc) 12%, var(--bg-2)); }
    .crumb { font-size: .84rem; color: var(--muted); }
    .crumb b { color: var(--faint); margin: 0 2px; }
    .crumb .cr-here { color: var(--fg); font-weight: 600; }
    .dfilter { display: flex; gap: 6px; margin-left: auto; flex-wrap: wrap; }
    .fchip { display: inline-flex; align-items: center; gap: 6px; padding: 7px 13px; border-radius: 999px; border: 1px solid var(--line); background: var(--bg-2); color: var(--fg-soft); font-size: .8rem; font-weight: 600; cursor: pointer; transition: background .14s, color .14s, border-color .14s; }
    .fchip:hover { color: var(--fg); }
    .fchip.on { background: color-mix(in srgb, var(--dc) 20%, transparent); border-color: var(--dc); color: #fff; }
    .detail-head { display: flex; align-items: center; gap: 16px; margin-bottom: 22px; padding: 22px; border-radius: 22px; background: linear-gradient(155deg, color-mix(in srgb, var(--dc) 15%, var(--bg-1)), var(--bg-1) 70%); border: 1px solid color-mix(in srgb, var(--dc) 28%, var(--line)); }
    .detail-head h2 { margin: 0; font-size: 1.6rem; letter-spacing: -.02em; }
    .dh-en { font-size: .82rem; color: var(--muted); font-weight: 500; margin-left: 8px; }
    .detail-head p { margin: 4px 0 0; color: var(--fg-soft); font-size: .9rem; }
    .regions { columns: 320px 3; column-gap: 16px; }
    .region { break-inside: avoid; margin: 0 0 16px; padding: 18px; border-radius: 18px; background: var(--bg-1); border: 1px solid var(--line); }
    .region h3 { margin: 0 0 10px; font-size: 1rem; font-weight: 700; letter-spacing: -.01em; display: flex; align-items: center; gap: 8px; }
    .region h3::before { content: ""; width: 8px; height: 8px; border-radius: 50%; background: var(--dc); box-shadow: 0 0 7px var(--dc); }
    .region ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 2px; }
    .place-a { display: flex; align-items: center; gap: 10px; padding: 9px 10px; margin: 0 -6px; border-radius: 10px; color: var(--fg-soft); font-size: .92rem; text-decoration: none; transition: background .14s, color .14s; }
    .place-a:hover, .place-a:focus-visible { background: color-mix(in srgb, var(--dc) 12%, var(--bg-2)); color: var(--fg); outline: none; }
    .place-t { flex: 1; line-height: 1.35; }
    .from { font-size: .7rem; color: var(--muted); background: var(--bg-2); border: 1px solid var(--line-soft); padding: 2px 7px; border-radius: 999px; white-space: nowrap; }
    .ext { color: var(--muted); font-size: .78rem; }
    .go { color: var(--dc); font-size: .85rem; opacity: 0; transform: translateX(-4px); transition: opacity .14s, transform .14s; }
    .place-a:hover .go { opacity: 1; transform: none; }
    .place[hidden] { display: none; }
    .no-hit { text-align: center; color: var(--muted); padding: 30px; }

    .dot { width: 8px; height: 8px; border-radius: 50%; flex: 0 0 auto; background: var(--line); box-shadow: 0 0 6px currentColor; }
    .dot.live { background: #6fe08a; color: #6fe08a; }
    .dot.building { background: #ffc061; color: #ffc061; }
    .dot.seed { background: #a78bfa; color: #a78bfa; }
    .dot.idea { background: #6b6f7a; color: transparent; }

    .legend { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 18px; margin: 32px 2px 0; color: var(--muted); font-size: .84rem; }
    .legend > span { display: inline-flex; align-items: center; gap: 7px; }
    .legend-note { color: var(--faint); }

    @media (max-width: 620px) { .continents { grid-template-columns: 1fr; } .regions { columns: 1; } .dfilter { margin-left: 0; width: 100%; } }
    @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
    @keyframes blink { 0%,92%,100% { transform: scaleY(1); } 96% { transform: scaleY(.1); } }
    @keyframes rise { from { opacity: 0; transform: translateY(16px); } }
    @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
    @keyframes squish { 0%,100% { border-radius: 50% 50% 48% 48%; } 50% { border-radius: 48% 48% 52% 52%; } }
    @keyframes shadowpulse { 0%,100% { transform: translateX(-50%) scale(1); opacity: .45; } 50% { transform: translateX(-50%) scale(.8); opacity: .25; } }
    @keyframes spin { to { transform: rotate(360deg); } }
    @keyframes talk { 0%,100% { height: 10px; } 50% { height: 6px; } }
    @keyframes wave { 0%,100% { transform: rotate(0); } 25% { transform: rotate(-22deg); } 60% { transform: rotate(14deg); } }
    @keyframes twinkle { 0%,100% { opacity: .25; transform: scale(.7); } 50% { opacity: 1; transform: scale(1.15); } }
    @media (prefers-reduced-motion: reduce) { .arami, .ar-ring, .ar-eye, .ar-mouth, .ar-spark, .ar-shadow, .ar-hand, .ar-body, .cf-body, .cf-eye { animation: none !important; } .cont, .detail, .cont-sheen { animation: none !important; transition: none !important; } }
  </style>

  <script is:inline>
    (function () {
      const view = document.getElementById('view');
      const conts = Array.from(document.querySelectorAll('.cont'));
      const details = Array.from(document.querySelectorAll('.detail'));
      const byKeyName = { '01': '개인', '02': '회사', '03': '사람·관계', '04': '지식', '05': '자산' };

      function openDomain(key) {
        details.forEach((d) => { d.hidden = d.dataset.key !== key; });
        view.dataset.level = 'detail';
        window.scrollTo({ top: 0, behavior: 'smooth' });
        history.replaceState(null, '', '#' + key);
      }
      function backToMap() {
        view.dataset.level = 'overview';
        details.forEach((d) => { d.hidden = true; });
        history.replaceState(null, '', location.pathname);
      }
      conts.forEach((c) => c.addEventListener('click', () => openDomain(c.dataset.key)));
      document.querySelectorAll('[data-back]').forEach((b) => b.addEventListener('click', backToMap));
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && view.dataset.level === 'detail') backToMap(); });

      details.forEach((d) => {
        const chips = Array.from(d.querySelectorAll('.fchip'));
        const places = Array.from(d.querySelectorAll('.place'));
        const noHit = d.querySelector('.no-hit');
        const regions = Array.from(d.querySelectorAll('.region'));
        chips.forEach((c) => c.addEventListener('click', () => {
          chips.forEach((x) => x.classList.toggle('on', x === c));
          const s = c.dataset.status;
          places.forEach((p) => { p.hidden = !(s === 'all' || p.dataset.status === s); });
          let any = false;
          regions.forEach((r) => { const vis = r.querySelector('.place:not([hidden])'); r.style.display = vis ? '' : 'none'; if (vis) any = true; });
          if (noHit) noHit.hidden = any;
        }));
      });

      // ── 성장(게이미피케이션): 활동 로그로 구동 ──
      function readEvents() { try { return JSON.parse(localStorage.getItem('aramirror.events.buffer.v1') || '[]'); } catch (_) { return []; } }
      function dayKey(iso) { const d = new Date(iso); return d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate(); }
      function streakOf(evs) { const days = new Set(evs.map((e) => dayKey(e.occurred_at))); let s = 0; const d = new Date(); for (;;) { const k = d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate(); if (days.has(k)) { s++; d.setDate(d.getDate() - 1); } else break; } return s; }
      const STAGES = [0, 3, 10, 25, 60, 120], NAMES = ['씨앗', '새싹', '잎', '봉오리', '꽃', '큰 나무'];
      const stageOf = (t) => { let s = 0; for (let i = 0; i < STAGES.length; i++) if (t >= STAGES[i]) s = i; return s; };
      const set = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
      function refresh() {
        const evs = readEvents(), total = evs.length;
        const today = evs.filter((e) => dayKey(e.occurred_at) === dayKey(new Date().toISOString())).length;
        const streak = streakOf(evs), stage = stageOf(total), level = Math.max(1, Math.floor(Math.sqrt(total)) + 1);
        set('statLevel', level); set('statStreak', streak); set('statToday', today); set('statTotal', total);
        set('stagePill', NAMES[stage]);
        const sp = document.getElementById('sprout'); if (sp) sp.setAttribute('data-stage', String(stage));
        const isMax = stage >= STAGES.length - 1, base = STAGES[stage], next = STAGES[Math.min(stage + 1, STAGES.length - 1)];
        const pct = isMax ? 100 : Math.round(((total - base) / (next - base)) * 100);
        const fill = document.getElementById('xpFill'); if (fill) fill.style.width = Math.max(6, pct) + '%';
        set('xpText', isMax ? '만개 완료 🌳' : (total + ' / ' + next + ' XP'));
        const ring = document.getElementById('ringFg'); if (ring) ring.style.strokeDashoffset = String(195 - 195 * (isMax ? 1 : Math.min(1, (total - base) / (next - base))));
        const say = document.getElementById('araSay');
        if (say && total > 0) say.textContent = '연속 ' + streak + '일째 · ' + NAMES[stage] + ' 단계예요!';
      }
      refresh(); setTimeout(refresh, 300);

      const h = location.hash.replace('#', '');
      if (h && details.some((d) => d.dataset.key === h)) openDomain(h);
    })();
  </script>
