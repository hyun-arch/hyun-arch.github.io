---
import Base from '../layouts/Base.astro';
import { video, osPillars, references } from '../data/video.js';

// 릴스 스튜디오 — 레퍼런스 하나로 기획→생산→제작→검수까지 한 화면.
// 사이트 chrome 은 아라미러 다크 테마, 씬 프레임 미리보기는 브랜드 노랑 #e9ed12(iframe 실제 렌더).
const stages = [
  { id: 'ref', n: '01', t: '레퍼런스' },
  { id: 'plan', n: '02', t: '기획' },
  { id: 'board', n: '03', t: '스토리보드' },
  { id: 'script', n: '04', t: '스크립트' },
  { id: 'produce', n: '05', t: '프로덕션' },
  { id: 'qc', n: '06', t: '검수' },
  { id: 'export', n: '07', t: '내보내기' },
  { id: 'archive', n: '08', t: '보관함' },
];
const caps = video.captions;
const a = video.reference.anatomy;
---
<Base title="릴스 스튜디오">
  <section style="padding-top:80px">
    <div class="wrap">
      <p class="section-kicker">Reels Studio · 영상 OS</p>
      <h2>레퍼런스 하나로, <mark>기획→제작→검수</mark>까지</h2>
      <p class="lead">
        인터넷·SNS에서 괜찮았던 영상 링크를 넣으면 → 같은 결로 스토리보드·스크립트·검수까지. HTML로 렌더하는 영상 OS.
        지금 세트: <b>{video.topic}</b> · {video.format} · 목표 {video.duration}초
      </p>

      <div class="stage-nav">
        {stages.map((s) => (<a href={`#${s.id}`}><span class="sn">{s.n}</span>{s.t}</a>))}
      </div>

      <div class="savebar">
        <button id="save-video" class="btn accent">＋ 이 릴스 보관함에 저장</button>
        <span id="save-status" class="save-status"></span>
        <span class="save-mode" id="save-mode"></span>
      </div>
      <!-- 저장 스냅샷 원본: 현재 세트를 JSON으로 보관함에 넣는다. -->
      <script id="video-snapshot" type="application/json" set:html={JSON.stringify({
        id: video.id,
        topic: video.topic,
        format: video.format,
        duration: video.duration,
        model: video.model,
        reference: video.reference,
        prompt: { hook: video.hook, audience: video.audience, brand: video.brand, handle: video.handle, bgm: video.bgm },
        scenes: video.scenes.map((s) => ({ n: s.n, at: s.at, dur: s.dur, kind: s.kind, onscreen: s.onscreen, narration: s.narration, broll: s.broll, motion: s.motion })),
        script: video.script,
      })} />

      <!-- 01 레퍼런스 -->
      <div class="block" id="ref">
        <h3 class="blk-h"><span class="blk-n">01</span> 레퍼런스 — 괜찮았던 영상 넣기</h3>
        <p class="blk-d">인터넷·SNS에서 본 영상 링크를 넣고 <b>분석</b>을 누르면, 왜 좋았는지(훅·페이싱·자막·사운드·CTA·스펙)를 6칸으로 뜯어드려요. 그 결대로 아래 스토리보드가 만들어집니다.</p>
        <div class="ref-in">
          <input id="ref-url" type="url" placeholder="https://instagram.com/reel/... · tiktok · youtube shorts ..." value={video.reference.url} />
          <button id="ref-go" class="btn accent" type="button">분석</button>
        </div>
        <p id="ref-detect" class="ref-detect"></p>
        <div class="anatomy">
          <label class="ana"><span class="ana-k">훅</span><textarea data-ana="hook" rows="2">{a.hook}</textarea></label>
          <label class="ana"><span class="ana-k">페이싱</span><textarea data-ana="pacing" rows="2">{a.pacing}</textarea></label>
          <label class="ana"><span class="ana-k">자막</span><textarea data-ana="caption" rows="2">{a.caption}</textarea></label>
          <label class="ana"><span class="ana-k">사운드</span><textarea data-ana="sound" rows="2">{a.sound}</textarea></label>
          <label class="ana"><span class="ana-k">CTA</span><textarea data-ana="cta" rows="2">{a.cta}</textarea></label>
          <label class="ana"><span class="ana-k">스펙</span><textarea data-ana="spec" rows="2">{a.spec}</textarea></label>
        </div>
        <p class="exp-note">※ 링크는 브라우저에 저장돼요(이 기기). 실제 영상 다운로드·자동분석은 텔레그램에 “이 링크 분석해줘” 하면 프레임 단위로 뜯어 채워드려요.</p>
      </div>

      <!-- 02 기획 -->
      <div class="block" id="plan">
        <h3 class="blk-h"><span class="blk-n">02</span> 기획 — 영상 OS 6가지</h3>
        <p class="blk-d">이 6개를 고정하면 “이 레퍼런스로 릴스 만들어줘” 한마디에 매번 같은 결이 나온다.</p>
        <div class="pillars">
          {osPillars.map((p) => (
            <div class="pillar">
              <div class="pil-top"><span class="pil-n">{p.n}</span><h4>{p.name}</h4>{p.done ? <span class="chk">✓</span> : <span class="wip">…</span>}</div>
              <p class="pil-detail">{p.detail}</p>
              <p class="pil-have">{p.have}</p>
              <p class="pil-miss">안 하면 · {p.miss}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- 03 스토리보드 -->
      <div class="block" id="board">
        <h3 class="blk-h"><span class="blk-n">03</span> 스토리보드 — {video.scenes.length}컷 · {video.duration}초</h3>
        <p class="blk-d">실제 세로 렌더(9:16)를 그대로 축소해 보여줍니다. ← → 로 넘겨보고, 각 컷의 자막·나레이션·수정 지시를 고칠 수 있어요.</p>
        <div class="viewer-row">
          <button class="nav-btn" id="prev" aria-label="이전">←</button>
          <div class="viewer"><iframe id="frame" src="/reels/frame/1" scrolling="no" title="scene"></iframe></div>
          <button class="nav-btn" id="next" aria-label="다음">→</button>
        </div>
        <p class="counter"><span id="counter">1</span> / {video.scenes.length} · <span id="counter-t"></span></p>
        <div class="strip">
          {video.scenes.map((s) => (
            <button class="thumb" data-n={s.n} title={`씬 ${s.n}`}>
              <iframe src={`/reels/frame/${s.n}`} scrolling="no" tabindex="-1"></iframe>
              <span class="thumb-n">{s.n}</span>
            </button>
          ))}
        </div>

        <div class="scenes">
          {video.scenes.map((s) => (
            <div class="scene" data-scene={s.n}>
              <div class="scene-head">
                <span class="scene-kick">{s.label} · <b>{s.kind}</b></span>
                <span class="scene-time">{s.dur}초</span>
              </div>
              <label class="fld"><span>화면 자막</span><input data-f="onscreen" value={s.onscreen} /></label>
              <label class="fld"><span>나레이션</span><textarea data-f="narration" rows="2">{s.narration}</textarea></label>
              <label class="fld"><span>비주얼 / 모션</span><textarea data-f="broll" rows="2">{s.broll} · {s.motion}</textarea></label>
            </div>
          ))}
        </div>
        <p id="board-saved" class="save-status"></p>
      </div>

      <!-- 04 스크립트 · 자막 -->
      <div class="block" id="script">
        <h3 class="blk-h"><span class="blk-n">04</span> 스크립트 · 자막 — 플랫폼별</h3>
        <p class="blk-d">보이스오버 전체 스크립트와, 플랫폼별 캡션. 복사해서 바로 붙여넣기.</p>
        <div class="cap-head"><span class="cap-note">🎙 보이스오버 스크립트 (나레이션)</span><button class="copy" id="copy-script">복사</button></div>
        <pre class="cap-body" id="script-body">{video.script}</pre>
        <div class="tabs" style="margin-top:22px">
          <button class="tab on" data-p="instagram">Instagram</button>
          <button class="tab" data-p="youtube">YouTube</button>
          <button class="tab" data-p="tiktok">TikTok</button>
        </div>
        {Object.entries(caps).map(([k, c], i) => (
          <div class={`cap ${i === 0 ? 'on' : ''}`} data-cap={k}>
            <div class="cap-head"><span class="cap-note">{c.note}</span><button class="copy" data-copy={k}>복사</button></div>
            <pre class="cap-body" id={`cap-${k}`}>{c.body}</pre>
          </div>
        ))}
      </div>

      <!-- 05 프로덕션 -->
      <div class="block" id="produce">
        <h3 class="blk-h"><span class="blk-n">05</span> 프로덕션 — 이 레퍼런스로 만들어줘</h3>
        <p class="blk-d">위 레퍼런스 해부 + 스토리보드 + 브랜드를 하나의 지시문으로 조립합니다. <b>복사</b>해서 텔레그램/클로드코드에 붙이면 HyperFrames가 9:16 영상을 렌더해요.</p>
        <div class="cap-head"><span class="cap-note">🎬 제작 지시문 (자동 조립 · 편집 반영됨)</span><button class="copy" id="copy-brief">복사</button></div>
        <pre class="cap-body" id="brief-body">조립 중…</pre>
      </div>

      <!-- 06 검수 -->
      <div class="block" id="qc">
        <h3 class="blk-h"><span class="blk-n">06</span> 검수 — 나가기 전 체크</h3>
        <p class="blk-d">발행 전에 이 항목을 확인. 체크 상태는 이 기기에 저장돼요. <b id="qc-count"></b></p>
        <div class="qc-list">
          {video.qc.map((q) => (
            <label class="qc-item" data-qc={q.k}>
              <input type="checkbox" data-qc-box={q.k} />
              <span>{q.label}</span>
            </label>
          ))}
        </div>
        <div class="qc-bar"><div id="qc-fill"></div></div>
      </div>

      <!-- 07 내보내기 -->
      <div class="block" id="export">
        <h3 class="blk-h"><span class="blk-n">07</span> 내보내기 — 프레임 · 영상</h3>
        <p class="blk-d">각 씬은 1080×1920 전용 페이지로 열려요. HyperFrames 렌더의 프레임 소스이자, 정지컷 썸네일로도 씁니다.</p>
        <div class="exp-grid">
          {video.scenes.map((s) => (
            <a class="exp" href={`/reels/frame/${s.n}`} target="_blank" rel="noopener">씬 {s.n} 열기 ↗</a>
          ))}
        </div>
        <p class="exp-note">※ 전체 mp4 렌더는 텔레그램에 “릴스 뽑아줘” 하면 스토리보드대로 HyperFrames가 영상으로 만들어 보내드려요.</p>
        <div class="refs" style="margin-top:22px">
          {references.map((r) => (
            <a class="ref" href={r.url} target="_blank" rel="noopener">
              <span class="ref-t">{r.label}</span>
              <span class="ref-d">{r.desc}</span>
              <span class="ref-go">↗</span>
            </a>
          ))}
        </div>
      </div>

      <!-- 08 보관함 -->
      <div class="block" id="archive">
        <h3 class="blk-h"><span class="blk-n">08</span> 보관함 — 만든 릴스 모아보기</h3>
        <p class="blk-d">저장한 릴스가 여기 쌓입니다. 새로고침해도 안 사라져요. <b id="arch-mode-note"></b></p>
        <div id="archive-list" class="archive-list"></div>
        <p id="archive-empty" class="exp-note">아직 저장한 릴스가 없어요. 위 “보관함에 저장”을 눌러보세요.</p>
        <div id="archive-detail" class="arch-detail" hidden>
          <div class="arch-detail-head">
            <h4 id="ad-topic"></h4>
            <button id="ad-close" class="copy sm" type="button">닫기</button>
          </div>
          <p id="ad-meta" class="arch-detail-meta"></p>
          <ol id="ad-scenes" class="arch-detail-slides"></ol>
        </div>
      </div>
    </div>
  </section>

  <style>
    .stage-nav { display: flex; flex-wrap: wrap; gap: 8px; margin: 8px 0 40px; }
    .stage-nav a { display: inline-flex; align-items: center; gap: 8px; border: 1px solid var(--line);
      border-radius: 999px; padding: 8px 16px; font-size: 0.9rem; font-weight: 600; color: var(--fg-soft); }
    .stage-nav a:hover { background: var(--bg-soft); border-color: var(--fg); }
    .stage-nav .sn { font-family: var(--mono); color: var(--accent); font-size: 0.78rem; }

    .block { padding: 40px 0; border-top: 1px solid var(--line-soft); scroll-margin-top: 70px; }
    .blk-h { font-size: 1.35rem; font-weight: 800; letter-spacing: -0.02em; margin: 0 0 6px; display: flex; align-items: baseline; gap: 12px; }
    .blk-n { font-family: var(--mono); color: var(--accent); font-size: 0.95rem; font-weight: 600; }
    .blk-d { color: var(--muted); margin: 0 0 24px; max-width: 62ch; line-height: 1.6; }

    /* 01 레퍼런스 */
    .ref-in { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 10px; }
    .ref-in input { flex: 1; min-width: 220px; background: var(--bg-card); border: 1px solid var(--line);
      border-radius: 12px; padding: 13px 16px; color: var(--fg); font: inherit; font-size: 0.95rem; }
    .ref-in input:focus { outline: none; border-color: var(--accent); }
    .ref-detect { font-family: var(--mono); font-size: 0.82rem; color: var(--accent); min-height: 1.2em; margin: 0 0 18px; }
    .anatomy { display: grid; gap: 12px; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
    .ana { display: flex; flex-direction: column; gap: 6px; }
    .ana-k { font-family: var(--mono); font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); font-weight: 700; }
    .ana textarea, .fld input, .fld textarea { background: var(--bg-card); border: 1px solid var(--line); border-radius: 10px;
      padding: 10px 12px; color: var(--fg); font: inherit; font-size: 0.92rem; line-height: 1.5; resize: vertical; width: 100%; }
    .ana textarea:focus, .fld input:focus, .fld textarea:focus { outline: none; border-color: var(--accent); }

    /* 기획 */
    .pillars { display: grid; gap: 14px; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); }
    .pillar { border: 1px solid var(--line); border-radius: 14px; padding: 20px; background: var(--bg-card); }
    .pil-top { display: flex; align-items: center; gap: 10px; }
    .pil-n { font-family: var(--mono); font-weight: 700; color: var(--accent); }
    .pil-top h4 { margin: 0; font-size: 1.05rem; font-weight: 700; flex: 1; }
    .chk { color: #2fa15a; font-weight: 800; }
    .wip { color: var(--accent); font-weight: 800; }
    .pil-detail { color: var(--muted); font-size: 0.85rem; margin: 8px 0 12px; }
    .pil-have { font-size: 0.92rem; line-height: 1.5; color: var(--fg-soft); margin: 0; }
    .pil-miss { font-size: 0.82rem; color: var(--accent-strong); margin: 12px 0 0; opacity: 0.9; }

    /* 스토리보드 뷰어 (세로 9:16) */
    .viewer-row { display: flex; align-items: center; justify-content: center; gap: 20px; }
    .viewer { width: 270px; height: 480px; border-radius: 20px; overflow: hidden; border: 1px solid var(--line);
      box-shadow: 0 18px 50px rgba(0,0,0,0.45); flex: 0 0 auto; background: #111; }
    .viewer iframe { width: 1080px; height: 1920px; border: 0; transform: scale(0.25); transform-origin: top left; }
    .nav-btn { width: 52px; height: 52px; border-radius: 50%; border: 1px solid var(--line); background: var(--bg-card);
      font-size: 1.3rem; cursor: pointer; color: var(--fg); flex: 0 0 auto; transition: background .15s; }
    .nav-btn:hover { background: var(--fg); color: var(--bg); }
    .counter { text-align: center; font-family: var(--mono); color: var(--muted); margin: 16px 0 22px; }
    .counter #counter { color: var(--accent); font-weight: 700; }
    .strip { display: flex; gap: 10px; overflow-x: auto; padding: 6px 2px 12px; }
    .thumb { position: relative; width: 88px; height: 156px; flex: 0 0 auto; border-radius: 10px; overflow: hidden;
      border: 2px solid var(--line); background: #111; cursor: pointer; padding: 0; }
    .thumb.on { border-color: var(--accent); }
    .thumb iframe { width: 1080px; height: 1920px; border: 0; transform: scale(0.0815); transform-origin: top left; pointer-events: none; }
    .thumb-n { position: absolute; left: 5px; bottom: 4px; font-family: var(--mono); font-size: 0.7rem; font-weight: 700;
      color: #fff; background: rgba(0,0,0,.5); border-radius: 4px; padding: 1px 5px; }

    .scenes { display: grid; gap: 12px; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); margin-top: 22px; }
    .scene { border: 1px solid var(--line); border-radius: 14px; padding: 16px 18px; background: var(--bg-card); }
    .scene-head { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 12px; }
    .scene-kick { font-family: var(--mono); font-size: 0.74rem; letter-spacing: 0.04em; color: var(--accent); font-weight: 700; }
    .scene-kick b { color: var(--fg); }
    .scene-time { font-family: var(--mono); font-size: 0.74rem; color: var(--muted); }
    .fld { display: flex; flex-direction: column; gap: 5px; margin-bottom: 10px; }
    .fld span { font-size: 0.76rem; color: var(--muted); }

    /* 스크립트 · 캡션 */
    .tabs { display: flex; gap: 8px; margin-bottom: 14px; }
    .tab { border: 1px solid var(--line); background: var(--bg-card); border-radius: 999px; padding: 8px 18px;
      font-weight: 600; font-size: 0.9rem; cursor: pointer; color: var(--fg-soft); }
    .tab.on { background: var(--fg); color: var(--bg); border-color: var(--fg); }
    .cap { display: none; }
    .cap.on { display: block; }
    .cap-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; gap: 10px; }
    .cap-note { color: var(--muted); font-size: 0.86rem; }
    .cap-body { white-space: pre-wrap; font-family: inherit; background: var(--bg-card); border: 1px solid var(--line);
      border-radius: 12px; padding: 20px 22px; line-height: 1.7; font-size: 0.94rem; margin: 0; color: var(--fg); }
    .copy { border: 1px solid var(--line); background: var(--bg-card); border-radius: 8px; padding: 6px 14px;
      font-size: 0.82rem; font-weight: 600; cursor: pointer; color: var(--fg); flex: 0 0 auto; }
    .copy:hover { background: var(--fg); color: var(--bg); }
    .copy.sm { padding: 4px 10px; font-size: 0.76rem; }
    .copy.done { background: #2fa15a; color: #fff; border-color: #2fa15a; }

    /* 검수 */
    .qc-list { display: grid; gap: 8px; }
    .qc-item { display: flex; align-items: flex-start; gap: 12px; border: 1px solid var(--line); border-radius: 12px;
      padding: 14px 16px; background: var(--bg-card); cursor: pointer; font-size: 0.94rem; line-height: 1.5; color: var(--fg-soft); }
    .qc-item input { margin-top: 3px; width: 18px; height: 18px; accent-color: var(--accent); flex: 0 0 auto; }
    .qc-item.on { border-color: #2fa15a; color: var(--fg); }
    .qc-bar { margin-top: 16px; height: 8px; border-radius: 999px; background: var(--bg-card); border: 1px solid var(--line); overflow: hidden; }
    .qc-bar #qc-fill { height: 100%; width: 0; background: #2fa15a; transition: width .3s; }

    /* 내보내기 */
    .exp-grid { display: grid; gap: 10px; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); }
    .exp { text-align: center; border: 1px solid var(--line); border-radius: 10px; padding: 14px; font-weight: 600;
      font-size: 0.9rem; color: var(--fg); background: var(--bg-card); }
    .exp:hover { background: var(--bg-soft); }
    .exp-note { color: var(--muted); font-size: 0.86rem; margin-top: 16px; }
    .refs { display: grid; gap: 10px; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
    .ref { display: flex; align-items: center; gap: 12px; border: 1px solid var(--line); border-radius: 12px; padding: 16px 18px; background: var(--bg-card); }
    .ref:hover { background: var(--bg-soft); border-color: var(--fg); }
    .ref-t { font-weight: 700; flex: 1; }
    .ref-d { color: var(--muted); font-size: 0.82rem; }
    .ref-go { color: var(--accent); font-weight: 700; }

    /* 저장 바 + 보관함 */
    .savebar { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin: 0 0 36px; }
    .save-status { color: #2fa15a; font-weight: 600; font-size: 0.9rem; }
    .save-mode { margin-left: auto; font-family: var(--mono); font-size: 0.76rem; color: var(--muted); }
    .archive-list { display: grid; gap: 12px; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); }
    .arch { border: 1px solid var(--line); border-radius: 14px; padding: 18px 20px; background: var(--bg-card); }
    .arch h4 { margin: 0 0 4px; font-size: 1.05rem; font-weight: 700; }
    .arch .meta { font-family: var(--mono); font-size: 0.76rem; color: var(--muted); }
    .arch .row { display: flex; gap: 8px; margin-top: 14px; }
    .arch button { border: 1px solid var(--line); background: var(--bg-card); border-radius: 8px; padding: 6px 12px; font-size: 0.82rem; font-weight: 600; cursor: pointer; color: var(--fg); }
    .arch button:hover { background: var(--bg-soft); }
    .arch button.del:hover { background: #b23c3c; color: #fff; border-color: #b23c3c; }
    .arch-detail { margin-top: 18px; border: 1px solid var(--line); border-radius: 14px; padding: 18px 20px; background: var(--bg-card); }
    .arch-detail-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .arch-detail-head h4 { margin: 0; font-size: 1.05rem; font-weight: 700; }
    .arch-detail-meta { font-family: var(--mono); font-size: 0.78rem; color: var(--muted); margin: 6px 0 12px; }
    .arch-detail-slides { margin: 0; padding-left: 1.3em; display: grid; gap: 6px; }
    .arch-detail-slides li { line-height: 1.5; color: var(--fg-soft); font-size: 0.92rem; }
    .arch-detail-slides li b { color: var(--fg); }

    @media (max-width: 680px) {
      .viewer { width: 216px; height: 384px; }
      .viewer iframe { transform: scale(0.2); }
    }
  </style>

  <script is:inline>
    (function () {
      var scenes = window.__reelScenes = [];
      document.querySelectorAll('.thumb').forEach(function (t) { scenes.push(Number(t.dataset.n)); });
      var total = scenes.length;
      var frame = document.getElementById('frame');
      var counter = document.getElementById('counter');
      var counterT = document.getElementById('counter-t');
      var cur = 1;
      function show(n) {
        cur = ((n - 1 + total) % total) + 1;
        frame.src = '/reels/frame/' + cur;
        counter.textContent = cur;
        var card = document.querySelector('.scene[data-scene="' + cur + '"] .scene-kick');
        if (counterT && card) counterT.textContent = card.textContent;
        document.querySelectorAll('.thumb').forEach(function (t) {
          t.classList.toggle('on', Number(t.dataset.n) === cur);
        });
      }
      document.getElementById('prev').onclick = function () { show(cur - 1); };
      document.getElementById('next').onclick = function () { show(cur + 1); };
      document.querySelectorAll('.thumb').forEach(function (t) {
        t.onclick = function () { show(Number(t.dataset.n)); };
      });
      show(1);

      // 캡션 탭
      document.querySelectorAll('.tab').forEach(function (tab) {
        tab.onclick = function () {
          document.querySelectorAll('.tab').forEach(function (x) { x.classList.remove('on'); });
          document.querySelectorAll('.cap').forEach(function (x) { x.classList.remove('on'); });
          tab.classList.add('on');
          document.querySelector('.cap[data-cap="' + tab.dataset.p + '"]').classList.add('on');
        };
      });

      // 복사
      window.__copyText = function (txt, btn) {
        navigator.clipboard.writeText(txt).then(function () {
          var old = btn.textContent; btn.textContent = '복사됨 ✓'; btn.classList.add('done');
          setTimeout(function () { btn.textContent = old; btn.classList.remove('done'); }, 1400);
        });
      };
      document.querySelectorAll('.copy[data-copy]').forEach(function (b) {
        b.onclick = function () { window.__copyText(document.getElementById('cap-' + b.dataset.copy).textContent, b); };
      });
      var cs = document.getElementById('copy-script');
      if (cs) cs.onclick = function () { window.__copyText(document.getElementById('script-body').textContent, cs); };
    })();
  </script>

  <!-- 상태 · 편집 · 프롬프트 조립 · 보관함 (모듈: localStorage / Supabase 이중 모드) -->
  <script>
    import { hasSupabase } from '../lib/config.js';
    import { sbVideoList, sbVideoInsert, sbVideoDelete } from '../lib/backend.js';
    import { detectPlatform } from '../data/video.js';

    // ── 로컬 상태 키 ──
    const K_REF = 'aramreel.ref';       // 레퍼런스 url + 해부
    const K_SC = 'aramreel.scenes';     // 씬 편집 오버라이드
    const K_QC = 'aramreel.qc';         // 검수 체크
    const K_ARCH = 'aramreel.saved';    // 보관함(로컬)

    const snapshot = JSON.parse(document.getElementById('video-snapshot').textContent || '{}');
    const readJSON = (k, f) => { try { return JSON.parse(localStorage.getItem(k)) ?? f; } catch { return f; } };
    const writeJSON = (k, v) => localStorage.setItem(k, JSON.stringify(v));

    // ── 01 레퍼런스 ──
    const refUrl = document.getElementById('ref-url');
    const refDetect = document.getElementById('ref-detect');
    const anaEls = Array.from(document.querySelectorAll('[data-ana]'));
    function paintDetect(url) {
      const p = detectPlatform(url);
      const names = { instagram: 'Instagram', tiktok: 'TikTok', youtube: 'YouTube', x: 'X (Twitter)', facebook: 'Facebook', link: '링크', '': '' };
      refDetect.textContent = p ? ('감지됨 · ' + (names[p] || p) + ' — 아래 6칸을 이 영상 기준으로 채우세요') : '링크를 넣고 분석을 눌러보세요';
    }
    function readRef() {
      return { url: refUrl.value.trim(), platform: detectPlatform(refUrl.value.trim()),
        anatomy: Object.fromEntries(anaEls.map((e) => [e.dataset.ana, e.value])) };
    }
    function saveRef() { writeJSON(K_REF, readRef()); buildBrief(); }
    (function initRef() {
      const saved = readJSON(K_REF, null);
      if (saved) {
        if (saved.url) refUrl.value = saved.url;
        anaEls.forEach((e) => { if (saved.anatomy && saved.anatomy[e.dataset.ana] != null) e.value = saved.anatomy[e.dataset.ana]; });
      }
      paintDetect(refUrl.value);
      document.getElementById('ref-go').onclick = () => { paintDetect(refUrl.value); saveRef(); };
      anaEls.forEach((e) => e.addEventListener('input', saveRef));
      refUrl.addEventListener('input', () => paintDetect(refUrl.value));
    })();

    // ── 03 스토리보드 편집 ──
    const boardSaved = document.getElementById('board-saved');
    function readScenes() {
      const out = {};
      document.querySelectorAll('.scene').forEach((el) => {
        const n = el.dataset.scene;
        out[n] = { onscreen: el.querySelector('[data-f="onscreen"]').value,
          narration: el.querySelector('[data-f="narration"]').value,
          broll: el.querySelector('[data-f="broll"]').value };
      });
      return out;
    }
    function saveScenes() {
      writeJSON(K_SC, readScenes());
      boardSaved.textContent = '수정 저장됨 ✓';
      setTimeout(() => { boardSaved.textContent = ''; }, 1200);
      buildBrief();
    }
    (function initScenes() {
      const saved = readJSON(K_SC, null);
      if (saved) {
        document.querySelectorAll('.scene').forEach((el) => {
          const s = saved[el.dataset.scene]; if (!s) return;
          if (s.onscreen != null) el.querySelector('[data-f="onscreen"]').value = s.onscreen;
          if (s.narration != null) el.querySelector('[data-f="narration"]').value = s.narration;
          if (s.broll != null) el.querySelector('[data-f="broll"]').value = s.broll;
        });
      }
      document.querySelectorAll('.scene [data-f]').forEach((e) => e.addEventListener('change', saveScenes));
    })();

    // ── 05 프로덕션: 지시문 조립 ──
    const briefBody = document.getElementById('brief-body');
    function buildBrief() {
      const ref = readRef();
      const sc = readScenes();
      const a = ref.anatomy || {};
      const lines = [];
      lines.push('아래 레퍼런스와 스토리보드로 ' + (snapshot.format || '9:16 릴스') + '를 HyperFrames(HTML→영상)로 만들어줘.');
      lines.push('');
      lines.push('[레퍼런스] ' + (ref.url || '(링크 없음)') + (ref.platform ? ' · ' + ref.platform : ''));
      lines.push('  훅: ' + (a.hook || '') );
      lines.push('  페이싱: ' + (a.pacing || ''));
      lines.push('  자막: ' + (a.caption || ''));
      lines.push('  사운드: ' + (a.sound || ''));
      lines.push('  CTA: ' + (a.cta || ''));
      lines.push('  스펙: ' + (a.spec || ''));
      lines.push('');
      lines.push('[브랜드] 다크 배경 + 포인트 노랑 #e9ed12, Pretendard, 컷 사이 0.3s 크로스페이드. 핸들 ' + (snapshot.prompt?.handle || '@aramirror'));
      lines.push('[사운드] ' + (snapshot.prompt?.bgm || ''));
      lines.push('[대상] ' + (snapshot.prompt?.audience || ''));
      lines.push('');
      lines.push('[스토리보드] ' + (snapshot.scenes || []).length + '컷 · 목표 ' + (snapshot.duration || 30) + '초');
      (snapshot.scenes || []).forEach((s) => {
        const o = sc[String(s.n)] || {};
        lines.push('  씬' + s.n + ' (' + s.at + '–' + (s.at + s.dur) + 's · ' + s.kind + ')');
        lines.push('    자막: ' + (o.onscreen ?? s.onscreen));
        lines.push('    나레이션: ' + (o.narration ?? s.narration));
        lines.push('    비주얼/모션: ' + (o.broll ?? (s.broll + ' · ' + s.motion)));
      });
      lines.push('');
      lines.push('[검수 기준] 훅 3초 안, 무음 시청 대응, 자막 안전영역 상하 15%, 브랜드 컬러 고정, 컷 2.5–4초, 30초 이하, CTA 명확.');
      lines.push('프레임 미리보기: /reels/frame/1 … /reels/frame/' + (snapshot.scenes || []).length);
      briefBody.textContent = lines.join('\n');
    }
    const cb = document.getElementById('copy-brief');
    if (cb) cb.onclick = () => window.__copyText(briefBody.textContent, cb);
    buildBrief();

    // ── 06 검수 ──
    const qcBoxes = Array.from(document.querySelectorAll('[data-qc-box]'));
    const qcFill = document.getElementById('qc-fill');
    const qcCount = document.getElementById('qc-count');
    function paintQC() {
      const done = qcBoxes.filter((b) => b.checked).length;
      qcFill.style.width = (done / qcBoxes.length * 100) + '%';
      qcCount.textContent = '· ' + done + '/' + qcBoxes.length + ' 통과';
      qcBoxes.forEach((b) => b.closest('.qc-item').classList.toggle('on', b.checked));
    }
    (function initQC() {
      const saved = readJSON(K_QC, {});
      qcBoxes.forEach((b) => {
        b.checked = !!saved[b.dataset.qcBox];
        b.addEventListener('change', () => {
          const cur = readJSON(K_QC, {}); cur[b.dataset.qcBox] = b.checked; writeJSON(K_QC, cur); paintQC();
        });
      });
      paintQC();
    })();

    // ── 08 보관함 (이중 모드) ──
    const cloud = hasSupabase();
    const listEl = document.getElementById('archive-list');
    const emptyEl = document.getElementById('archive-empty');
    const modeNote = document.getElementById('arch-mode-note');
    const saveModeEl = document.getElementById('save-mode');
    const statusEl = document.getElementById('save-status');
    const saveBtn = document.getElementById('save-video');
    const detailEl = document.getElementById('archive-detail');

    const mode = cloud ? '클라우드 저장 (Supabase · 모든 기기)' : '브라우저 저장 (이 기기)';
    if (modeNote) modeNote.textContent = '· 현재: ' + mode;
    if (saveModeEl) saveModeEl.textContent = mode;

    const esc = (s) => (s || '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
    const stamp = (iso) => (iso || '').replace('T', ' ').slice(0, 16);
    function nowLocal() {
      const d = new Date(); const p = (n) => (n < 10 ? '0' : '') + n;
      return d.getFullYear() + '-' + p(d.getMonth() + 1) + '-' + p(d.getDate()) + ' ' + p(d.getHours()) + ':' + p(d.getMinutes());
    }
    function currentSnap() {
      const ref = readRef(); const sc = readScenes();
      return { ...snapshot, reference: ref,
        scenes: (snapshot.scenes || []).map((s) => ({ ...s, ...(sc[String(s.n)] || {}) })) };
    }
    function contentHash(snap) {
      const basis = [snap.topic, snap.reference?.url, (snap.scenes || []).map((s) => s.onscreen).join('§')].join('#');
      let h = 5381; for (let i = 0; i < basis.length; i++) h = ((h << 5) + h + basis.charCodeAt(i)) | 0;
      return 'h' + (h >>> 0).toString(36);
    }
    const readLocal = () => readJSON(K_ARCH, []);
    const writeLocal = (a) => writeJSON(K_ARCH, a);

    function normalize(x) {
      let data = null;
      if (x.data) { try { data = typeof x.data === 'string' ? JSON.parse(x.data) : x.data; } catch {} }
      return { id: String(x.id), topic: x.topic, scenes: (data && data.scenes) ? data.scenes.length : (x.scenes ?? 0),
        date: x.date || stamp(x.created_at), hash: x.hash || (data ? contentHash(data) : ''), reference: x.reference || (data?.reference?.url) || '', data };
    }
    async function listAll() {
      if (!cloud) return readLocal();
      const rows = await sbVideoList(); return (rows || []).map(normalize);
    }
    function renderCards(arr) {
      emptyEl.style.display = arr.length ? 'none' : 'block';
      listEl.innerHTML = arr.map((x) =>
        '<div class="arch"><h4>' + esc(x.topic) + '</h4>' +
        '<span class="meta">' + x.scenes + '컷 · ' + esc(x.date) + '</span>' +
        '<div class="row"><button data-open="' + x.id + '">보기</button>' +
        '<button class="del" data-del="' + x.id + '">삭제</button></div></div>').join('');
      listEl.querySelectorAll('[data-del]').forEach((b) => { b.onclick = async () => { await removeOne(b.dataset.del); refresh(); }; });
      listEl.querySelectorAll('[data-open]').forEach((b) => { b.onclick = () => openDetail(arr.find((y) => y.id === b.dataset.open)); });
    }
    function openDetail(item) {
      if (!item || !detailEl) return;
      const data = item.data || { topic: item.topic, scenes: [] };
      document.getElementById('ad-topic').textContent = item.topic || '(제목 없음)';
      const bits = [(data.scenes || []).length + '컷', item.date];
      if (data.duration) bits.push(data.duration + '초');
      if (item.reference) bits.push('ref: ' + item.reference);
      document.getElementById('ad-meta').textContent = bits.filter(Boolean).join(' · ');
      document.getElementById('ad-scenes').innerHTML = (data.scenes || []).map((s) =>
        '<li><b>씬' + s.n + '</b> — ' + esc(s.onscreen || '') + (s.narration ? ' <span style="opacity:.7">(' + esc(s.narration) + ')</span>' : '') + '</li>').join('')
        || '<li>스토리보드 정보가 저장되지 않은 항목입니다.</li>';
      detailEl.hidden = false; detailEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    if (document.getElementById('ad-close')) document.getElementById('ad-close').onclick = () => { detailEl.hidden = true; };

    async function removeOne(id) {
      if (cloud) { try { await sbVideoDelete(id); } catch (e) { console.error(e); } }
      else writeLocal(readLocal().filter((y) => y.id !== id));
      if (detailEl) detailEl.hidden = true;
    }
    async function refresh() { try { renderCards(await listAll()); } catch (e) { console.error(e); renderCards(readLocal()); } }
    async function promoteLocal() {
      if (!cloud) return; const local = readLocal(); if (!local.length) return;
      for (const x of local) {
        try { await sbVideoInsert({ topic: x.topic, format: x.data?.format || '9:16 릴스', duration: x.data?.duration || 0, scenes: Number(x.scenes) || 0, reference: x.reference || '', hash: x.hash, data: x.data }); }
        catch (e) { try { await sbVideoInsert({ topic: x.topic, scenes: Number(x.scenes) || 0 }); } catch (e2) { console.error('promote fail', e2); } }
      }
      writeLocal([]);
    }

    if (saveBtn) {
      saveBtn.onclick = async () => {
        const snap = currentSnap();
        const topic = snap.topic || '릴스';
        const scenes = (snap.scenes || []).length;
        const hash = contentHash(snap);
        let existing = [];
        try { existing = await listAll(); } catch { existing = readLocal(); }
        if (existing.some((y) => y.hash === hash)) {
          statusEl.textContent = '이미 같은 릴스가 있어요';
          setTimeout(() => { statusEl.textContent = ''; }, 1800); return;
        }
        if (cloud) {
          try { await sbVideoInsert({ topic, format: snap.format, duration: snap.duration || 0, scenes, reference: snap.reference?.url || '', hash, data: snap }); }
          catch (e) { console.warn('rich insert failed, retry minimal', e);
            try { await sbVideoInsert({ topic, scenes }); } catch (e2) { console.error(e2); statusEl.textContent = '저장 실패 — 잠시 후 다시'; return; } }
        } else {
          const arr = readLocal();
          arr.unshift({ id: 'v' + Date.now(), topic, scenes, date: nowLocal(), hash, reference: snap.reference?.url || '', data: snap });
          writeLocal(arr);
        }
        statusEl.textContent = '보관함에 저장됨 ✓';
        setTimeout(() => { statusEl.textContent = ''; }, 1800); refresh();
      };
    }

    (async () => { await promoteLocal(); refresh(); })();
  </script>
