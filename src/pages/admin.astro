---
import Base from '../layouts/Base.astro';
---
<Base title="관리자">
  <section style="padding-top:80px">
    <div class="wrap">
      <p class="section-kicker">Admin · 관리자 콘솔</p>
      <h2>게시판 · 웹페이지 상위 관리</h2>
      <p class="lead">게시판 글을 만들고 고치고 지운다. 웹페이지 노출을 관리한다. 데이터는 브라우저에 저장되고, JSON으로 내보내 영속화한다.</p>

      <!-- 접근 게이트 -->
      <div id="gate" class="ad-gate">
        <p>관리자 확인이 필요합니다.</p>
        <div class="ad-row">
          <input id="pass" type="password" placeholder="관리자 암호" class="ad-input" />
          <button id="enter" class="ad-btn ad-primary">입장</button>
        </div>
        <p class="ad-hint">기본 암호: <code>arami</code> — 첫 입장 후 하단에서 변경할 수 있습니다.</p>
      </div>

      <div id="panel" hidden>
        <!-- 통계 -->
        <div class="ad-stats" id="stats"></div>

        <!-- 글 작성/수정 폼 -->
        <div class="ad-card">
          <div class="ad-card-h">
            <h3 id="formTitle">새 글 작성</h3>
            <button id="cancelEdit" class="ad-btn" hidden>편집 취소</button>
          </div>
          <input type="hidden" id="editId" />
          <div class="ad-grid">
            <label class="ad-field ad-col2">
              <span>제목</span>
              <input id="fTitle" class="ad-input" placeholder="글 제목" />
            </label>
            <label class="ad-field">
              <span>카테고리</span>
              <select id="fCategory" class="ad-input"></select>
            </label>
            <label class="ad-field">
              <span>날짜</span>
              <input id="fDate" type="date" class="ad-input" />
            </label>
            <label class="ad-field ad-col2">
              <span>태그 (쉼표로 구분)</span>
              <input id="fTags" class="ad-input" placeholder="Aramirror, 성장" />
            </label>
            <label class="ad-field">
              <span>상태</span>
              <select id="fStatus" class="ad-input">
                <option value="published">게시</option>
                <option value="draft">초안</option>
              </select>
            </label>
            <label class="ad-field ad-col-full">
              <span>본문</span>
              <textarea id="fBody" class="ad-input ad-textarea" placeholder="내용을 입력하세요"></textarea>
            </label>
          </div>
          <div class="ad-row">
            <button id="save" class="ad-btn ad-primary">저장</button>
          </div>
        </div>

        <!-- 게시판 글 목록 (CRUD) -->
        <div class="ad-card">
          <div class="ad-card-h"><h3>게시판 글 관리</h3><span class="ad-count" id="postCount"></span></div>
          <div class="ad-table-wrap">
            <table class="ad-table" id="postTable">
              <thead>
                <tr><th>제목</th><th>분류</th><th>날짜</th><th>상태</th><th class="ad-actions-h">관리</th></tr>
              </thead>
              <tbody id="postRows"></tbody>
            </table>
          </div>
        </div>

        <!-- 웹페이지 상위 관리 -->
        <div class="ad-card">
          <div class="ad-card-h"><h3>웹페이지 상위 관리</h3><span class="ad-count" id="pageCount"></span></div>
          <div class="ad-table-wrap">
            <table class="ad-table" id="pageTable">
              <thead><tr><th>페이지</th><th>경로</th><th>메모</th><th>노출</th></tr></thead>
              <tbody id="pageRows"></tbody>
            </table>
          </div>
        </div>

        <!-- 데이터 영속화 -->
        <div class="ad-card">
          <div class="ad-card-h"><h3>데이터 내보내기 / 가져오기</h3></div>
          <p class="ad-hint">브라우저 저장분을 JSON으로 백업하거나 복원합니다. 내보낸 JSON을 저장소에 커밋하면 영구 보관됩니다.</p>
          <p class="ad-hint">↗ 업그레이드 경로 — 공유회 아젠다 ②처럼 <code>.env</code>에 KEY를 넣어 <b>Supabase</b>(DB)+<b>Vercel</b>(배포)로 연결하면, 이 콘솔이 그대로 다중 사용자 실서버 CRUD가 됩니다. "한 번이 힘들지 그다음은 쭉 편해진다."</p>
          <div class="ad-row">
            <button id="export" class="ad-btn">JSON 내보내기 (다운로드)</button>
            <button id="copyJson" class="ad-btn">클립보드 복사</button>
            <label class="ad-btn ad-file">JSON 가져오기<input id="importFile" type="file" accept="application/json" hidden /></label>
            <button id="reset" class="ad-btn ad-danger">시드로 초기화</button>
          </div>
          <textarea id="jsonOut" class="ad-input ad-textarea ad-json" readonly hidden></textarea>
        </div>

        <!-- 암호 변경 -->
        <div class="ad-card">
          <div class="ad-card-h"><h3>관리자 암호 변경</h3></div>
          <div class="ad-row">
            <input id="newPass" type="password" placeholder="새 암호" class="ad-input" />
            <button id="changePass" class="ad-btn">변경</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    .ad-gate { border: 1px solid var(--line); border-radius: var(--radius); padding: 32px; max-width: 460px; }
    .ad-gate p { margin: 0 0 14px; color: var(--fg-soft); }
    .ad-hint { color: var(--muted); font-size: 0.85rem; margin: 12px 0 0; }
    .ad-hint code, .ad-gate code { background: var(--bg-soft); padding: 2px 7px; border-radius: 6px; font-size: 0.9em; }
    .ad-row { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; margin-top: 14px; }
    .ad-input {
      font-family: inherit; font-size: 0.95rem; color: var(--fg);
      background: var(--bg); border: 1px solid var(--line); border-radius: 10px;
      padding: 11px 14px; width: 100%; box-sizing: border-box;
    }
    .ad-input:focus { outline: none; border-color: var(--fg); }
    .ad-textarea { min-height: 140px; resize: vertical; line-height: 1.6; }
    .ad-json { min-height: 180px; font-family: ui-monospace, monospace; font-size: 0.8rem; margin-top: 14px; }
    .ad-btn {
      font-family: inherit; font-size: 0.9rem; cursor: pointer; white-space: nowrap;
      background: var(--bg); color: var(--fg); border: 1px solid var(--line);
      border-radius: 10px; padding: 10px 18px; transition: all 0.15s ease;
    }
    .ad-btn:hover { border-color: var(--fg); }
    .ad-primary { background: var(--fg); color: #fff; border-color: var(--fg); }
    .ad-primary:hover { opacity: 0.85; }
    .ad-danger { color: #b00020; border-color: #e5b4bc; }
    .ad-danger:hover { border-color: #b00020; }
    .ad-file { display: inline-flex; align-items: center; }
    .ad-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 14px; margin: 8px 0 28px; }
    .ad-stat { border: 1px solid var(--line); border-radius: 14px; padding: 18px; }
    .ad-stat .v { font-size: 1.7rem; font-weight: 700; letter-spacing: -0.02em; }
    .ad-stat .l { color: var(--muted); font-size: 0.82rem; margin-top: 2px; }
    .ad-card { border: 1px solid var(--line); border-radius: var(--radius); padding: 28px; margin-bottom: 22px; }
    .ad-card-h { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
    .ad-card-h h3 { font-size: 1.15rem; font-weight: 700; letter-spacing: -0.02em; margin: 0; }
    .ad-count { color: var(--muted); font-size: 0.85rem; }
    .ad-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .ad-field { display: flex; flex-direction: column; gap: 6px; }
    .ad-field > span { font-size: 0.82rem; color: var(--muted); font-weight: 600; }
    .ad-col2 { grid-column: span 2; }
    .ad-col-full { grid-column: 1 / -1; }
    .ad-table-wrap { overflow-x: auto; }
    .ad-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .ad-table th { text-align: left; color: var(--muted); font-weight: 600; font-size: 0.78rem; padding: 10px 12px; border-bottom: 1px solid var(--line); }
    .ad-table td { padding: 12px; border-bottom: 1px solid var(--line-soft); vertical-align: middle; }
    .ad-table .ad-title-cell { font-weight: 600; }
    .ad-actions-h { text-align: right; }
    .ad-cell-actions { display: flex; gap: 6px; justify-content: flex-end; }
    .ad-mini { font-size: 0.78rem; padding: 6px 10px; border-radius: 8px; }
    .ad-badge { font-size: 0.72rem; padding: 3px 9px; border-radius: 999px; border: 1px solid var(--line); color: var(--muted); }
    .ad-badge.on { background: var(--fg); color: #fff; border-color: var(--fg); }
    .ad-toggle { cursor: pointer; }
    @media (max-width: 640px) { .ad-grid { grid-template-columns: 1fr; } .ad-col2 { grid-column: span 1; } }
  </style>

  <script>
    import {
      getPosts, createPost, updatePost, deletePost, togglePublish,
      getPages, togglePageVisibility, setPageNote,
      CATEGORIES, stats, exportAll, importAll, resetAll, onChange,
      init, backendMode,
    } from '../scripts/store.js';

    const PASS_KEY = 'aramirror.admin.pass';
    const SESSION_KEY = 'aramirror.admin.session';
    const $ = (id) => document.getElementById(id);
    const esc = (s) => String(s).replace(/[&<>"]/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[m]));
    // 로컬(KST) 날짜 YYYY-MM-DD — UTC(toISOString) 쓰면 새벽엔 하루 전으로 찍힘
    const localDate = () => { const d = new Date(), p = (n) => (n < 10 ? '0' : '') + n; return d.getFullYear() + '-' + p(d.getMonth() + 1) + '-' + p(d.getDate()); };

    // ── 접근 게이트 ──────────────────────────────────
    function currentPass() { return localStorage.getItem(PASS_KEY) || 'arami'; }
    function unlock() {
      $('gate').hidden = true;
      $('panel').hidden = false;
      initPanel();
    }
    $('enter').addEventListener('click', tryEnter);
    $('pass').addEventListener('keydown', (e) => { if (e.key === 'Enter') tryEnter(); });
    function tryEnter() {
      if ($('pass').value === currentPass()) {
        sessionStorage.setItem(SESSION_KEY, '1');
        unlock();
      } else {
        alert('암호가 올바르지 않습니다.');
      }
    }

    // ── 패널 초기화 ──────────────────────────────────
    let inited = false;
    function initPanel() {
      if (inited) return;
      inited = true;

      $('fCategory').innerHTML = CATEGORIES.map((c) => `<option value="${c}">${c}</option>`).join('');
      $('fDate').value = localDate();

      $('save').addEventListener('click', onSave);
      $('cancelEdit').addEventListener('click', clearForm);
      $('export').addEventListener('click', doExport);
      $('copyJson').addEventListener('click', doCopy);
      $('importFile').addEventListener('change', doImport);
      $('reset').addEventListener('click', async () => {
        const msg = backendMode() === 'supabase'
          ? '서버 데이터는 보호됩니다. 최신 상태로 다시 불러올까요?'
          : '모든 데이터를 시드 상태로 되돌립니다. 계속할까요?';
        if (confirm(msg)) { try { await resetAll(); } catch (e) { alert(e.message); } }
      });
      $('changePass').addEventListener('click', () => {
        const v = $('newPass').value.trim();
        if (v.length < 3) { alert('암호는 3자 이상이어야 합니다.'); return; }
        localStorage.setItem(PASS_KEY, v);
        $('newPass').value = '';
        alert('암호가 변경되었습니다.');
      });

      $('postRows').addEventListener('click', onPostAction);
      $('pageRows').addEventListener('click', onPageAction);
      $('pageRows').addEventListener('change', onNoteChange);

      onChange(renderAll);
      init().then(renderAll).catch(() => renderAll());
    }

    // ── 폼: 생성/수정 ────────────────────────────────
    async function onSave() {
      const payload = {
        title: $('fTitle').value.trim(),
        category: $('fCategory').value,
        date: $('fDate').value,
        tags: $('fTags').value,
        status: $('fStatus').value,
        body: $('fBody').value,
      };
      if (!payload.title) { alert('제목을 입력하세요.'); return; }
      const editId = $('editId').value;
      const btn = $('save');
      btn.disabled = true;
      try {
        if (editId) await updatePost(editId, payload);
        else await createPost(payload);
        clearForm();
      } catch (e) {
        alert('저장 실패: ' + e.message);
      } finally {
        btn.disabled = false;
      }
    }

    function clearForm() {
      $('editId').value = '';
      $('fTitle').value = '';
      $('fTags').value = '';
      $('fBody').value = '';
      $('fCategory').value = CATEGORIES[0];
      $('fStatus').value = 'published';
      $('fDate').value = localDate();
      $('formTitle').textContent = '새 글 작성';
      $('cancelEdit').hidden = true;
    }

    function loadIntoForm(p) {
      $('editId').value = p.id;
      $('fTitle').value = p.title;
      $('fCategory').value = p.category;
      $('fDate').value = p.date;
      $('fTags').value = (p.tags || []).join(', ');
      $('fStatus').value = p.status;
      $('fBody').value = p.body;
      $('formTitle').textContent = '글 수정';
      $('cancelEdit').hidden = false;
      $('fTitle').scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    async function onPostAction(e) {
      const btn = e.target.closest('button[data-act]');
      if (!btn) return;
      const id = btn.dataset.id;
      const act = btn.dataset.act;
      try {
        if (act === 'edit') loadIntoForm(getPosts().find((p) => p.id === id));
        else if (act === 'toggle') await togglePublish(id);
        else if (act === 'delete') { if (confirm('이 글을 삭제할까요?')) await deletePost(id); }
      } catch (err) {
        alert('처리 실패: ' + err.message);
      }
    }

    // ── 웹페이지 관리 ────────────────────────────────
    function onPageAction(e) {
      const btn = e.target.closest('button[data-path]');
      if (!btn) return;
      togglePageVisibility(btn.dataset.path);
    }
    function onNoteChange(e) {
      const inp = e.target.closest('input[data-note-path]');
      if (!inp) return;
      setPageNote(inp.dataset.notePath, inp.value);
    }

    // ── 내보내기 / 가져오기 ──────────────────────────
    function doExport() {
      const blob = new Blob([exportAll()], { type: 'application/json' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `aramirror-board-${localDate()}.json`;
      a.click();
      URL.revokeObjectURL(a.href);
    }
    async function doCopy() {
      const out = $('jsonOut');
      out.hidden = false;
      out.value = exportAll();
      try { await navigator.clipboard.writeText(out.value); alert('클립보드에 복사했습니다.'); }
      catch { out.select(); }
    }
    function doImport(e) {
      const file = e.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = async () => {
        try { await importAll(reader.result); alert('가져오기 완료.'); }
        catch (err) { alert('가져오기 실패: ' + err.message); }
      };
      reader.readAsText(file);
      e.target.value = '';
    }

    // ── 렌더 ─────────────────────────────────────────
    function renderAll() {
      const s = stats();
      const store = backendMode() === 'supabase' ? 'Supabase' : '브라우저';
      $('stats').innerHTML = [
        ['총 글', s.total], ['게시', s.published], ['초안', s.draft],
        ['노출 페이지', `${s.pagesVisible}/${s.pagesTotal}`], ['저장소', store],
      ].map(([l, v]) => `<div class="ad-stat"><div class="v">${v}</div><div class="l">${l}</div></div>`).join('');

      const posts = getPosts();
      $('postCount').textContent = `${posts.length}개`;
      $('postRows').innerHTML = posts.map((p) => `
        <tr>
          <td class="ad-title-cell">${esc(p.title)}</td>
          <td>${esc(p.category)}</td>
          <td>${esc(p.date)}</td>
          <td><span class="ad-badge ${p.status === 'published' ? 'on' : ''}">${p.status === 'published' ? '게시' : '초안'}</span></td>
          <td><div class="ad-cell-actions">
            <button class="ad-btn ad-mini" data-act="edit" data-id="${p.id}">수정</button>
            <button class="ad-btn ad-mini" data-act="toggle" data-id="${p.id}">${p.status === 'published' ? '숨김' : '게시'}</button>
            <button class="ad-btn ad-mini ad-danger" data-act="delete" data-id="${p.id}">삭제</button>
          </div></td>
        </tr>`).join('');

      const pages = getPages();
      $('pageCount').textContent = `${pages.length}개`;
      $('pageRows').innerHTML = pages.map((pg) => `
        <tr>
          <td class="ad-title-cell">${esc(pg.label)}</td>
          <td><a href="${pg.path}" style="text-decoration:underline">${esc(pg.path)}</a></td>
          <td><input class="ad-input" style="padding:7px 10px;font-size:0.82rem" data-note-path="${pg.path}" value="${esc(pg.note || '')}" placeholder="메모" /></td>
          <td><button class="ad-btn ad-mini ad-toggle ${pg.visible ? 'ad-primary' : ''}" data-path="${pg.path}">${pg.visible ? '노출' : '숨김'}</button></td>
        </tr>`).join('');
    }

    // 모든 선언 이후에 자동 언락 (세션 유지 시 재방문/새로고침에서도 정상 초기화)
    if (sessionStorage.getItem(SESSION_KEY) === '1') unlock();
  </script>
</Base>
