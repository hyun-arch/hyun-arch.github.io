---
import Base from '../layouts/Base.astro';

// ── 놀이터 구역 정의 ─────────────────────────────────────
const ZONES = [
  {
    key: 'hq', name: '총괄실', tag: 'Command', emoji: '🎧', color: '#ff7a4d',
    blurb: '오늘 할 일과 회사의 심장', prefixes: ['/hq', '/order', '/eval', '/vault', '/admin'],
    items: [
      { label: '대시보드', href: '/hq/index.html', d: '오늘의 관제실' },
      { label: '🔴 금고', href: '/vault', d: '매출·재무 (로컬 전용)' },
      { label: '기획주문서', href: '/order/index.html', d: '무엇을 만들지' },
      { label: '평가시트', href: '/eval/index.html', d: '어떻게 됐는지' },
      { label: '관리자', href: '/admin', d: '콘솔' },
    ],
  },
  {
    key: 'brain', name: '세컨드브레인', tag: 'Second Brain', emoji: '🧠', color: '#a78bfa',
    blurb: '던진 생각과 자료가 자산이 되는 곳', prefixes: ['/ask', '/archive', '/mirror', '/wall', '/writings', '/reading', '/board', '/publish'],
    items: [
      { label: '되묻기 · 멘토', href: '/ask', d: '생각을 던지면 되물어줌' },
      { label: '📥 자료실', href: '/archive', d: '뭐든 던지면 분류·요약' },
      { label: '전체 지도', href: '/mirror', d: '생각의 연결망' },
      { label: '생각의 벽', href: '/wall', d: '떠오른 것 그대로' },
      { label: '글', href: '/writings', d: '자산이 된 생각' },
      { label: '독서 · 학습', href: '/reading', d: '읽고 배운 것' },
      { label: '게시판', href: '/board', d: '기록' },
      { label: '발행', href: '/publish', d: '내보내기' },
    ],
  },
  {
    key: 'time', name: '시간 · 몰입', tag: 'Flow', emoji: '⏳', color: '#34d3c0',
    blurb: '깊게 몰입하고 리듬을 지키는 시간', prefixes: ['/flow', '/masters', '/sponge', '/world'],
    items: [
      { label: '몰입 · Flow', href: '/flow', d: '딥워크 타이머' },
      { label: '몰입의 거장', href: '/masters', d: '집중의 레퍼런스' },
      { label: '스폰지 시계', href: '/sponge', d: '나만의 리듬' },
      { label: '세계 시계', href: '/world', d: '지구 시간' },
    ],
  },
  {
    key: 'proj', name: '프로젝트', tag: 'Projects', emoji: '🚀', color: '#ffb457',
    blurb: '지금 굴러가는 만들기들', prefixes: ['/gtb', '/spongeclub', '/studio', '/reels', '/shell-studio'],
    items: [
      { label: '농구클럽 · GTB', href: '/gtb', d: '' },
      { label: '스폰지클럽', href: '/spongeclub', d: '' },
      { label: '캐러셀 스튜디오', href: '/studio', d: '슬라이드 만들기' },
      { label: '릴스 스튜디오', href: '/reels', d: '영상 프레임' },
      { label: '셸 스튜디오', href: '/shell-studio', d: '자동 셸 선물 봇' },
    ],
  },
  {
    key: 'rec', name: '기록 · 안내', tag: 'Logs', emoji: '📖', color: '#7fd67a',
    blurb: '이 시스템이 자라온 이야기', prefixes: ['/build-logs', '/how', '/log'],
    items: [
      { label: 'Build Logs', href: '/build-logs', d: '개발일지' },
      { label: '작동 방식', href: '/how', d: '어떻게 도는가' },
    ],
  },
];
const zonesJson = JSON.stringify(ZONES);
---
<Base title="놀이터">
  <section class="pg">
    <!-- ── 히어로: 캐릭터 인사 + 스탯 ─────────────── -->
    <header class="pg-hero">
      <div class="hero-left">
        <div class="ara" aria-hidden="true">
          <span class="ara-body">
            <span class="ara-eye l"></span><span class="ara-eye r"></span>
            <span class="ara-cheek l"></span><span class="ara-cheek r"></span>
          </span>
          <span class="ara-shadow"></span>
        </div>
        <div class="hero-say">
          <p class="bubble" id="araSay">오늘도 왔네요! 어디부터 가볼까요?</p>
          <h1>아라미러 놀이터</h1>
          <p class="hero-sub">구역을 골라 들어가고, 쓸수록 정원이 자라요.</p>
        </div>
      </div>
      <div class="stats" role="group" aria-label="내 성장 현황">
        <div class="stat"><b id="statLevel">1</b><span>레벨</span></div>
        <div class="stat"><b id="statStreak">0🔥</b><span>연속일</span></div>
        <div class="stat"><b id="statToday">0</b><span>오늘</span></div>
        <div class="stat"><b id="statTotal">0</b><span>누적</span></div>
      </div>
    </header>

    <div class="pg-body">
      <!-- ── 구역 타일 (반응형 그리드) ────────────── -->
      <div class="zones" id="zones">
        {ZONES.map((z) => (
          <button class="zone" type="button" data-key={z.key} style={`--zc:${z.color}`} aria-label={`${z.name} 열기`}>
            <span class="zone-glow" aria-hidden="true"></span>
            <span class="creature" aria-hidden="true">
              <span class="cr-body">
                <span class="cr-eye l"></span><span class="cr-eye r"></span>
                <span class="cr-cheek l"></span><span class="cr-cheek r"></span>
              </span>
              <span class="cr-badge">{z.emoji}</span>
            </span>
            <span class="zone-tx">
              <span class="zone-name">{z.name}</span>
              <span class="zone-blurb">{z.blurb}</span>
            </span>
            <span class="zone-meter" aria-hidden="true"><i style="width:0"></i></span>
            <span class="zone-foot">
              <span class="zone-count" data-count>0회 방문</span>
              <span class="zone-go">열기 →</span>
            </span>
          </button>
        ))}
      </div>

      <!-- ── 성장 정원 패널 ───────────────────────── -->
      <aside class="garden">
        <div class="garden-top">
          <h2>🌱 성장 정원</h2>
          <span class="stage-pill" id="stagePill">씨앗</span>
        </div>
        <div class="scene" id="scene" data-stage="0">
          <svg viewBox="0 0 240 210" width="100%" role="img" aria-label="활동으로 자라는 정원">
            <defs>
              <radialGradient id="sky" cx="50%" cy="35%" r="75%">
                <stop offset="0%" stop-color="rgba(255,180,87,.16)"/>
                <stop offset="100%" stop-color="rgba(255,180,87,0)"/>
              </radialGradient>
              <linearGradient id="stem" x1="0" y1="1" x2="0" y2="0">
                <stop offset="0%" stop-color="#5fae5b"/><stop offset="100%" stop-color="#8ce08a"/>
              </linearGradient>
            </defs>
            <circle cx="120" cy="80" r="96" fill="url(#sky)"/>
            <!-- 땅 -->
            <ellipse cx="120" cy="196" rx="96" ry="12" fill="rgba(0,0,0,.35)"/>
            <!-- 화분 -->
            <path d="M74 168 h92 l-9 30 a9 9 0 0 1-9 6 H92 a9 9 0 0 1-9-6 Z" fill="#8a5334"/>
            <path d="M74 168 h92 l-2 7 H76 Z" fill="#9c6440"/>
            <rect x="68" y="156" width="104" height="16" rx="6" fill="#a06a44"/>
            <ellipse cx="120" cy="158" rx="48" ry="7" fill="#3f2817"/>
            <!-- 씨앗 (stage 0) -->
            <g class="seed"><ellipse cx="120" cy="154" rx="7" ry="9" fill="#c9905a"/><path d="M120 148 v10" stroke="#8a5b34" stroke-width="1.4"/></g>
            <!-- 줄기+새싹 (1+) -->
            <g class="grow g1">
              <path d="M120 156 C120 138 120 128 120 112" stroke="url(#stem)" stroke-width="7" fill="none" stroke-linecap="round"/>
              <path d="M120 138 C104 132 92 138 90 150 C106 152 116 148 120 138 Z" fill="#8ce08a"/>
              <path d="M120 128 C136 122 148 128 150 140 C134 142 124 138 120 128 Z" fill="#7fd67a"/>
            </g>
            <!-- 잎 무성 (2+) -->
            <g class="grow g2">
              <path d="M120 116 C98 108 84 116 82 130 C104 132 116 124 120 116 Z" fill="#9be89a"/>
              <path d="M120 108 C142 100 156 108 158 122 C136 124 124 116 120 108 Z" fill="#72ca6d"/>
            </g>
            <!-- 봉오리 (3+) -->
            <g class="grow g3">
              <circle cx="120" cy="98" r="9" fill="#ffd27a"/>
              <circle cx="92" cy="122" r="7" fill="#ffcf6e"/><circle cx="148" cy="118" r="7" fill="#ffcf6e"/>
            </g>
            <!-- 꽃 (4+) -->
            <g class="grow g4 flowers">
              <g transform="translate(120 92)"><circle r="11" fill="#ff7a4d"/><circle r="5" fill="#ffe08a"/></g>
              <g transform="translate(90 118)"><circle r="8" fill="#ff9f6a"/><circle r="3.5" fill="#ffe08a"/></g>
              <g transform="translate(150 114)"><circle r="8" fill="#ff9f6a"/><circle r="3.5" fill="#ffe08a"/></g>
            </g>
            <!-- 큰 나무 캐노피 (5) -->
            <g class="grow g5">
              <circle cx="120" cy="72" r="36" fill="#69c164"/>
              <circle cx="88" cy="90" r="25" fill="#7fd67a"/><circle cx="152" cy="90" r="25" fill="#7fd67a"/>
              <circle cx="120" cy="60" r="10" fill="#ff7a4d"/><circle cx="100" cy="82" r="7" fill="#ffb457"/><circle cx="140" cy="82" r="7" fill="#ffb457"/>
            </g>
          </svg>
          <span class="firefly f1"></span><span class="firefly f2"></span><span class="firefly f3"></span>
        </div>
        <div class="xp"><i id="xpFill"></i></div>
        <p class="xp-line"><span id="xpText">0 / 3 XP</span></p>
        <p class="garden-note" id="gardenNote">구역을 열어 아라미러를 쓰면 정원이 자라나요.</p>
      </aside>
    </div>

    <!-- ── 자동화 허브 ──────────────────────────── -->
    <section class="hub">
      <h2>⚡ 자동화 허브</h2>
      <div class="hub-grid">
        <a class="hub-card" href="/shell-studio">
          <span class="hub-ic">🐚</span>
          <b>자동 셸 선물 봇</b>
          <small>매일 조원에게 셸을 공정하게 순환 전송</small>
          <span class="hub-go">셸 스튜디오 →</span>
        </a>
        <a class="hub-card" href="/build-logs">
          <span class="hub-ic">⚙️</span>
          <b>GitHub 자동 배포</b>
          <small>main → gh-pages, 빌드 산출물 라이브 반영</small>
          <span class="hub-go">기록 보기 →</span>
        </a>
        <a class="hub-card" href="/hq/index.html">
          <span class="hub-ic">📊</span>
          <b>관제실 통계</b>
          <small>프로젝트·자동화 상태 실시간 집계</small>
          <span class="hub-go">대시보드 →</span>
        </a>
      </div>
    </section>
  </section>

  <!-- ── 구역 메뉴 시트 (모달, 절대 안 잘림) ──────── -->
  <div class="sheet-back" id="sheetBack" hidden>
    <div class="sheet" role="dialog" aria-modal="true" aria-labelledby="sheetTitle">
      <div class="sheet-head">
        <span class="sheet-emoji" id="sheetEmoji">🎧</span>
        <div><h3 id="sheetTitle">구역</h3><p id="sheetBlurb"></p></div>
        <button class="sheet-x" id="sheetX" type="button" aria-label="닫기">✕</button>
      </div>
      <div class="sheet-list" id="sheetList"></div>
    </div>
  </div>

  <style is:global>
    .pg { max-width: 1160px; margin: 0 auto; padding: 88px 18px 64px; }

    /* ── 히어로 ── */
    .pg-hero { display: flex; align-items: center; justify-content: space-between; gap: 20px; flex-wrap: wrap; margin-bottom: 26px; }
    .hero-left { display: flex; align-items: center; gap: 18px; }
    .ara { position: relative; width: 66px; height: 62px; flex-shrink: 0; }
    .ara-body { position: absolute; inset: 0; border-radius: 50% 50% 47% 47%; background: linear-gradient(160deg, #fff8ee, #e7ddc9); box-shadow: inset 0 -7px 12px rgba(0,0,0,.15), 0 10px 22px rgba(0,0,0,.45); animation: bob 2.6s var(--ease) infinite; }
    .ara-eye { position: absolute; top: 26px; width: 8px; height: 11px; background: #2a2320; border-radius: 50%; animation: blink 4.5s infinite; }
    .ara-eye::after { content: ""; position: absolute; top: 1px; left: 1.5px; width: 3px; height: 3px; background: #fff; border-radius: 50%; }
    .ara-eye.l { left: 20px; } .ara-eye.r { right: 20px; }
    .ara-cheek { position: absolute; top: 35px; width: 8px; height: 5px; background: rgba(255,130,110,.5); border-radius: 50%; }
    .ara-cheek.l { left: 14px; } .ara-cheek.r { right: 14px; }
    .ara-shadow { position: absolute; left: 50%; bottom: -10px; width: 44px; height: 9px; transform: translateX(-50%); background: rgba(0,0,0,.4); border-radius: 50%; filter: blur(3px); }
    .hero-say .bubble { display: inline-block; font-size: .82rem; color: var(--fg); background: var(--bg-2); border: 1px solid var(--line); padding: 5px 12px; border-radius: 12px 12px 12px 3px; margin: 0 0 8px; }
    .hero-say h1 { font-size: 1.7rem; margin: 0; letter-spacing: -.02em; }
    .hero-sub { margin: 4px 0 0; color: var(--muted); font-size: .9rem; }
    .stats { display: flex; gap: 10px; }
    .stat { min-width: 66px; text-align: center; padding: 11px 8px; background: var(--bg-1); border: 1px solid var(--line); border-radius: 16px; }
    .stat b { display: block; font-family: var(--mono); font-size: 1.3rem; font-weight: 600; line-height: 1; font-variant-numeric: tabular-nums; }
    .stat span { display: block; margin-top: 5px; font-size: .7rem; color: var(--muted); }

    /* ── 본문 레이아웃 ── */
    .pg-body { display: grid; grid-template-columns: 1fr 300px; gap: 18px; align-items: start; }
    @media (max-width: 860px) { .pg-body { grid-template-columns: 1fr; } }

    /* ── 구역 타일 ── */
    .zones { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 14px; }
    .zone {
      position: relative; text-align: left; cursor: pointer; overflow: hidden;
      display: grid; grid-template-columns: auto 1fr; grid-template-rows: auto auto auto; gap: 4px 14px;
      padding: 18px; border-radius: 20px; color: var(--fg);
      background: linear-gradient(160deg, color-mix(in srgb, var(--zc) 12%, var(--bg-1)), var(--bg-1) 70%);
      border: 1px solid color-mix(in srgb, var(--zc) 30%, var(--line));
      transition: transform .2s var(--ease), box-shadow .2s var(--ease), border-color .2s;
    }
    .zone:hover, .zone:focus-visible { transform: translateY(-4px); border-color: var(--zc); box-shadow: 0 18px 40px rgba(0,0,0,.5); outline: none; }
    .zone:focus-visible { box-shadow: 0 0 0 2px var(--zc), 0 18px 40px rgba(0,0,0,.5); }
    .zone-glow { position: absolute; top: -30px; right: -30px; width: 130px; height: 130px; background: radial-gradient(circle, color-mix(in srgb, var(--zc) 45%, transparent), transparent 70%); opacity: .5; pointer-events: none; transition: opacity .2s; }
    .zone:hover .zone-glow { opacity: .85; }
    .creature { position: relative; grid-row: 1 / 3; width: 54px; height: 50px; }
    .cr-body { position: absolute; inset: 0; border-radius: 50% 50% 46% 46%; background: linear-gradient(160deg, color-mix(in srgb, var(--zc) 90%, #fff 10%), color-mix(in srgb, var(--zc) 66%, #000 34%)); box-shadow: inset 0 -6px 10px rgba(0,0,0,.28), 0 6px 14px rgba(0,0,0,.4); animation: bob 3s var(--ease) infinite; }
    .zone:hover .cr-body { animation-duration: 1.2s; }
    .cr-eye { position: absolute; top: 22px; width: 8px; height: 10px; background: #1a1620; border-radius: 50%; animation: blink 5s infinite; }
    .cr-eye::after { content: ""; position: absolute; top: 1px; left: 1.5px; width: 3px; height: 3px; background: #fff; border-radius: 50%; }
    .cr-eye.l { left: 15px; } .cr-eye.r { right: 15px; }
    .cr-cheek { position: absolute; top: 30px; width: 7px; height: 4px; background: rgba(255,120,120,.5); border-radius: 50%; }
    .cr-cheek.l { left: 10px; } .cr-cheek.r { right: 10px; }
    .cr-badge { position: absolute; top: -6px; right: -8px; width: 25px; height: 25px; font-size: .95rem; background: var(--bg); border: 1px solid var(--line); border-radius: 50%; display: grid; place-items: center; box-shadow: 0 3px 8px rgba(0,0,0,.45); }
    .zone-tx { grid-column: 2; display: flex; flex-direction: column; gap: 3px; align-self: center; }
    .zone-name { font-size: 1.02rem; font-weight: 700; letter-spacing: -.01em; }
    .zone-blurb { font-size: .78rem; color: var(--fg-soft); line-height: 1.4; }
    .zone-meter { grid-column: 1 / 3; height: 5px; border-radius: 999px; background: rgba(255,255,255,.06); overflow: hidden; margin-top: 6px; }
    .zone-meter i { display: block; height: 100%; border-radius: 999px; background: var(--zc); transition: width .8s var(--ease); }
    .zone-foot { grid-column: 1 / 3; display: flex; align-items: center; justify-content: space-between; margin-top: 2px; }
    .zone-count { font-family: var(--mono); font-size: .68rem; color: var(--muted); font-variant-numeric: tabular-nums; }
    .zone-go { font-size: .78rem; font-weight: 600; color: var(--zc); }

    /* ── 성장 정원 ── */
    .garden { background: var(--bg-1); border: 1px solid var(--line); border-radius: 22px; padding: 16px; position: sticky; top: 84px; }
    @media (max-width: 860px) { .garden { position: static; } }
    .garden-top { display: flex; align-items: center; justify-content: space-between; }
    .garden-top h2 { font-size: 1rem; margin: 0; }
    .stage-pill { font-family: var(--mono); font-size: .72rem; color: var(--a2); background: var(--accent-soft); padding: 3px 11px; border-radius: 999px; }
    .scene { position: relative; margin: 6px auto 4px; max-width: 240px; }
    .scene .grow { opacity: 0; transform: translateY(8px) scale(.55); transform-origin: 120px 158px; transition: opacity .7s var(--ease), transform .7s var(--ease); }
    .scene .seed { transition: opacity .5s; }
    .scene[data-stage="0"] .seed { opacity: 1; }
    .scene:not([data-stage="0"]) .seed { opacity: 0; }
    .scene[data-stage="1"] .g1,
    .scene[data-stage="2"] .g1, .scene[data-stage="2"] .g2,
    .scene[data-stage="3"] .g1, .scene[data-stage="3"] .g2, .scene[data-stage="3"] .g3,
    .scene[data-stage="4"] .g1, .scene[data-stage="4"] .g2, .scene[data-stage="4"] .g3, .scene[data-stage="4"] .g4,
    .scene[data-stage="5"] .g1, .scene[data-stage="5"] .g2, .scene[data-stage="5"] .g3, .scene[data-stage="5"] .g4, .scene[data-stage="5"] .g5
      { opacity: 1; transform: none; }
    .firefly { position: absolute; width: 5px; height: 5px; border-radius: 50%; background: #ffe08a; box-shadow: 0 0 8px 2px rgba(255,224,138,.7); opacity: 0; }
    .firefly.f1 { left: 22%; top: 30%; animation: float 6s ease-in-out infinite; }
    .firefly.f2 { left: 74%; top: 42%; animation: float 7.5s ease-in-out infinite 1.5s; }
    .firefly.f3 { left: 55%; top: 22%; animation: float 5.5s ease-in-out infinite .8s; }
    .xp { height: 9px; border-radius: 999px; background: var(--bg-2); border: 1px solid var(--line); overflow: hidden; margin-top: 4px; }
    .xp i { display: block; height: 100%; width: 6%; border-radius: 999px; background: var(--grad); transition: width .9s var(--ease); }
    .xp-line { margin: 8px 0 0; font-family: var(--mono); font-size: .74rem; color: var(--muted); font-variant-numeric: tabular-nums; }
    .garden-note { margin: 7px 0 0; font-size: .8rem; color: var(--fg-soft); line-height: 1.5; }

    /* ── 자동화 허브 ── */
    .hub { margin-top: 26px; }
    .hub > h2 { font-size: 1.05rem; margin: 0 0 12px; }
    .hub-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; }
    .hub-card { display: grid; gap: 4px; padding: 16px; border-radius: 18px; background: var(--bg-1); border: 1px solid var(--line); text-decoration: none; color: var(--fg); transition: transform .15s, border-color .15s, background .15s; }
    .hub-card:hover { transform: translateY(-3px); border-color: var(--accent); }
    .hub-ic { font-size: 1.5rem; }
    .hub-card b { font-size: .95rem; margin-top: 4px; }
    .hub-card small { font-size: .78rem; color: var(--muted); line-height: 1.45; }
    .hub-go { font-size: .8rem; font-weight: 600; color: var(--accent); margin-top: 6px; }

    /* ── 구역 시트 (모달) ── */
    .sheet-back { position: fixed; inset: 0; z-index: 200; display: grid; place-items: end center; background: rgba(4,4,7,.62); backdrop-filter: blur(4px); animation: fade .2s ease; }
    .sheet-back[hidden] { display: none; }
    @media (min-width: 620px) { .sheet-back { place-items: center; } }
    .sheet {
      width: 100%; max-width: 460px; max-height: 82vh; overflow-y: auto;
      background: var(--bg-1); border: 1px solid var(--line); border-radius: 24px 24px 0 0;
      box-shadow: 0 -20px 60px rgba(0,0,0,.6); padding: 20px; animation: sheetUp .28s var(--ease);
    }
    @media (min-width: 620px) { .sheet { border-radius: 24px; box-shadow: 0 30px 80px rgba(0,0,0,.6); animation: sheetPop .28s var(--ease); } }
    .sheet-head { display: flex; align-items: center; gap: 12px; margin-bottom: 14px; }
    .sheet-emoji { font-size: 1.7rem; width: 46px; height: 46px; display: grid; place-items: center; background: var(--bg-2); border: 1px solid var(--line); border-radius: 14px; }
    .sheet-head h3 { margin: 0; font-size: 1.15rem; }
    .sheet-head p { margin: 2px 0 0; font-size: .82rem; color: var(--muted); }
    .sheet-x { margin-left: auto; width: 34px; height: 34px; border-radius: 10px; background: var(--bg-2); border: 1px solid var(--line); color: var(--fg-soft); font-size: 1rem; cursor: pointer; }
    .sheet-x:hover { color: #fff; border-color: var(--accent); }
    .sheet-list { display: flex; flex-direction: column; gap: 8px; }
    .sheet-item { display: flex; align-items: center; gap: 12px; padding: 13px 15px; border-radius: 14px; background: var(--bg-2); border: 1px solid var(--line); text-decoration: none; color: var(--fg); transition: transform .14s, border-color .14s, background .14s; }
    .sheet-item:hover, .sheet-item:focus-visible { transform: translateX(4px); border-color: var(--zc, var(--accent)); background: color-mix(in srgb, var(--zc, var(--accent)) 12%, var(--bg-2)); outline: none; }
    .sheet-item .si-t { font-weight: 600; font-size: .95rem; }
    .sheet-item .si-d { font-size: .76rem; color: var(--muted); margin-top: 1px; }
    .sheet-item .si-go { margin-left: auto; color: var(--muted); }

    /* ── 애니메이션 ── */
    @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
    @keyframes blink { 0%,92%,100% { transform: scaleY(1); } 96% { transform: scaleY(.1); } }
    @keyframes float { 0%,100% { opacity: 0; transform: translate(0,0); } 30%,70% { opacity: .9; } 50% { transform: translate(6px,-12px); } }
    @keyframes fade { from { opacity: 0; } }
    @keyframes sheetUp { from { transform: translateY(40px); opacity: 0; } }
    @keyframes sheetPop { from { transform: scale(.94); opacity: 0; } }
    @media (prefers-reduced-motion: reduce) {
      .ara-body, .cr-body, .ara-eye, .cr-eye, .firefly { animation: none !important; }
      .sheet-back, .sheet, .zone, .hub-card { animation: none !important; transition: none !important; }
    }
  </style>

  <script is:inline define:vars={{ zonesJson }}>
    (function () {
      const ZONES = JSON.parse(zonesJson);
      const byKey = Object.fromEntries(ZONES.map((z) => [z.key, z]));
      const $ = (id) => document.getElementById(id);

      // ── 활동 로그 → 성장 ──
      function readEvents() { try { return JSON.parse(localStorage.getItem('aramirror.events.buffer.v1') || '[]'); } catch (_) { return []; } }
      function dayKey(iso) { const d = new Date(iso); return d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate(); }
      function streakOf(evs) {
        const days = new Set(evs.map((e) => dayKey(e.occurred_at)));
        let s = 0; const d = new Date();
        for (;;) { const k = d.getFullYear() + '-' + (d.getMonth() + 1) + '-' + d.getDate(); if (days.has(k)) { s++; d.setDate(d.getDate() - 1); } else break; }
        return s;
      }
      const STAGES = [0, 3, 10, 25, 60, 120];
      const NAMES = ['씨앗', '새싹', '잎', '봉오리', '꽃', '큰 나무'];
      const stageOf = (t) => { let s = 0; for (let i = 0; i < STAGES.length; i++) if (t >= STAGES[i]) s = i; return s; };

      function refresh() {
        const evs = readEvents();
        const total = evs.length;
        const today = evs.filter((e) => dayKey(e.occurred_at) === dayKey(new Date().toISOString())).length;
        const streak = streakOf(evs);
        const stage = stageOf(total);
        const level = Math.max(1, Math.floor(Math.sqrt(total)) + 1);

        $('statLevel').textContent = level;
        $('statStreak').textContent = streak + '🔥';
        $('statToday').textContent = today;
        $('statTotal').textContent = total;

        $('scene').setAttribute('data-stage', String(stage));
        $('stagePill').textContent = NAMES[stage];
        const isMax = stage >= STAGES.length - 1;
        const base = STAGES[stage], next = STAGES[Math.min(stage + 1, STAGES.length - 1)];
        const pct = isMax ? 100 : Math.round(((total - base) / (next - base)) * 100);
        $('xpFill').style.width = Math.max(6, pct) + '%';
        $('xpText').textContent = isMax ? '만개 완료 🌳' : (total + ' / ' + next + ' XP');
        $('gardenNote').textContent = total === 0
          ? '아직 씨앗이에요. 구역을 열어 아라미러를 써보면 새싹이 돋아요.'
          : (isMax ? '큰 나무로 자랐어요! 오늘도 ' + today + '번 활동했어요. 🌳'
                   : '누적 ' + total + '번 · ' + NAMES[stage] + ' 단계. ' + (next - total) + '번 더 쓰면 다음 단계!');

        // 구역별 방문수 → 미터/카운트
        document.querySelectorAll('.zone').forEach((el) => {
          const z = byKey[el.dataset.key];
          const n = evs.filter((e) => { const p = (e.payload && e.payload.path) || ''; return z.prefixes.some((pre) => p.indexOf(pre) === 0); }).length;
          el.querySelector('.zone-meter i').style.width = Math.min(100, n * 12) + '%';
          el.querySelector('[data-count]').textContent = n + '회 방문';
        });
      }

      // ── 구역 시트 열기/닫기 ──
      const back = $('sheetBack');
      let lastFocus = null;
      function openZone(key) {
        const z = byKey[key]; if (!z) return;
        lastFocus = document.activeElement;
        $('sheetEmoji').textContent = z.emoji;
        $('sheetTitle').textContent = z.name;
        $('sheetBlurb').textContent = z.blurb;
        document.querySelector('.sheet').style.setProperty('--zc', z.color);
        $('sheetList').innerHTML = z.items.map((it) =>
          '<a class="sheet-item" href="' + it.href + '" data-zone="' + z.key + '">' +
          '<span><span class="si-t">' + it.label + '</span>' + (it.d ? '<div class="si-d">' + it.d + '</div>' : '') + '</span>' +
          '<span class="si-go">→</span></a>'
        ).join('');
        $('sheetList').querySelectorAll('a').forEach((a) => a.addEventListener('click', () => {
          try { (window.aramLog || function () {})('zone_enter', { zone: a.dataset.zone, href: a.getAttribute('href') }); } catch (_) {}
        }));
        back.hidden = false;
        $('araSay').textContent = z.name + '! 좋은 선택이에요.';
        setTimeout(() => { const f = $('sheetList').querySelector('a'); if (f) f.focus(); }, 60);
      }
      function closeZone() { back.hidden = true; if (lastFocus) lastFocus.focus(); }

      document.querySelectorAll('.zone').forEach((el) => el.addEventListener('click', () => openZone(el.dataset.key)));
      $('sheetX').addEventListener('click', closeZone);
      back.addEventListener('click', (e) => { if (e.target === back) closeZone(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !back.hidden) closeZone(); });

      refresh();
      setTimeout(refresh, 400);
    })();
  </script>
</Base>
