    /* 스승 카드 색 띠 */
    .m-person.choi::before { background: linear-gradient(180deg, #8ad1b0, #58b894); }
    .m-person.ko::before { background: linear-gradient(180deg, #f0b866, #e6963a); }

    /* 자문 에이전트 — 질문 던지기 */
    .m-agent { margin: 34px 0 6px; padding: 26px 26px 24px; border: 1px solid var(--line);
      border-radius: 18px; background: var(--bg-1); position: relative; overflow: hidden; }
    .m-agent::before { content: ""; position: absolute; inset: 0 auto 0 0; width: 3px; background: var(--grad); }
    .m-agent-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 6px 12px; margin-bottom: 16px; }
    .m-agent-badge { font-family: var(--mono); font-size: 0.74rem; letter-spacing: 0.05em; color: var(--accent);
      font-weight: 600; }
    .m-agent-tip { margin: 0; font-size: 0.86rem; color: var(--muted); }
    .m-agent-q { font-size: 1.18rem; line-height: 1.6; font-weight: 600; color: var(--fg); letter-spacing: -0.02em;
      margin: 0 0 20px; min-height: 2.2em; transition: opacity .18s; }
    .m-agent-q.swap { opacity: 0; }
    .m-agent-q.asked { color: var(--fg); }
    .m-agent-q.asked::before { content: "\201C"; color: var(--accent); margin-right: 2px; }
    .m-agent-q.asked::after { content: "\201D"; color: var(--accent); }
    .m-agent-btn { font: inherit; font-size: 0.92rem; font-weight: 700; color: var(--fg);
      background: var(--bg-2); border: 1px solid var(--line); border-radius: 999px; padding: 10px 20px;
      cursor: pointer; transition: background .15s, transform .12s, border-color .15s; }
    .m-agent-btn:hover { background: var(--accent-soft); border-color: var(--accent); transform: translateY(-1px); }
    .m-agent-btn:active { transform: translateY(0); }

    .m-grid2 { grid-template-columns: 1fr 1fr; }
    .m-grid2 .m-num { color: var(--accent); font-weight: 600; }

    @media (max-width: 780px) {
      .m-two { grid-template-columns: 1fr; }
      .m-grid, .m-grid2 { grid-template-columns: 1fr; }
      .m-condrow { grid-template-columns: 64px 1fr; gap: 12px; }
      .m-section { padding: 54px 0; }
      .m-part { padding-top: 48px; }
      .m-part.alt2 { padding-top: 64px; }
    }
  </style>

  <script>
    // 자문형 에이전트 — 버튼을 누르면 그 스승의 철학으로 사장님에게 질문을 던진다.
    // 정적 사이트라 LLM 대신 인물별 질문 뱅크에서 (직전 질문과 안 겹치게) 하나를 던진다.
    const BANKS: Record<string, string[]> = {
      choi: [
        '지금 그 결정은 사장님의 ‘욕망’입니까, 남들이 옳다는 ‘정답’입니까?',
        '이건 남의 개념을 수입한 겁니까, 사장님이 직접 만든 개념입니까?',
        '지금 어느 ‘높이’에서 이 문제를 보고 있습니까? 한 단계 올라가면 뭐가 보입니까?',
        '정해진 답 안에 갇혀 있습니까, 아직 답이 없는 ‘경계’에 서 있습니까?',
        '사장님은 ‘사장님으로’ 존재한 적이 있습니까, 역할로만 살아왔습니까?',
        '남을 따라가는 기능을 키우는 중입니까, 앞서가는 시선을 키우는 중입니까?',
        '이 일을 왜 하는지, 사장님만의 언어로 설명할 수 있습니까?',
      ],
      ko: [
        '이 사업의 ‘본질’을 한 문장으로 말해보십시오. 못 하면 아직 시작 안 한 겁니다.',
        '오늘 죽는다면, 지금 붙잡은 일 중 무엇을 놓겠습니까? 그게 답입니다.',
        '이 결정, 요즘 유행하는 트렌드입니까 아니면 검증된 원리입니까?',
        '이건 손님에게 진짜 이득입니까, 사장님한테만 이득입니까?',
        '이번 주에 읽은 것 중 사업에 ‘한 개’라도 적용해봤습니까?',
        '벌여놓은 일이 너무 많지 않습니까? 죽음 앞에서도 남길 하나는 무엇입니까?',
        '고객이 진짜 사는 건 제품입니까, 그 뒤의 이유입니까?',
      ],
    };
    const idx: Record<string, number> = {};
    document.querySelectorAll<HTMLElement>('.m-agent').forEach((box) => {
      const key = box.dataset.agent || '';
      const bank = BANKS[key] || [];
      const q = box.querySelector<HTMLElement>('[data-role="q"]');
      const btn = box.querySelector<HTMLButtonElement>('[data-role="btn"]');
      if (!bank.length || !q || !btn) return;
      btn.addEventListener('click', () => {
        let next = Math.floor(Math.random() * bank.length);
        if (bank.length > 1 && next === idx[key]) next = (next + 1) % bank.length;
        idx[key] = next;
        q.classList.add('swap');
        setTimeout(() => {
          q.textContent = bank[next];
          q.classList.remove('swap');
          q.classList.add('asked');
        }, 160);
        btn.textContent = '다른 질문 →';
      });
    });
  </script>
</Base>
