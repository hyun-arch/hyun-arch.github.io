---
import Base from '../layouts/Base.astro';

// 되묻는 멘토 — Aramirror의 심장.
// AI는 답을 대신 주지 않는다. 되물어서, 사장님 안의 생각을 밖으로 꺼낸다.
// 5개 렌즈: 근거 · 반대 · 전제 · 확장 · 실행
const lenses = [
  { key: 'why',    label: '근거',  sub: '왜?',     color: '#ff6a3d' },
  { key: 'oppose', label: '반대',  sub: '정말?',   color: '#ff4d6d' },
  { key: 'assume', label: '전제',  sub: '당연히?', color: '#ffb457' },
  { key: 'expand', label: '확장',  sub: '그러면?', color: '#7db4ff' },
  { key: 'act',    label: '실행',  sub: '그래서?', color: '#6ee7a8' },
];
---
<Base title="되묻기 · 멘토">
  <section style="padding-top:88px; padding-bottom:40px">
    <div class="wrap ask-wrap">
      <p style="margin-bottom:14px">
        <a href="/mirror" style="color:var(--muted);text-decoration:none;font-size:0.9rem">← 전체 지도</a>
      </p>
      <p class="section-kicker" data-reveal>The Mentor</p>
      <h2 data-reveal="60">되묻기</h2>
      <p class="lead" data-reveal="120">
        생각을 던지면 답을 주지 않는다. <strong>되묻는다.</strong>
        다섯 방향(근거·반대·전제·확장·실행)에서 질문이 돌아온다.
        그 질문에 사장님이 답하면서 — 생각이 사장님 밖으로 꺼내지고, 단단해진다.
      </p>

      <!-- 입력: 마찰 0 -->
      <div class="throw" data-reveal="160">
        <textarea id="thought" rows="3"
          placeholder="지금 떠오른 생각을 그대로 던지세요. 정리 안 해도 돼요.&#10;예) 이번 워크샵을 해커톤으로 바꿀까 고민 중이다."></textarea>
        <div class="throw-row">
          <span class="hint" id="hint">Ctrl+Enter 로도 던질 수 있어요</span>
          <button id="throwBtn" class="btn accent">되물어줘 →</button>
        </div>
      </div>

      <!-- 되묻기 결과 -->
      <div id="answer" class="answer" hidden>
        <p class="echo">“<span id="echoText"></span>”</p>
        <div class="lens-grid" id="lensGrid">
          {lenses.map((l) => (
            <div class="lens" data-lens={l.key} style={`--lc:${l.color}`}>
              <div class="lens-head">
                <span class="lens-badge">{l.label}</span>
                <span class="lens-sub">{l.sub}</span>
              </div>
              <p class="lens-q"></p>
            </div>
          ))}
        </div>
        <div class="answer-actions">
          <button id="saveBtn" class="btn-outline">생각DB에 저장 ↓</button>
          <button id="reThrow" class="btn-ghost">다른 각도로 다시</button>
        </div>
      </div>
    </div>
  </section>

  <!-- 생각DB -->
  <section class="db-section">
    <div class="wrap ask-wrap">
      <div class="db-head">
        <div>
          <p class="section-kicker">My Thought DB</p>
          <h3 style="margin:4px 0 0">생각DB <span id="dbCount" class="db-count">0</span></h3>
        </div>
        <button id="clearDb" class="btn-ghost" hidden>전체 비우기</button>
      </div>
      <p class="lead" style="margin-top:8px">
        던진 생각은 이 기기에 그대로 쌓입니다. 출처는 곧 사장님입니다.
      </p>
      <div id="dbList" class="db-list"></div>
      <p id="dbEmpty" class="db-empty">아직 던진 생각이 없어요. 위에서 첫 생각을 던져보세요.</p>
    </div>
  </section>

  <style>
    .ask-wrap { max-width: 860px; }
    .throw {
      margin-top: 26px; background: var(--bg-2); border: 1px solid var(--line);
      border-radius: var(--radius); padding: 18px; transition: border-color .2s, box-shadow .2s;
    }
    .throw:focus-within { border-color: var(--accent); box-shadow: 0 0 0 4px var(--accent-soft); }
    #thought {
      width: 100%; background: transparent; border: 0; resize: vertical; color: var(--fg);
      font: inherit; font-size: 1.05rem; line-height: 1.6; outline: none; min-height: 78px;
    }
    #thought::placeholder { color: var(--faint); }
    .throw-row { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; gap: 12px; }
    .hint { color: var(--muted); font-size: 0.82rem; }

    .btn-ghost {
      background: none; border: 0; color: var(--muted); font: inherit; font-size: 0.9rem;
      cursor: pointer; padding: 8px 10px; border-radius: 10px;
    }
    .btn-ghost:hover { color: var(--fg); background: var(--bg-1); }

    .answer { margin-top: 30px; }
    .echo {
      font-size: 1.15rem; color: var(--fg); line-height: 1.5; margin: 0 0 22px;
      padding-left: 16px; border-left: 3px solid var(--accent);
    }
    .lens-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
    .lens {
      background: var(--bg-2); border: 1px solid var(--line); border-radius: 16px;
      padding: 18px; position: relative; overflow: hidden;
      opacity: 0; transform: translateY(10px); animation: lensIn .5s var(--ease) forwards;
    }
    .lens::before {
      content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 3px; background: var(--lc);
    }
    .lens:nth-child(1){animation-delay:.04s}.lens:nth-child(2){animation-delay:.12s}
    .lens:nth-child(3){animation-delay:.20s}.lens:nth-child(4){animation-delay:.28s}
    .lens:nth-child(5){animation-delay:.36s}
    @keyframes lensIn { to { opacity: 1; transform: none; } }
    .lens-head { display: flex; align-items: baseline; gap: 10px; margin-bottom: 10px; }
    .lens-badge {
      font-size: 0.78rem; font-weight: 700; color: var(--lc);
      border: 1px solid color-mix(in srgb, var(--lc) 40%, transparent);
      padding: 2px 9px; border-radius: 999px;
    }
    .lens-sub { font-family: var(--mono); font-size: 0.8rem; color: var(--muted); }
    .lens-q { margin: 0; font-size: 1rem; color: var(--fg-soft); line-height: 1.55; }

    .answer-actions { display: flex; gap: 10px; margin-top: 22px; flex-wrap: wrap; }

    .db-section { border-top: 1px solid var(--line-soft); margin-top: 20px; }
    .db-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 12px; }
    .db-count {
      display: inline-block; font-family: var(--mono); font-size: 0.9rem; color: var(--accent);
      background: var(--accent-soft); padding: 1px 10px; border-radius: 999px; vertical-align: middle;
    }
    .db-list { display: flex; flex-direction: column; gap: 12px; margin-top: 20px; }
    .db-card {
      background: var(--bg-2); border: 1px solid var(--line); border-radius: 14px; padding: 16px 18px;
    }
    .db-card .db-thought { margin: 0 0 8px; font-size: 1.02rem; color: var(--fg); line-height: 1.5; }
    .db-card .db-meta { display: flex; align-items: center; gap: 12px; }
    .db-card .db-date { font-family: var(--mono); font-size: 0.78rem; color: var(--muted); }
    .db-card .db-del {
      margin-left: auto; background: none; border: 0; color: var(--faint); cursor: pointer;
      font-size: 0.82rem; padding: 4px 8px; border-radius: 8px;
    }
    .db-card .db-del:hover { color: var(--a3); background: var(--bg-1); }
    .db-empty { color: var(--muted); margin-top: 20px; }

    @media (max-width: 640px) {
      .lens-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline>
    (function () {
      var K = 'aramirror.ask.';
      var thoughtEl = document.getElementById('thought');
      var throwBtn = document.getElementById('throwBtn');
      var answerEl = document.getElementById('answer');
      var echoEl = document.getElementById('echoText');
      var lensEls = Array.from(document.querySelectorAll('#lensGrid .lens'));
      var saveBtn = document.getElementById('saveBtn');
      var reThrow = document.getElementById('reThrow');
      var dbList = document.getElementById('dbList');
      var dbEmpty = document.getElementById('dbEmpty');
      var dbCount = document.getElementById('dbCount');
      var clearDb = document.getElementById('clearDb');
      var current = '';

      function get(k, d){ try { var v = localStorage.getItem(K+k); return v==null?d:JSON.parse(v); } catch(e){ return d; } }
      function set(k, v){ try { localStorage.setItem(K+k, JSON.stringify(v)); } catch(e){} }

      // ── 되묻기 엔진: 생각의 결을 읽고 5개 렌즈로 질문을 생성 ──
      // 답을 주지 않는다. 사장님이 스스로 답하게 만드는 질문만 돌려준다.
      function questionsFor(t) {
        var s = t.trim();
        var isDecision = /(할까|말까|고민|결정|택|골라|vs|아니면|둘 중|바꿀까|해야|말아야)/.test(s);
        var isPlan     = /(하겠|만들|시작|진행|추진|계획|론칭|출시|배포|도입)/.test(s);
        var isFeeling  = /(힘들|불안|답답|화나|지친|막막|두렵|설레|짜증|외로)/.test(s);
        var isBelief   = /(이다|중요|필요|맞다|옳|틀렸|해야 한다|본질|핵심)/.test(s);

        var Q = {
          why: [
            '왜 지금 이 생각이 떠올랐을까? 계기가 된 사건이 하나 있었나요?',
            '이게 사장님에게 왜 중요한가요? 한 줄로 말한다면?'
          ],
          oppose: [
            '정반대로 결정한다면, 그게 더 나은 경우는 어떤 상황일까요?',
            '이 생각이 틀렸다면, 가장 먼저 무엇 때문에 틀렸을까요?'
          ],
          assume: [
            '이 말 안에 “당연히 그렇다”고 깔고 있는 전제는 무엇인가요?',
            '그 전제가 사실이 아니라면, 결론이 어떻게 바뀌나요?'
          ],
          expand: [
            '이게 정말 이뤄지면, 그다음엔 무엇이 따라올까요?',
            '한 달 뒤·1년 뒤의 사장님이 이걸 본다면 뭐라고 할까요?'
          ],
          act: [
            '그래서 오늘, 딱 한 가지만 한다면 무엇인가요?',
            '가장 작게 시작할 수 있는 첫 한 걸음은?'
          ]
        };

        if (isDecision) {
          Q.why[0] = '두 선택지 각각, 사장님이 진짜로 얻고 싶은 건 무엇인가요?';
          Q.act[0] = '어느 쪽이든, 되돌릴 수 없게 되기 전에 시험해볼 방법이 있나요?';
        }
        if (isPlan) {
          Q.oppose[0] = '이걸 아예 안 한다면 무슨 일이 생기나요? 정말 그게 문제인가요?';
          Q.act[0] = '이번 주 안에 눈에 보이게 만들 수 있는 첫 조각은 무엇인가요?';
        }
        if (isFeeling) {
          Q.why[0] = '이 감정은 무엇이 채워지지 않아서 생겼을까요?';
          Q.assume[0] = '지금 사실이라고 믿고 있는 것 중, 아직 확인 안 된 건 무엇인가요?';
          Q.act[0] = '지금 이 순간을 1도라도 낫게 만들 작은 행동 하나는?';
        }
        if (isBelief) {
          Q.oppose[0] = '이 주장에 가장 강하게 반대하는 사람이 있다면, 뭐라고 할까요?';
          Q.assume[0] = '“이게 맞다”는 건 어떤 근거 위에 서 있나요? 그 근거는 튼튼한가요?';
        }

        var pick = function (arr) { return arr[0]; };
        return [
          pick(Q.why), pick(Q.oppose), pick(Q.assume), pick(Q.expand), pick(Q.act)
        ];
      }

      function renderAnswer(t) {
        current = t;
        echoEl.textContent = t;
        var qs = questionsFor(t);
        lensEls.forEach(function (el, i) {
          var q = el.querySelector('.lens-q');
          q.textContent = qs[i] || '';
          // 애니메이션 재시작
          el.style.animation = 'none'; void el.offsetWidth; el.style.animation = '';
        });
        answerEl.hidden = false;
        saveBtn.textContent = '생각DB에 저장 ↓';
        saveBtn.disabled = false;
      }

      function doThrow() {
        var t = thoughtEl.value.trim();
        if (!t) { thoughtEl.focus(); return; }
        renderAnswer(t);
        answerEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      throwBtn.addEventListener('click', doThrow);
      thoughtEl.addEventListener('keydown', function (e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); doThrow(); }
      });
      reThrow.addEventListener('click', doThrow);

      // ── 생각DB ──
      function db(){ return get('db', []); }
      function saveDb(list){ set('db', list); }

      function fmt(ts) {
        var d = new Date(ts);
        var p = function (n){ return (n<10?'0':'')+n; };
        return d.getFullYear() + '.' + p(d.getMonth()+1) + '.' + p(d.getDate()) + ' ' + p(d.getHours()) + ':' + p(d.getMinutes());
      }

      function renderDb() {
        var list = db();
        dbCount.textContent = list.length;
        clearDb.hidden = list.length === 0;
        dbEmpty.hidden = list.length !== 0;
        dbList.innerHTML = '';
        list.forEach(function (item) {
          var card = document.createElement('div');
          card.className = 'db-card';
          var p = document.createElement('p');
          p.className = 'db-thought';
          p.textContent = item.text;
          var meta = document.createElement('div');
          meta.className = 'db-meta';
          var date = document.createElement('span');
          date.className = 'db-date';
          date.textContent = fmt(item.ts);
          var del = document.createElement('button');
          del.className = 'db-del';
          del.textContent = '지우기';
          del.addEventListener('click', function () {
            saveDb(db().filter(function (x){ return x.id !== item.id; }));
            renderDb();
          });
          meta.appendChild(date); meta.appendChild(del);
          card.appendChild(p); card.appendChild(meta);
          dbList.appendChild(card);
        });
      }

      saveBtn.addEventListener('click', function () {
        if (!current) return;
        var list = db();
        list.unshift({ id: 'th_' + Date.now() + '_' + Math.floor(Math.random()*1e4), text: current, ts: Date.now() });
        saveDb(list);
        renderDb();
        saveBtn.textContent = '저장됨 ✓';
        saveBtn.disabled = true;
        thoughtEl.value = '';
      });

      clearDb.addEventListener('click', function () {
        if (db().length && confirm('생각DB를 전부 비울까요? 되돌릴 수 없어요.')) {
          saveDb([]); renderDb();
        }
      });

      renderDb();
    })();
  </script>
</Base>
